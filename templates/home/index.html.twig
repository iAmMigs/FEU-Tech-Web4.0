                                <span class="block text-slate-800 text-xl">24</span>
                            </div>
                        </div>
                        <div class="p-6">
                            <span class="text-feu-yellow font-bold text-sm">Exhibitions</span>
                            <h3 class="text-xl font-bold text-slate-800 mt-2 mb-3 hover:text-feu-green cursor-pointer transition-colors">Annual Student Research Expo</h3>
                            <p class="text-slate-500 text-sm mb-4">Showcasing the brightest capstone projects from our graduating engineering students.</p>
                        </div>
                    </div>
                    <!-- Event 3 -->
                    <div class="bg-white rounded-2xl overflow-hidden shadow-lg border border-slate-100 group">
                        <div class="relative h-48 overflow-hidden">
                            <img src="https://placehold.co/600x400/008348/FFF?text=Hackathon" alt="Event" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500">
                            <div class="absolute top-4 left-4 bg-white px-4 py-2 rounded-lg shadow-md font-bold text-center">
