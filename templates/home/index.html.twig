{% extends 'base.html.twig' %}

{% block body %}
<!-- Hero Section -->
<section id="top" class="relative w-full h-[80vh] min-h-[600px] flex items-center justify-center overflow-hidden">
    <!-- Banner Image Background -->
    <div class="absolute inset-0 z-0">
        <img src="/images/FEU_TECH.jpg" alt="Hero Background" class="w-full h-full object-cover opacity-80 mix-blend-multiply">
        <div class="absolute inset-0 bg-slate-900/60 mix-blend-multiply"></div>
    </div>
    
    <div class="relative z-10 text-center px-4 max-w-4xl mx-auto pb-20 md:pb-32">
        <span class="text-feu-yellow font-bold tracking-widest uppercase text-sm mb-4 block animate-bounce mt-16 md:mt-0">Welcome to FEU Institute of Technology</span>
        <h1 class="text-5xl md:text-7xl font-extrabold text-white mb-6 leading-tight drop-shadow-lg">
            Shape Your Future at <span class="text-transparent bg-clip-text bg-gradient-to-r from-feu-yellow to-yellow-200">FEU Tech</span>
        </h1>
        <p class="text-lg md:text-xl text-slate-200 mb-10 font-light max-w-2xl mx-auto drop-shadow-md">
            Join the premier engineering and computer studies institution. Discover world-class facilities and global opportunities.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="#apply" class="px-8 py-4 bg-feu-yellow text-slate-900 font-bold rounded-lg shadow-xl shadow-feu-yellow/20 hover:bg-yellow-400 hover:-translate-y-1 transition-all">
                Apply Now
            </a>
            <a href="#courses" class="px-8 py-4 bg-white/10 backdrop-blur-sm text-white font-bold rounded-lg border border-white/20 hover:bg-white/20 hover:-translate-y-1 transition-all">
                Explore Programs
            </a>
        </div>
    </div>
</section>

<!-- Characteristics/Services Section -->
<section class="py-20 bg-white relative -mt-16 z-20 mx-4 lg:mx-auto max-w-7xl rounded-2xl shadow-xl shadow-slate-200/50 border border-slate-100">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 px-8">
        <!-- Feature 1 -->
        <div class="group text-center p-6 rounded-xl hover:bg-slate-50 transition-colors">
            <div class="w-16 h-16 mx-auto bg-feu-green/10 text-feu-green rounded-full flex items-center justify-center mb-6 group-hover:scale-110 group-hover:bg-feu-green group-hover:text-white transition-all shadow-sm">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
            </div>
            <h4 class="text-xl font-bold text-slate-800 mb-3">Best Education</h4>
            <p class="text-slate-500 text-sm">Experience top-notch curriculum tailored to the demands of modern industries.</p>
        </div>
        <!-- Feature 2 -->
        <div class="group text-center p-6 rounded-xl hover:bg-slate-50 transition-colors">
            <div class="w-16 h-16 mx-auto bg-feu-green/10 text-feu-green rounded-full flex items-center justify-center mb-6 group-hover:scale-110 group-hover:bg-feu-green group-hover:text-white transition-all shadow-sm">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M12 14l9-5-9-5-9 5 9 5z"></path><path d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222"></path></svg>
            </div>
            <h4 class="text-xl font-bold text-slate-800 mb-3">Expert Faculty</h4>
            <p class="text-slate-500 text-sm">Learn straight from industry experts and highly qualified academicians.</p>
        </div>
        <!-- Feature 3 -->
        <div class="group text-center p-6 rounded-xl hover:bg-slate-50 transition-colors">
             <div class="w-16 h-16 mx-auto bg-feu-green/10 text-feu-green rounded-full flex items-center justify-center mb-6 group-hover:scale-110 group-hover:bg-feu-green group-hover:text-white transition-all shadow-sm">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
            </div>
            <h4 class="text-xl font-bold text-slate-800 mb-3">Modern Labs</h4>
            <p class="text-slate-500 text-sm">Gain hands-on experience using state-of-the-art technological facilities.</p>
        </div>
        <!-- Feature 4 -->
        <div class="group text-center p-6 rounded-xl hover:bg-slate-50 transition-colors">
            <div class="w-16 h-16 mx-auto bg-feu-green/10 text-feu-green rounded-full flex items-center justify-center mb-6 group-hover:scale-110 group-hover:bg-feu-green group-hover:text-white transition-all shadow-sm">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
            </div>
            <h4 class="text-xl font-bold text-slate-800 mb-3">Vibrant Community</h4>
            <p class="text-slate-500 text-sm">Engage in rich student life, organizations, and global network opportunities.</p>
        </div>
    </div>
</section>

<!-- Upcoming Events Section -->
<section id="meetings" class="py-24 bg-slate-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col md:flex-row justify-between items-end mb-12">
            <div>
                <span class="text-feu-green font-bold tracking-wider uppercase text-sm mb-2 block">What's Happening</span>
                <h2 class="text-4xl font-extrabold text-slate-800">Upcoming Events</h2>
            </div>
            <a href="#" class="mt-4 md:mt-0 px-6 py-3 border-2 border-feu-green text-feu-green font-bold rounded-lg hover:bg-feu-green hover:text-white transition-all shadow-sm">View All Events</a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            <!-- Event Card 1 -->
            <div class="bg-white rounded-2xl overflow-hidden shadow-lg border border-slate-100 group">
                <div class="relative h-48 overflow-hidden">
                    <img src="https://placehold.co/600x400/008348/FFF?text=Tech+Symposium" alt="Event" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500">
                    <div class="absolute top-4 left-4 bg-white px-4 py-2 rounded-lg shadow-md font-bold text-center">
                        <span class="block text-feu-green text-sm uppercase">Nov</span>
                        <span class="block text-slate-800 text-xl">10</span>
                    </div>
                </div>
                <div class="p-6">
                    <span class="text-feu-yellow font-bold text-sm">Seminars</span>
                    <h3 class="text-xl font-bold text-slate-800 mt-2 mb-3 hover:text-feu-green cursor-pointer transition-colors">National Tech Symposium 2026</h3>
                    <p class="text-slate-500 text-sm mb-4">Join industry leaders as they discuss the future of AI and Machine Learning innovations.</p>
                </div>
            </div>
            <!-- Event Card 2 -->
            <div class="bg-white rounded-2xl overflow-hidden shadow-lg border border-slate-100 group">
                <div class="relative h-48 overflow-hidden">
                    <img src="https://placehold.co/600x400/008348/FFF?text=Research+Expo" alt="Event" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500">
                    <div class="absolute top-4 left-4 bg-white px-4 py-2 rounded-lg shadow-md font-bold text-center">
                        <span class="block text-feu-green text-sm uppercase">Nov</span>
                        <span class="block text-slate-800 text-xl">24</span>
                    </div>
                </div>
                <div class="p-6">
                    <span class="text-feu-yellow font-bold text-sm">Exhibitions</span>
                    <h3 class="text-xl font-bold text-slate-800 mt-2 mb-3 hover:text-feu-green cursor-pointer transition-colors">Annual Student Research Expo</h3>
                    <p class="text-slate-500 text-sm mb-4">Showcasing the brightest capstone projects from our graduating engineering students.</p>
                </div>
            </div>
            <!-- Event Card 3 -->
            <div class="bg-white rounded-2xl overflow-hidden shadow-lg border border-slate-100 group">
                <div class="relative h-48 overflow-hidden">
                    <img src="https://placehold.co/600x400/008348/FFF?text=Hackathon" alt="Event" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500">
                    <div class="absolute top-4 left-4 bg-white px-4 py-2 rounded-lg shadow-md font-bold text-center">
                        <span class="block text-feu-green text-sm uppercase">Dec</span>
                        <span class="block text-slate-800 text-xl">05</span>
                    </div>
                </div>
                <div class="p-6">
                    <span class="text-feu-yellow font-bold text-sm">Competitions</span>
                    <h3 class="text-xl font-bold text-slate-800 mt-2 mb-3 hover:text-feu-green cursor-pointer transition-colors">iCreate Hackathon Series</h3>
                    <p class="text-slate-500 text-sm mb-4">A 48-hour coding marathon to solve real-world problems. Open to all students.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Apply Now Section (Modified based on feedback) -->
<section id="apply" class="py-24 bg-feu-green relative overflow-hidden">
    <!-- Abstract pattern -->
    <div class="absolute top-0 right-0 w-full h-full opacity-10 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-white via-transparent to-transparent pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="text-center mb-16">
            <h2 class="text-4xl md:text-5xl font-extrabold text-white mb-4">Launch Your Career Here</h2>
            <p class="text-xl text-feu-yellow font-light max-w-2xl mx-auto">Take the first step towards a successful career by applying to our premier degree programs.</p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 max-w-6xl mx-auto">
            <!-- Apply Card: Engineering -->
            <div class="bg-white rounded-2xl p-10 shadow-2xl hover:-translate-y-2 transition-transform duration-300 relative group overflow-hidden border-b-4 border-feu-yellow hover:border-teal-500 flex flex-col h-full">
                <div class="absolute top-0 right-0 bg-teal-100 text-teal-800 text-sm font-bold px-4 py-2 rounded-bl-lg">Pioneering</div>
                <div class="w-16 h-16 bg-teal-50 text-teal-600 rounded-2xl flex items-center justify-center mb-6 shadow-inner">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                </div>
                <h3 class="text-3xl font-extrabold text-slate-800 mb-4 tracking-tight leading-snug">College of Engineering</h3>
                <p class="text-slate-600 mb-10 text-lg flex-grow">Build the future with fully-accredited civil, electronics, mechanical, and computer engineering programs.</p>
                <div class="mt-auto">
                    <a href="#" class="inline-flex w-full justify-center items-center px-8 py-4 bg-feu-green text-white font-bold rounded-xl hover:bg-green-700 transition-colors group-hover:bg-teal-600 text-lg shadow-md hover:shadow-xl">
                        Explore Engineering <span class="ml-3 font-normal">→</span>
                    </a>
                </div>
            </div>

            <!-- Apply Card: Computer Studies & MMA -->
            <div class="bg-white rounded-2xl p-10 shadow-2xl hover:-translate-y-2 transition-transform duration-300 relative group overflow-hidden border-b-4 border-feu-yellow hover:border-purple-500 flex flex-col h-full">
               <div class="absolute top-0 right-0 bg-purple-100 text-purple-800 text-sm font-bold px-4 py-2 rounded-bl-lg">Innovation</div>
                <div class="w-16 h-16 bg-purple-50 text-purple-600 rounded-2xl flex items-center justify-center mb-6 shadow-inner">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path></svg>
                </div>
                <h3 class="text-3xl font-extrabold text-slate-800 mb-4 tracking-tight leading-snug">College of Computer Studies and Multimedia Arts</h3>
                <p class="text-slate-600 mb-10 text-lg flex-grow">Dive deep into software engineering, artificial intelligence, and premier creative multimedia programs.</p>
                 <div class="mt-auto">
                     <a href="#" class="inline-flex w-full justify-center items-center px-8 py-4 bg-feu-green text-white font-bold rounded-xl hover:bg-green-700 transition-colors group-hover:bg-purple-600 text-lg shadow-md hover:shadow-xl">
                        Explore CCS & MMA <span class="ml-3 font-normal">→</span>
                    </a>
                 </div>
            </div>
        </div>
    </div>
</section>

<!-- University Facts Section -->
<section class="py-24 bg-slate-900 border-b-4">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 text-center divide-y md:divide-y-0 md:divide-x divide-slate-800">
             <div class="p-6 transition-transform hover:scale-105">
                <div class="text-6xl font-extrabold text-feu-yellow mb-2">94%</div>
                <div class="text-slate-300 font-medium uppercase tracking-wide">Board Passers</div>
            </div>
            <div class="p-6 transition-transform hover:scale-105">
                <div class="text-6xl font-extrabold text-feu-green mb-2">126</div>
                <div class="text-slate-300 font-medium uppercase tracking-wide">Expert Faculty</div>
            </div>
            <div class="p-6 transition-transform hover:scale-105">
                <div class="text-6xl font-extrabold text-feu-yellow mb-2">2k+</div>
                <div class="text-slate-300 font-medium uppercase tracking-wide">New Students Yearly</div>
            </div>
            <div class="p-6 transition-transform hover:scale-105">
                <div class="text-6xl font-extrabold text-feu-green mb-2">32</div>
                <div class="text-slate-300 font-medium uppercase tracking-wide">Major Awards</div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
