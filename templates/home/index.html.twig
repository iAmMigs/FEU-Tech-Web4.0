{% extends 'base.html.twig' %}

{% block body %}
<!-- Hero Section -->
<section id="top" class="relative w-full h-[80vh] min-h-[600px] flex items-center justify-center overflow-hidden">
    <!-- Banner Image Background -->
    <div class="absolute inset-0 z-0">
        <img src="/images/FEU_TECH.jpg" alt="Hero Background" class="w-full h-full object-cover opacity-80 mix-blend-multiply">
        <div class="absolute inset-0 bg-slate-900/60 mix-blend-multiply"></div>
    </div>
    
    <div class="relative z-10 text-center px-4 max-w-4xl mx-auto pb-32">
        <span class="text-feu-yellow font-bold tracking-widest uppercase text-sm mb-4 block animate-bounce mt-8 md:mt-0">Welcome to FEU Institute of Technology</span>
        <h1 class="text-5xl md:text-7xl font-extrabold text-white mb-6 leading-tight drop-shadow-lg">
            Shape Your Future at <span class="text-transparent bg-clip-text bg-gradient-to-r from-feu-yellow to-yellow-200">FEU Tech</span>
        </h1>
        <p class="text-lg md:text-xl text-slate-200 mb-10 font-light max-w-2xl mx-auto drop-shadow-md">
            Join the premier engineering and computer studies institution. Discover world-class facilities and global opportunities.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="#apply" class="px-8 py-4 bg-feu-yellow text-slate-900 font-bold rounded-lg shadow-xl shadow-feu-yellow/20 hover:bg-yellow-400 hover:-translate-y-1 transition-all">
                Apply Now
            </a>
            <a href="#courses" class="px-8 py-4 bg-white/10 backdrop-blur-sm text-white font-bold rounded-lg border border-white/20 hover:bg-white/20 hover:-translate-y-1 transition-all">
                Explore Programs
            </a>
        </div>
    </div>
</section>

<!-- Characteristics/Services Section -->
<section class="relative z-20 mx-4 lg:mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 -mt-24 pb-12 scroll-animate">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Feature 1 -->
        <div class="bg-white rounded-3xl p-8 pt-14 text-center shadow-2xl relative mt-12 lg:mt-0">
            <div class="absolute -top-10 left-1/2 -translate-x-1/2 w-20 h-20 bg-[#008348] text-white rounded-full flex items-center justify-center border-[6px] border-white shadow-sm">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
            </div>
            <h4 class="text-xl font-bold text-slate-800 mb-3 tracking-tight">Best Education</h4>
            <p class="text-slate-500 text-sm leading-relaxed">Experience top-notch curriculum tailored to the demands of modern industries.</p>
        </div>
        <!-- Feature 2 -->
        <div class="bg-white rounded-3xl p-8 pt-14 text-center shadow-2xl relative mt-12 lg:mt-0">
            <div class="absolute -top-10 left-1/2 -translate-x-1/2 w-20 h-20 bg-[#f0b323] text-slate-900 rounded-full flex items-center justify-center border-[6px] border-white shadow-sm">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M12 14l9-5-9-5-9 5 9 5z"></path><path d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222"></path></svg>
            </div>
            <h4 class="text-xl font-bold text-slate-800 mb-3 tracking-tight">Expert Faculty</h4>
            <p class="text-slate-500 text-sm leading-relaxed">Learn straight from industry experts and highly qualified academicians.</p>
        </div>
        <!-- Feature 3 -->
        <div class="bg-white rounded-3xl p-8 pt-14 text-center shadow-2xl relative mt-12 lg:mt-0">
             <div class="absolute -top-10 left-1/2 -translate-x-1/2 w-20 h-20 bg-[#008348] text-white rounded-full flex items-center justify-center border-[6px] border-white shadow-sm">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
            </div>
            <h4 class="text-xl font-bold text-slate-800 mb-3 tracking-tight">Modern Labs</h4>
            <p class="text-slate-500 text-sm leading-relaxed">Gain hands-on experience using state-of-the-art technological facilities.</p>
        </div>
        <!-- Feature 4 -->
        <div class="bg-white rounded-3xl p-8 pt-14 text-center shadow-2xl relative mt-12 lg:mt-0">
            <div class="absolute -top-10 left-1/2 -translate-x-1/2 w-20 h-20 bg-[#f0b323] text-slate-900 rounded-full flex items-center justify-center border-[6px] border-white shadow-sm">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
            </div>
            <h4 class="text-xl font-bold text-slate-800 mb-3 tracking-tight">Vibrant Community</h4>
            <p class="text-slate-500 text-sm leading-relaxed">Engage in rich student life, organizations, and global network opportunities.</p>
        </div>
    </div>
</section>

<!-- Upcoming Events Section -->
<section id="meetings" class="py-24 bg-slate-50 scroll-animate">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col md:flex-row justify-between items-end mb-12">
            <div>
                <span class="text-feu-green font-bold tracking-wider uppercase text-sm mb-2 block">What's Happening</span>
                <h2 class="text-4xl font-extrabold text-slate-800">Upcoming Events</h2>
            </div>
            <a href="#" class="mt-4 md:mt-0 px-6 py-3 border-2 border-feu-green text-feu-green font-bold rounded-lg hover:bg-feu-green hover:text-white transition-all shadow-sm">View All Events</a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            <!-- Event Card 1 -->
            <div class="bg-white rounded-2xl overflow-hidden shadow-lg border border-slate-100 group">
                <div class="relative h-48 overflow-hidden">
                    <img src="https://placehold.co/600x400/008348/FFF?text=Tech+Symposium" alt="Event" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500">
                    <div class="absolute top-4 left-4 bg-white px-4 py-2 rounded-lg shadow-md font-bold text-center">
                        <span class="block text-feu-green text-sm uppercase">Nov</span>
                        <span class="block text-slate-800 text-xl">10</span>
                    </div>
                </div>
                <div class="p-6">
                    <span class="text-feu-yellow font-bold text-sm">Seminars</span>
                    <h3 class="text-xl font-bold text-slate-800 mt-2 mb-3 hover:text-feu-green cursor-pointer transition-colors">National Tech Symposium 2026</h3>
                    <p class="text-slate-500 text-sm mb-4">Join industry leaders as they discuss the future of AI and Machine Learning innovations.</p>
                </div>
            </div>
            <!-- Event Card 2 -->
            <div class="bg-white rounded-2xl overflow-hidden shadow-lg border border-slate-100 group">
                <div class="relative h-48 overflow-hidden">
                    <img src="https://placehold.co/600x400/008348/FFF?text=Research+Expo" alt="Event" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500">
                    <div class="absolute top-4 left-4 bg-white px-4 py-2 rounded-lg shadow-md font-bold text-center">
                        <span class="block text-feu-green text-sm uppercase">Nov</span>
                        <span class="block text-slate-800 text-xl">24</span>
                    </div>
                </div>
                <div class="p-6">
                    <span class="text-feu-yellow font-bold text-sm">Exhibitions</span>
                    <h3 class="text-xl font-bold text-slate-800 mt-2 mb-3 hover:text-feu-green cursor-pointer transition-colors">Annual Student Research Expo</h3>
                    <p class="text-slate-500 text-sm mb-4">Showcasing the brightest capstone projects from our graduating engineering students.</p>
                </div>
            </div>
            <!-- Event Card 3 -->
            <div class="bg-white rounded-2xl overflow-hidden shadow-lg border border-slate-100 group">
                <div class="relative h-48 overflow-hidden">
                    <img src="https://placehold.co/600x400/008348/FFF?text=Hackathon" alt="Event" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500">
                    <div class="absolute top-4 left-4 bg-white px-4 py-2 rounded-lg shadow-md font-bold text-center">
                        <span class="block text-feu-green text-sm uppercase">Dec</span>
                        <span class="block text-slate-800 text-xl">05</span>
                    </div>
                </div>
                <div class="p-6">
                    <span class="text-feu-yellow font-bold text-sm">Competitions</span>
                    <h3 class="text-xl font-bold text-slate-800 mt-2 mb-3 hover:text-feu-green cursor-pointer transition-colors">iCreate Hackathon Series</h3>
                    <p class="text-slate-500 text-sm mb-4">A 48-hour coding marathon to solve real-world problems. Open to all students.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Apply Now Section -->
<section id="apply" class="py-24 bg-[#008348] relative overflow-hidden border-t-4 border-feu-yellow scroll-animate">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 max-w-6xl mx-auto">
            
            <!-- Left Side - Apply Cards -->
            <div class="flex flex-col gap-6">
                <!-- Apply Card: Engineering -->
                <div class="bg-[#129658] rounded-3xl p-8 shadow-lg flex flex-col">
                    <h3 class="text-2xl font-extrabold text-white mb-4 uppercase tracking-wide">College of Engineering</h3>
                    <p class="text-white/90 mb-8 leading-relaxed pr-4">Build the future with fully-accredited civil, electronics, mechanical, and computer engineering programs. Take the first step towards a successful career.</p>
                    <div class="mt-auto">
                        <a href="#" class="inline-block px-8 py-3 bg-[#f0b323] text-slate-900 font-bold rounded-full hover:bg-yellow-400 transition-colors shadow-md">
                            Apply Now!
                        </a>
                    </div>
                </div>

                <!-- Apply Card: Computer Studies -->
                <div class="bg-[#129658] rounded-3xl p-8 shadow-lg flex flex-col">
                    <h3 class="text-2xl font-extrabold text-white mb-4 uppercase tracking-wide">College of Computer Studies</h3>
                    <p class="text-white/90 mb-8 leading-relaxed pr-4">Dive deep into software engineering, artificial intelligence, and premier creative multimedia programs. Lead the digital revolution.</p>
                     <div class="mt-auto">
                         <a href="#" class="inline-block px-8 py-3 bg-white text-[#008348] font-bold rounded-full hover:bg-slate-50 transition-colors shadow-md">
                            Apply Now!
                        </a>
                     </div>
                </div>
            </div>

            <!-- Right Side - Accordion -->
            <div class="bg-white rounded-[2rem] p-8 md:p-10 shadow-2xl flex flex-col justify-center">
                
                <!-- Accordion Item 1 (Expanded) -->
                <div class="border-b border-slate-100 pb-6 mb-6">
                    <button class="w-full flex justify-between items-center text-left group focus:outline-none">
                        <span class="text-[1.35rem] font-bold text-slate-800">About FEU Tech Experience</span>
                        <div class="w-8 h-8 rounded-full bg-[#008348] text-white flex items-center justify-center shadow-sm flex-shrink-0">
                            <svg class="w-5 h-5 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                        </div>
                    </button>
                    <div class="mt-6 text-slate-500 leading-relaxed text-[0.95rem] pr-2">
                        At FEU Tech, we're more than a school — we're a launchpad for your future. We push boundaries and shape industry leaders through fully-accredited engineering, computer science, and multimedia programs. Here, you don't just learn — you build, innovate, and lead.
                    </div>
                </div>

                <!-- Accordion Item 2 -->
                <div class="border-b border-slate-100 pb-6 mb-6">
                    <button class="w-full flex justify-between items-center text-left group focus:outline-none hover:text-[#008348] transition-colors">
                        <span class="text-[1.35rem] font-bold text-slate-800 group-hover:text-[#008348] transition-colors">Campus Life</span>
                        <div class="w-8 h-8 rounded-full bg-slate-50 text-slate-400 flex items-center justify-center group-hover:bg-slate-100 group-hover:text-[#008348] transition-colors flex-shrink-0">
                            <svg class="w-5 h-5 -rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                        </div>
                    </button>
                </div>

                <!-- Accordion Item 3 -->
                <div class="border-b border-slate-100 pb-6 mb-6">
                    <button class="w-full flex justify-between items-center text-left group focus:outline-none hover:text-[#008348] transition-colors">
                        <span class="text-[1.35rem] font-bold text-slate-800 group-hover:text-[#008348] transition-colors">Student Organizations</span>
                        <div class="w-8 h-8 rounded-full bg-slate-50 text-slate-400 flex items-center justify-center group-hover:bg-slate-100 group-hover:text-[#008348] transition-colors flex-shrink-0">
                            <svg class="w-5 h-5 -rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                        </div>
                    </button>
                </div>

                <!-- Accordion Item 4 -->
                <div class="pt-2">
                    <button class="w-full flex justify-between items-center text-left group focus:outline-none hover:text-[#008348] transition-colors">
                        <span class="text-[1.35rem] font-bold text-slate-800 group-hover:text-[#008348] transition-colors">Regular Events</span>
                        <div class="w-8 h-8 rounded-full bg-slate-50 text-slate-400 flex items-center justify-center group-hover:bg-slate-100 group-hover:text-[#008348] transition-colors flex-shrink-0">
                            <svg class="w-5 h-5 -rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                        </div>
                    </button>
                </div>

            </div>
        </div>
    </div>
</section>

<!-- University Facts Section -->
<section class="py-24 bg-slate-900 border-t-4 border-feu-yellow scroll-animate">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col lg:flex-row gap-12 items-center">
            <!-- Left Side - Facts Grid -->
            <div class="lg:w-1/2">
                <div class="mb-12">
                    <h2 class="text-4xl md:text-5xl font-extrabold text-white tracking-tight">Why FEU Institute of Technology?</h2>
                </div>
                <div class="grid grid-cols-2 gap-8 text-center">
                     <div class="bg-slate-800 p-8 rounded-[2rem] shadow-lg hover:bg-slate-700 transition-colors">
                        <div class="text-5xl md:text-6xl font-extrabold text-feu-yellow mb-3 counter-animate" data-target="94" data-suffix="%">0%</div>
                        <div class="text-slate-300 font-medium tracking-wide">Board Passers</div>
                    </div>
                    <div class="bg-slate-800 p-8 rounded-[2rem] shadow-lg hover:bg-slate-700 transition-colors">
                        <div class="text-5xl md:text-6xl font-extrabold text-feu-green mb-3 counter-animate" data-target="126">0</div>
                        <div class="text-slate-300 font-medium tracking-wide">Current Teachers</div>
                    </div>
                    <div class="bg-slate-800 p-8 rounded-[2rem] shadow-lg hover:bg-slate-700 transition-colors">
                        <div class="text-5xl md:text-6xl font-extrabold text-feu-green mb-3 counter-animate" data-target="2k+">0</div>
                        <div class="text-slate-300 font-medium tracking-wide">New Students</div>
                    </div>
                    <div class="bg-slate-800 p-8 rounded-[2rem] shadow-lg hover:bg-slate-700 transition-colors">
                        <div class="text-5xl md:text-6xl font-extrabold text-feu-yellow mb-3 counter-animate" data-target="32">0</div>
                        <div class="text-slate-300 font-medium tracking-wide">Awards</div>
                    </div>
                </div>
            </div>
            
            <!-- Right Side - Video Placeholder -->
            <div class="lg:w-1/2 w-full">
                <div class="relative rounded-[2rem] overflow-hidden shadow-2xl group cursor-pointer border-4 border-slate-800">
                    <img src="/images/FEU_TECH.jpg" alt="University Video" class="w-full h-[300px] md:h-[400px] object-cover group-hover:scale-105 transition-transform duration-700">
                    <div class="absolute inset-0 bg-slate-900/40 group-hover:bg-slate-900/20 transition-colors flex items-center justify-center">
                        <a href="https://www.youtube.com/watch?v=HndV87XpkWg" target="_blank" class="w-20 h-20 bg-white/30 backdrop-blur-md rounded-full flex items-center justify-center text-white border-2 border-white/50 group-hover:scale-110 group-hover:bg-feu-yellow group-hover:border-feu-yellow group-hover:text-slate-900 transition-all shadow-xl">
                            <svg class="w-8 h-8 ml-1" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
