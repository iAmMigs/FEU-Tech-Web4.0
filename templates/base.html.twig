<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
        <title>{% block title %}FEU Institute of Technology{% endblock %}</title>
        <link rel="icon" href="https://feutech.edu.ph/assets/img/logo/feutech-icon.png">
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@100;200;300;400;500;600;700;800;900&display=swap" rel="stylesheet">
        
        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}

        {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
        {% if frankenphpHotReload %}
        <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
        <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
        <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
        {% endif %}
    </head>
    <body class="flex flex-col min-h-screen">
        <!-- Sub Header -->
        <div class="bg-feu-green text-white py-2 text-sm shadow-inner relative z-50">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex justify-between items-center">
                <div class="hidden sm:block">
                    <p class="font-medium">Welcome to <span class="text-feu-yellow">FEU Institute of Technology</span> - Where Education meets Innovation</p>
                </div>
                <div class="flex space-x-6">
                    <a href="#" class="hover:text-feu-yellow transition-colors font-medium">Facebook</a>
                    <a href="#" class="hover:text-feu-yellow transition-colors font-medium">Twitter</a>
                    <a href="#" class="hover:text-feu-yellow transition-colors font-medium">LinkedIn</a>
                </div>
            </div>
        </div>

        <!-- Main Header Area -->
        <header class="sticky top-0 z-50 bg-white/95 backdrop-blur-md shadow-sm border-b border-gray-100 transition-all duration-300">
            <div class="max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8">
                <div class="flex justify-between items-center h-20">
                    <!-- Logo Start -->
                    <a href="/" class="flex-shrink-0 flex items-center gap-3 group mr-4 lg:mr-8">
                        <img src="/images/Tech_Logo.png" alt="FEU Tech Logo" class="h-10 w-auto group-hover:scale-105 transition-transform drop-shadow-md">
                        <img src="/images/Tech_Text.png" alt="FEU Tech Text" class="h-6 md:h-7 w-auto group-hover:opacity-80 transition-opacity">
                    </a>
                    
                    <!-- Menu Start -->
                    <nav class="hidden md:flex space-x-4 lg:space-x-6 items-center">
                        <a href="/" class="whitespace-nowrap text-feu-green font-semibold hover:text-feu-green relative after:absolute after:bottom-[-4px] after:left-0 after:w-full after:h-0.5 after:bg-feu-green">HOME</a>
                        
                        <!-- ABOUT Dropdown -->
                        <div class="relative group mt-1">
                            <button class="whitespace-nowrap text-slate-600 font-medium hover:text-feu-green transition-colors flex items-center gap-1 uppercase pb-1 relative after:absolute after:bottom-[-4px] after:left-0 after:w-0 hover:after:w-full after:h-0.5 after:bg-feu-yellow after:transition-all">
                                ABOUT <svg class="w-4 h-4 ml-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                            </button>
                            <div class="absolute left-0 mt-0 w-48 bg-white border border-slate-100 shadow-xl rounded-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all transform origin-top-left translate-y-2 group-hover:translate-y-0 z-50">
                                <div class="py-2 flex flex-col min-h-[40px]">
                                    <!-- Empty for now -->
                                </div>
                            </div>
                        </div>

                        <!-- ADMISSION Dropdown -->
                        <div class="relative group mt-1">
                            <button class="whitespace-nowrap text-slate-600 font-medium hover:text-feu-green transition-colors flex items-center gap-1 uppercase pb-1 relative after:absolute after:bottom-[-4px] after:left-0 after:w-0 hover:after:w-full after:h-0.5 after:bg-feu-yellow after:transition-all">
                                ADMISSION <svg class="w-4 h-4 ml-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                            </button>
                            <div class="absolute left-0 mt-0 w-48 bg-white border border-slate-100 shadow-xl rounded-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all transform origin-top-left translate-y-2 group-hover:translate-y-0 z-50">
                                <div class="py-2 flex flex-col min-h-[40px]">
                                    <!-- Empty for now -->
                                </div>
                            </div>
                        </div>

                        <!-- ACADEMICS Dropdown -->
                        <div class="relative group mt-1">
                            <button class="whitespace-nowrap text-slate-600 font-medium hover:text-feu-green transition-colors flex items-center gap-1 uppercase pb-1 relative after:absolute after:bottom-[-4px] after:left-0 after:w-0 hover:after:w-full after:h-0.5 after:bg-feu-yellow after:transition-all">
                                ACADEMICS <svg class="w-4 h-4 ml-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                            </button>
                            <div class="absolute left-0 mt-0 w-48 bg-white border border-slate-100 shadow-xl rounded-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all transform origin-top-left translate-y-2 group-hover:translate-y-0 z-50">
                                <div class="py-2 flex flex-col min-h-[40px]">
                                    <!-- Empty for now -->
                                </div>
                            </div>
                        </div>

                        <!-- FACILITIES Dropdown -->
                        <div class="relative group mt-1">
                            <button class="whitespace-nowrap text-slate-600 font-medium hover:text-feu-green transition-colors flex items-center gap-1 uppercase pb-1 relative after:absolute after:bottom-[-4px] after:left-0 after:w-0 hover:after:w-full after:h-0.5 after:bg-feu-yellow after:transition-all">
                                FACILITIES <svg class="w-4 h-4 ml-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                            </button>
                            <div class="absolute left-0 mt-0 w-48 bg-white border border-slate-100 shadow-xl rounded-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all transform origin-top-left translate-y-2 group-hover:translate-y-0 z-50">
                                <div class="py-2 flex flex-col min-h-[40px]">
                                    <!-- Empty for now -->
                                </div>
                            </div>
                        </div>

                        <a href="#contact" class="whitespace-nowrap text-slate-600 font-medium hover:text-feu-green transition-colors uppercase relative after:absolute after:bottom-[-4px] after:left-0 after:w-0 hover:after:w-full after:h-0.5 after:bg-feu-yellow after:transition-all">CONTACT US</a>
                    </nav>

                    <div class="md:hidden flex items-center">
                        <button class="text-slate-600 hover:text-feu-green focus:outline-none p-2 bg-slate-100 rounded-lg">
                            <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
                        </button>
                    </div>
                </div>
            </div>
        </header>

        <!-- Main Content -->
        <main class="flex-grow w-full relative">
            {% block body %}{% endblock %}
        </main>

        <!-- Footer -->
        <footer class="bg-[#0f172a] text-slate-400 py-16 border-t-4 border-feu-green mt-auto relative overflow-hidden">
            <!-- Footer subtle background element -->
            <div class="absolute right-0 bottom-0 w-96 h-96 bg-feu-green opacity-5 rounded-tl-full pointer-events-none"></div>

            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
                <div class="grid grid-cols-1 md:grid-cols-4 gap-12">
                    <div class="col-span-1 md:col-span-2">
                        <div class="flex items-center gap-3 mb-6">
                            <div class="brightness-0 invert flex items-center gap-3">
                                <img src="/images/Tech_Logo.png" alt="FEU Tech Logo" class="h-10 w-auto opacity-90">
                                <img src="/images/Tech_Text.png" alt="FEU Tech Text" class="h-8 w-auto opacity-90 hidden sm:block">
                            </div>
                        </div>
                        <p class="text-sm leading-relaxed mb-6 max-w-sm text-slate-400">
                            Providing quality education in the fields of Engineering and Computer Studies. We aim to produce globally competitive graduates equipped with strong core values.
                        </p>
                        <div class="flex space-x-4">
                            <a href="#" class="w-10 h-10 rounded-full bg-slate-800 flex items-center justify-center hover:bg-feu-green hover:text-white transition-all text-slate-400"><span class="sr-only">Facebook</span>f</a>
                            <a href="#" class="w-10 h-10 rounded-full bg-slate-800 flex items-center justify-center hover:bg-feu-green hover:text-white transition-all text-slate-400"><span class="sr-only">Twitter</span>t</a>
                            <a href="#" class="w-10 h-10 rounded-full bg-slate-800 flex items-center justify-center hover:bg-feu-green hover:text-white transition-all text-slate-400"><span class="sr-only">LinkedIn</span>in</a>
                        </div>
                    </div>
                    <div>
                        <h4 class="text-white text-lg font-bold mb-6 relative inline-block after:absolute after:bottom-[-8px] after:left-0 after:w-1/2 after:h-1 after:bg-feu-yellow">Quick Links</h4>
                        <ul class="space-y-3 text-sm">
                            <li><a href="#" class="hover:text-feu-yellow transition-colors flex items-center gap-2"><span class="text-feu-green text-xs">▹</span> About Us</a></li>
                            <li><a href="#" class="hover:text-feu-yellow transition-colors flex items-center gap-2"><span class="text-feu-green text-xs">▹</span> Admissions</a></li>
                            <li><a href="#" class="hover:text-feu-yellow transition-colors flex items-center gap-2"><span class="text-feu-green text-xs">▹</span> Academic Programs</a></li>
                            <li><a href="#" class="hover:text-feu-yellow transition-colors flex items-center gap-2"><span class="text-feu-green text-xs">▹</span> Student Life</a></li>
                        </ul>
                    </div>
                    <div>
                        <h4 class="text-white text-lg font-bold mb-6 relative inline-block after:absolute after:bottom-[-8px] after:left-0 after:w-1/2 after:h-1 after:bg-feu-yellow">Contact Info</h4>
                        <ul class="space-y-4 text-sm">
                            <li class="flex items-start gap-3">
                                <span class="mt-1 text-feu-yellow">📍</span>
                                <span>P. Paredes St., Sampaloc, Manila, Philippines 1008</span>
                            </li>
                            <li class="flex items-start gap-3">
                                <span class="mt-1 text-feu-yellow">📞</span>
                                <span>(02) 8281-8888</span>
                            </li>
                            <li class="flex items-start gap-3">
                                <span class="mt-1 text-feu-yellow">✉️</span>
                                <span>info@feutech.edu.ph</span>
                            </li>
                        </ul>
                    </div>
                </div>
                <div class="mt-16 pt-8 border-t border-slate-800/50 flex flex-col md:flex-row justify-between items-center text-sm text-slate-500">
                    <p>&copy; {{ 'now'|date('Y') }} FEU Institute of Technology. All Rights Reserved.</p>
                    <p class="mt-2 md:mt-0">Inspired by TemplateMo &bull; Powered by Symfony & Tailwind</p>
                </div>
            </div>
        </footer>
    </body>
</html>
