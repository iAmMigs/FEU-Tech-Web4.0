            <button class="cat-btn px-6 py-2 rounded-full font-semibold text-sm transition-colors bg-white text-slate-600 hover:bg-slate-100 border border-slate-200" data-filter="financials">Financials & Scholarships</button>
            <button class="cat-btn px-6 py-2 rounded-full font-semibold text-sm transition-colors bg-white text-slate-600 hover:bg-slate-100 border border-slate-200" data-filter="academics">Academics</button>
        </div>

        <!-- FAQ Container -->
        <div id="faq-container" class="space-y-4">
            
            <!-- No Results State -->
            <div id="no-results" class="hidden text-center py-12">
