<section class="relative w-full h-[50vh] min-h-[400px] flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 z-0">
        <img src="/images/FEU-TECHBLD.jpg" alt="FEU Tech Building" class="w-full h-full object-cover transform scale-105">
        <div class="absolute inset-0 bg-slate-900/75 mix-blend-multiply"></div>
        <div class="absolute inset-0 bg-gradient-to-t from-slate-900 via-transparent to-transparent opacity-80"></div>
        <div class="absolute bottom-0 left-0 right-0 h-1.5 bg-gradient-to-r from-[#008348] via-[#febe10] to-[#008348]"></div>
    </div>

    <div class="relative z-10 text-center px-5 max-w-4xl mx-auto">
        <span class="text-feu-yellow font-bold tracking-widest uppercase text-sm mb-4 block">
            Admissions
        </span>
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-black text-white leading-tight drop-shadow-2xl uppercase tracking-wider mb-4">
            Tuition & Fees
        </h1>
        <p class="text-slate-300 text-lg md:text-xl font-light max-w-2xl mx-auto">
            Convenient and secure payment options for your educational journey.
        </p>
    </div>
</section>

