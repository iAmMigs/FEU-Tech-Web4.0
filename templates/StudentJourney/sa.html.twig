{% extends 'base.html.twig' %}

{% block title %}Student Activities and Development - FEU Institute of Technology{% endblock %}

{% block body %}
<style>
    :root {
        --feu-green: #008348;
        --feu-yellow: #febe10;
    }

    /* Gradient Text */
    .text-gradient {
        background-clip: text;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-image: linear-gradient(to right, var(--feu-green), #00b362);
    }

    /* Card Hover Lift */
    .hover-lift {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .hover-lift:hover {
        transform: translateY(-8px);
        box-shadow: 0 20px 40px -10px rgba(0, 131, 72, 0.15);
    }
</style>

<!-- Hero Section -->
<section id="top" class="relative w-full h-[50vh] min-h-[400px] flex items-center justify-center overflow-hidden bg-slate-900">
    <div class="absolute inset-0 z-0">
        <img src="/images/FACILITIES_TECH.jpg" alt="Student Life" class="w-full h-full object-cover opacity-40 mix-blend-overlay">
        <div class="absolute inset-0 bg-gradient-to-t from-slate-900 via-slate-900/60 to-transparent"></div>
    </div>

    <div class="relative z-10 text-center px-5 max-w-5xl mx-auto">
        <span class="text-[#febe10] font-bold tracking-[0.3em] uppercase text-xs mb-4 block">
            Student Journey
        </span>
        <h1 class="text-5xl md:text-7xl font-black text-white leading-tight uppercase tracking-tighter">
            Student <span class="text-[#febe10]">Activities</span> & Development
        </h1>
        <p class="mt-6 text-slate-300 text-lg max-w-3xl mx-auto font-light leading-relaxed">
            Developing students to become effective leaders, efficient followers, and active contributors to society.
        </p>
        <div class="w-24 h-1 bg-[#febe10] mx-auto mt-8 rounded-full"></div>
    </div>
</section>

<!-- Vision & Mission Section -->
<section class="py-20 bg-slate-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-24">
            <!-- Vision -->
            <div class="bg-white p-10 rounded-3xl shadow-sm border border-slate-100 relative overflow-hidden group">
                <div class="absolute top-0 right-0 w-32 h-32 bg-green-50 rounded-bl-[100px] -z-10 group-hover:scale-110 transition-transform"></div>
                <div class="flex items-center gap-4 mb-6">
                    <div class="w-12 h-12 bg-feu-green text-white rounded-2xl flex items-center justify-center shadow-lg shadow-green-200">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                    </div>
                    <h2 class="text-3xl font-black text-slate-900 uppercase">Vision</h2>
                </div>
                <p class="text-slate-600 leading-relaxed text-lg">
                    A recognized premier provider of holistic development programs that produce effective, dynamic, transformational and innovative leaders of the society.
                </p>
            </div>

            <!-- Mission -->
            <div class="bg-white p-10 rounded-3xl shadow-sm border border-slate-100 relative overflow-hidden group">
                <div class="absolute top-0 right-0 w-32 h-32 bg-yellow-50 rounded-bl-[100px] -z-10 group-hover:scale-110 transition-transform"></div>
                <div class="flex items-center gap-4 mb-6">
                    <div class="w-12 h-12 bg-[#febe10] text-slate-900 rounded-2xl flex items-center justify-center shadow-lg shadow-yellow-200/50">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21l-7-5-7 5V5a2 2 0 012-2h10a2 2 0 012 2v16z"></path></svg>
                    </div>
                    <h2 class="text-3xl font-black text-slate-900 uppercase">Mission</h2>
                </div>
                <ul class="space-y-4 text-slate-600 text-lg">
                    <li class="flex items-start gap-3">
                        <svg class="w-6 h-6 text-feu-green flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                        To mold innovative leaders guided by values of Fortitude, Excellence, and Uprightness.
                    </li>
                    <li class="flex items-start gap-3">
                        <svg class="w-6 h-6 text-feu-green flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                        To conduct exemplary programs for student development.
                    </li>
                    <li class="flex items-start gap-3">
                        <svg class="w-6 h-6 text-feu-green flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                        To provide opportunities in academic excellence, leadership, community service, diversity, and innovation.
                    </li>
                </ul>
            </div>
        </div>
    </div>
</section>

<!-- The Mantra -->
<section class="py-24 bg-white relative overflow-hidden">
    <!-- Mascot Integration -->
    <div class="absolute top-[20%] right-[5%] opacity-40 z-0 hidden lg:block hover:opacity-100 transition-opacity duration-300">
        <img src="/images/Tamtam/Megaphone_Tammy.png" alt="Tammy" class="w-72 h-auto transform rotate-6">
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="text-center mb-16">
            <h2 class="text-4xl md:text-5xl font-black text-slate-900 uppercase tracking-tight mb-4">The <span class="text-gradient">Mantra</span></h2>
            <div class="w-24 h-1 bg-slate-200 mx-auto rounded-full"></div>
        </div>

        <div class="space-y-16 max-w-5xl mx-auto">
            <!-- Serve -->
            <div class="flex flex-col md:flex-row gap-8 items-start">
                <div class="md:w-1/3 flex-shrink-0">
                    <div class="text-6xl md:text-8xl font-black text-slate-100 tracking-tighter uppercase relative">
                        Serve
                        <h3 class="absolute inset-0 flex items-center text-3xl md:text-4xl text-feu-green ml-4 mt-2">Serve</h3>
                    </div>
                </div>
                <div class="md:w-2/3 pt-4 md:pt-8 border-t border-slate-100 md:border-none">
                    <p class="text-slate-600 text-lg leading-relaxed">
                        Programs of SADU are geared toward creating a community of leaders who are passionate, proactive, innovative, and ever ready to be of service to others. "Service to others is the essence of success. The measure of anyone is the number of people that they serve."
                    </p>
                </div>
            </div>

            <!-- Lead -->
            <div class="flex flex-col md:flex-row gap-8 items-start">
                <div class="md:w-1/3 flex-shrink-0">
                    <div class="text-6xl md:text-8xl font-black text-slate-100 tracking-tighter uppercase relative">
                        Lead
                        <h3 class="absolute inset-0 flex items-center text-3xl md:text-4xl text-feu-yellow ml-4 mt-2">Lead</h3>
                    </div>
                </div>
                <div class="md:w-2/3 pt-4 md:pt-8 border-t border-slate-100 md:border-none">
                    <p class="text-slate-600 text-lg leading-relaxed">
                        Leaders exhibit a unique blend of charisma, vision, and character traits that attract people. The unit aims not only to create good followers; it aims to produce leaders who will take charge of every situation.
                    </p>
                </div>
            </div>

            <!-- Excel -->
            <div class="flex flex-col md:flex-row gap-8 items-start">
                <div class="md:w-1/3 flex-shrink-0">
                    <div class="text-6xl md:text-8xl font-black text-slate-100 tracking-tighter uppercase relative">
                        Excel
                        <h3 class="absolute inset-0 flex items-center text-3xl md:text-4xl text-feu-green ml-4 mt-2">Excel</h3>
                    </div>
                </div>
                <div class="md:w-2/3 pt-4 md:pt-8 border-t border-slate-100 md:border-none">
                    <p class="text-slate-600 text-lg leading-relaxed">
                        FEU TECH student leaders are expected to imbibe excellence in their personal lives. Student Leaders imbibe the culture of Excellence by defining vision and mission, collaborating, acquiring effective communication skills, and having an innovative mindset.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Components Section (Development & Activities) -->
<section class="py-20 bg-slate-900 relative">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            
            <!-- Student Development -->
            <div class="bg-white/5 border border-white/10 p-10 rounded-3xl hover-lift">
                <h3 class="text-2xl font-bold text-white mb-6 uppercase tracking-wider flex items-center gap-3">
                    <span class="w-3 h-3 rounded-full bg-feu-green"></span>
                    Student Development
                </h3>
                <p class="text-slate-400 mb-8 line-clamp-3">Creates programs that encourage formation in social, spiritual, cultural, technological, and recreational aspects.</p>
                
                <ul class="space-y-4 text-slate-300">
                    <li class="flex items-center gap-3"><svg class="w-5 h-5 text-feu-yellow" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg> Holistic Development</li>
                    <li class="flex items-center gap-3"><svg class="w-5 h-5 text-feu-yellow" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg> Leadership Training Seminar</li>
                    <li class="flex items-center gap-3"><svg class="w-5 h-5 text-feu-yellow" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg> Efficiency Training</li>
                    <li class="flex items-center gap-3"><svg class="w-5 h-5 text-feu-yellow" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg> Personality Enhancement</li>
                    <li class="flex items-center gap-3"><svg class="w-5 h-5 text-feu-yellow" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg> Athletics</li>
                </ul>
            </div>

            <!-- Student Activities -->
            <div class="bg-white/5 border border-white/10 p-10 rounded-3xl hover-lift">
                <h3 class="text-2xl font-bold text-white mb-6 uppercase tracking-wider flex items-center gap-3">
                    <span class="w-3 h-3 rounded-full bg-[#febe10]"></span>
                    Student Activities
                </h3>
                <p class="text-slate-400 mb-8 line-clamp-3">Supervises and regulates the operations of Recognized Student Organizations and Special Interest Groups.</p>
                
                <ul class="space-y-4 text-slate-300">
                    <li class="flex items-center gap-3"><svg class="w-5 h-5 text-feu-green" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg> Accreditation of Organizations</li>
                    <li class="flex items-center gap-3"><svg class="w-5 h-5 text-feu-green" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg> Recognition of Organization Advisers</li>
                    <li class="flex items-center gap-3"><svg class="w-5 h-5 text-feu-green" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg> Approval of Student Activities</li>
                    <li class="flex items-center gap-3"><svg class="w-5 h-5 text-feu-green" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg> Social Media Postings Approval</li>
                    <li class="flex items-center gap-3"><svg class="w-5 h-5 text-feu-green" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg> Contingency Selection for Conventions</li>
                </ul>
            </div>

        </div>
    </div>
</section>

<!-- Contact Section -->
<section class="py-16 bg-feu-green text-white relative overflow-hidden">
    <!-- Subtle Background Elements -->
    <div class="absolute -right-20 -top-20 w-64 h-64 border-4 border-white/10 rounded-full"></div>
    <div class="absolute -left-10 -bottom-20 w-48 h-48 border-4 border-white/10 rounded-full"></div>

    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center">
        <h2 class="text-3xl font-black uppercase mb-8 tracking-wider">Contact Student Affairs</h2>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
            <div class="p-6 bg-white/10 rounded-2xl backdrop-blur-sm border border-white/20 hover:bg-white/20 transition-colors">
                <svg class="w-8 h-8 mx-auto mb-4 text-feu-yellow" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path></svg>
                <p class="font-bold">Location</p>
                <p class="text-sm text-green-100 mt-2">Room 1501</p>
            </div>
            <div class="p-6 bg-white/10 rounded-2xl backdrop-blur-sm border border-white/20 hover:bg-white/20 transition-colors">
                <svg class="w-8 h-8 mx-auto mb-4 text-feu-yellow" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                <p class="font-bold">Phone</p>
                <p class="text-sm text-green-100 mt-2">(02) 8281 8888 Local 128</p>
            </div>
            <div class="p-6 bg-white/10 rounded-2xl backdrop-blur-sm border border-white/20 hover:bg-white/20 transition-colors">
                <svg class="w-8 h-8 mx-auto mb-4 text-feu-yellow" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                <p class="font-bold">Email</p>
                <a href="mailto:sadu@feutech.edu.ph" class="text-sm text-green-100 mt-2 hover:text-white transition-colors">sadu@feutech.edu.ph</a>
            </div>
        </div>
    </div>
</section>

{% endblock %}
