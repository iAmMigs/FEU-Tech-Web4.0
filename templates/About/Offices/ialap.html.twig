{% extends 'base.html.twig' %}

{% block title %}Linkages | FEU Tech{% endblock %}

{% block body %}

<!-- HERO SECTION -->
<section class="relative w-full h-[55vh] min-h-[480px] flex items-end justify-center overflow-hidden">

    <!-- Background -->
    <div class="absolute inset-0 z-0">
        <img 
            src="/images/offices/offices.png" 
            alt="Industry-Academe Linkage, Alumni, and Placement Office"
            class="w-full h-full object-cover"
        >

        <!-- Overlay -->
        <div class="absolute inset-0 z-10 bg-black/60"></div>

        <!-- Accent -->
        <div class="absolute bottom-0 left-0 right-0 h-1 bg-gradient-to-r from-[#008348] via-[#febe10] to-[#008348]"></div>
    </div>

    <!-- Decorative Pattern -->
    <div class="absolute inset-0 z-[1] opacity-[0.04] pointer-events-none"
         style="background-image:url('data:image/svg+xml,%3Csvg width=%2760%27 height=%2760%27 viewBox=%270 0 60 60%27 xmlns=%27http://www.w3.org/2000/svg%27%3E%3Cg fill=%27none%27 fill-rule=%27evenodd%27%3E%3Cg fill=%27%23ffffff%27 fill-opacity=%271%27%3E%3Ccircle cx=%2730%27 cy=%2730%27 r=%272%27/%3E%3C/g%3E%3C/g%3E%3C/svg%3E'); background-size:30px 30px;">
    </div>

    <!-- Content -->
    <div class="relative z-10 text-center px-6 max-w-5xl mx-auto pb-14 md:pb-20">

        <span class="text-feu-yellow font-bold tracking-widest uppercase text-sm mb-4 block animate-bounce mt-8 md:mt-0">
            Offices
        </span>

        <h1 class="text-2xl md:text-6xl lg:text-7xl font-extrabold text-white uppercase leading-tight tracking-wide drop-shadow-xl">
             Industry-Academe Linkage, Alumni, and Placement Office
        </h1>

        <p class="mt-6 text-slate-200 text-base md:text-lg max-w-3xl mx-auto leading-relaxed">
            The Industry-Academe Linkage, Alumni, and Placement Office manages partnerships and alumni relations
            to provide students and graduates with meaningful industry exposure and career opportunities.
        </p>
    </div>
</section>


<!-- OVERVIEW SECTION -->
<section class="py-24 bg-gradient-to-b from-slate-50 to-white relative overflow-hidden">

    <!-- Background Accent -->
    <div class="absolute top-0 left-0 w-72 h-72 bg-feu-green opacity-5 rounded-full blur-3xl -translate-x-1/2 -translate-y-1/2"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">


        <!-- MAIN GRID -->
        <div class="grid grid-cols-1 xl:grid-cols-5 gap-8">

            <!-- LEFT CONTENT -->
            <div class="xl:col-span-3 bg-white rounded-[2rem] border border-slate-200 shadow-xl overflow-hidden">

                <!-- Accent -->
                <div class="h-1 bg-gradient-to-r from-feu-green via-feu-yellow to-feu-green"></div>

                <div class="p-8 md:p-12">

                    <!-- Badge -->
                    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-emerald-50 border border-emerald-100 mb-8">
                        <div class="w-2 h-2 rounded-full bg-feu-green"></div>

                        <span class="text-feu-green text-sm font-bold uppercase tracking-wide">
                            Overview
                        </span>
                    </div>

                    <!-- Intro -->
                    <h3 class="text-3xl font-extrabold text-slate-800 leading-tight mb-6">
                        Building Strong Academe and Industry Partnerships
                    </h3>

                    <!-- Paragraphs -->
                    <div class="space-y-6 text-slate-600 leading-relaxed text-[15px]">

                        <p>
                            The Industry-Academe Linkage, Alumni, and Placement Office (IALAP) oversees partnership programs
                            and alumni relations of the institution.
                        </p>

                        <p>
                            IALAP provides opportunities for students, associates, and alumni to gain practical experience
                            through collaborative projects with academic and industry partners, including internships,
                            faculty immersion, research, student exchange, and project-based learning.
                        </p>

                        <p>
                            The office also supports alumni placement by connecting graduates with employment opportunities,
                            organizing recruitment activities, and coordinating with industry partners and the Alumni Steering Committee
                            for seminars, training, and community engagement programs.
                        </p>
                    </div>

                    <!-- Stats -->
                    <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 mt-10">

                        <div class="bg-slate-50 border border-slate-100 rounded-2xl p-5">
                            <h4 class="text-2xl font-black text-feu-green">
                                Partnerships
                            </h4>

                            <p class="text-sm text-slate-500 mt-2">
                                Managing academic and industry collaboration programs
                            </p>
                        </div>

                        <div class="bg-slate-50 border border-slate-100 rounded-2xl p-5">
                            <h4 class="text-3xl font-black text-slate-800">
                                Experience
                            </h4>

                            <p class="text-sm text-slate-500 mt-2">
                                Supporting internships, immersion, and project-based learning
                            </p>
                        </div>

                        <div class="bg-slate-50 border border-slate-100 rounded-2xl p-5">
                            <h4 class="text-2xl font-black text-feu-green">
                                Careers
                            </h4>

                            <p class="text-sm text-slate-500 mt-2">
                                Linking alumni to employment and recruitment opportunities
                            </p>
                        </div>

                    </div>

                </div>
            </div>

            <!-- OFFICE INFO -->
            <div class="xl:col-span-2 relative overflow-hidden rounded-[2rem] shadow-2xl">

                <!-- Background -->
                <div class="absolute inset-0 bg-feu-green"></div>

                <!-- Glow -->
                <div class="absolute -top-16 -right-16 w-72 h-72 bg-feu-yellow/10 rounded-full blur-3xl"></div>
                <div class="absolute bottom-0 left-0 w-60 h-60 bg-white/5 rounded-full blur-3xl"></div>

                <!-- Content -->
                <div class="relative z-10 p-8 md:p-10 text-white h-full flex flex-col">

                    <!-- Header -->
                    <div class="flex items-center gap-4 mb-10">

                        <div class="w-16 h-16 rounded-2xl bg-white/10 border border-white/10 flex items-center justify-center backdrop-blur">

                            <svg class="w-8 h-8 text-feu-yellow"
                                 fill="none"
                                 stroke="currentColor"
                                 viewBox="0 0 24 24">

                                <path stroke-linecap="round"
                                      stroke-linejoin="round"
                                      stroke-width="2"
                                      d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/>
                            </svg>
                        </div>

                        <div>
                            <h3 class="text-3xl font-extrabold mt-1">
                                Office Information
                            </h3>
                        </div>
                    </div>

                    <!-- Cards -->
                    <div class="space-y-5">

                        <!-- LOCATION -->
                        <div class="group bg-white/5 hover:bg-white/10 border border-white/10 rounded-3xl p-6 transition-all duration-300 backdrop-blur-sm">

                            <div class="flex items-start gap-5">

                                <div class="w-14 h-14 rounded-2xl bg-feu-yellow text-slate-900 flex items-center justify-center font-black text-lg shadow-lg">
                                    01
                                </div>

                                <div class="flex-1">

                                    <h4 class="font-bold text-lg mb-2">
                                        Office Location
                                    </h4>

                                    <p class="text-slate-300 text-sm leading-relaxed">
                                        Industry-Academe Linkage, Alumni, and Placement Office <br>
                                        Room 1601
                                    </p>

                                </div>
                            </div>
                        </div>

                        <!-- HOURS -->
                        <div class="group bg-white/5 hover:bg-white/10 border border-white/10 rounded-3xl p-6 transition-all duration-300 backdrop-blur-sm">

                            <div class="flex items-start gap-5">

                                <div class="w-14 h-14 rounded-2xl bg-feu-yellow text-slate-900 flex items-center justify-center font-black text-lg shadow-lg">
                                    02
                                </div>

                                <div class="flex-1">

                                    <h4 class="font-bold text-lg mb-2">
                                        Office Hours
                                    </h4>

                                    <p class="text-slate-300 text-sm leading-relaxed">
                                        Monday to Friday <br>
                                        8:00 a.m. – 5:00 p.m.
                                    </p>

                                </div>
                            </div>
                        </div>

                        <!-- CONTACT -->
                        <div class="group bg-white/5 hover:bg-white/10 border border-white/10 rounded-3xl p-6 transition-all duration-300 backdrop-blur-sm">

                            <div class="flex items-start gap-5">

                                <div class="w-14 h-14 rounded-2xl bg-feu-yellow text-slate-900 flex items-center justify-center font-black text-lg shadow-lg">
                                    03
                                </div>

                                <div class="flex-1">

                                    <h4 class="font-bold text-lg mb-2">
                                        Contact Information
                                    </h4>

                                    <p class="text-slate-300 text-sm mb-4">
                                        (02) 8281 8888 Local 119
                                    </p>

                                    <a href="mailto:ialap@feutech.edu.ph"
                                       class="inline-flex items-center gap-2 text-feu-yellow font-semibold hover:text-yellow-300 transition">

                                        ialap@feutech.edu.ph

                                        <svg class="w-4 h-4"
                                             fill="none"
                                             stroke="currentColor"
                                             viewBox="0 0 24 24">

                                            <path stroke-linecap="round"
                                                  stroke-linejoin="round"
                                                  stroke-width="2"
                                                  d="M5 12h14">
                                            </path>

                                            <path stroke-linecap="round"
                                                  stroke-linejoin="round"
                                                  stroke-width="2"
                                                  d="M13 6l6 6-6 6">
                                            </path>
                                        </svg>
                                    </a>

                                </div>
                            </div>
                        </div>

                    </div>

                    <!-- Bottom Notice -->
                    <div class="mt-8 bg-white/5 border border-white/10 rounded-3xl p-6 backdrop-blur-sm">

                        <div class="flex items-start gap-4">

                            <div class="w-10 h-10 rounded-xl bg-feu-yellow text-slate-900 flex items-center justify-center flex-shrink-0">

                                <svg class="w-5 h-5"
                                     fill="currentColor"
                                     viewBox="0 0 20 20">

                                    <path fill-rule="evenodd"
                                          d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z"
                                          clip-rule="evenodd">
                                    </path>
                                </svg>
                            </div>

                            <p class="text-sm text-slate-300 leading-relaxed">
                                IALAP strengthens academe-industry collaboration and supports alumni development
                                by providing partnerships, training opportunities, and employment linkages.
                            </p>

                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</section>

{% endblock %}