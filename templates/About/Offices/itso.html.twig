{% extends 'base.html.twig' %}

{% block title %}Information Technology Services Office | FEU Tech{% endblock %}

{% block body %}

<section class="relative w-full h-[58vh] min-h-[450px] flex items-end justify-center overflow-hidden">

    <div class="absolute inset-0 z-0">
        <img 
            src="/images/EXECUTIVE_TECH.jpg" 
            alt="Information Technology Services Office"
            class="w-full h-full object-cover"
        >

        <div class="absolute inset-0 bg-gradient-to-b from-slate-950/80 via-slate-900/75 to-[#00351e]/95"></div>

        <div class="absolute bottom-0 left-0 right-0 h-1 bg-gradient-to-r from-[#008348] via-[#febe10] to-[#008348]"></div>
    </div>

    <div class="absolute inset-0 z-[1] opacity-[0.05] pointer-events-none"
         style="background-image:url('data:image/svg+xml,%3Csvg width=%2760%27 height=%2760%27 viewBox=%270 0 60 60%27 xmlns=%27http://www.w3.org/2000/svg%27%3E%3Cg fill=%27none%27 fill-rule=%27evenodd%27%3E%3Cg fill=%27%23ffffff%27 fill-opacity=%271%27%3E%3Ccircle cx=%2730%27 cy=%2730%27 r=%272%27/%3E%3C/g%3E%3C/g%3E%3C/svg%3E'); background-size:30px 30px;">
    </div>

    <div class="relative z-10 text-center px-6 max-w-5xl mx-auto pb-16 md:pb-24">

        <span class="text-feu-yellow font-bold tracking-widest uppercase text-sm mb-4 block animate-bounce mt-8 md:mt-0">
            Offices
        </span>

        <h1 class="text-4xl md:text-6xl lg:text-7xl font-extrabold text-white uppercase leading-tight tracking-wide drop-shadow-xl">
            Information Technology Services Office
        </h1>

        <p class="mt-6 text-slate-200 text-base md:text-lg max-w-3xl mx-auto leading-relaxed">
            Handles, manages, and governs the IT infrastructure and resources of the Institute while providing technical support, systems development, and IT operational services.
        </p>

    </div>
</section>

<!-- OVERVIEW SECTION -->
<section class="py-28 lg:py-32 bg-gradient-to-b from-slate-50 to-white relative overflow-hidden">

    <div class="absolute top-0 left-0 w-72 h-72 bg-feu-green opacity-5 rounded-full blur-3xl -translate-x-1/2 -translate-y-1/2"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">

        <div class="grid grid-cols-1 xl:grid-cols-5 gap-8">

            <!-- LEFT CONTENT -->
            <div class="xl:col-span-3 bg-white rounded-[2rem] border border-slate-200 shadow-xl overflow-hidden">

                <div class="h-1 bg-gradient-to-r from-feu-green via-feu-yellow to-feu-green"></div>

                <div class="p-8 md:p-12">

                    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-emerald-50 border border-emerald-100 mb-8">
                        <div class="w-2 h-2 rounded-full bg-feu-green"></div>

                        <span class="text-feu-green text-sm font-bold uppercase tracking-wide">
                            Overview
                        </span>
                    </div>

                    <h3 class="text-3xl font-extrabold text-slate-800 leading-tight mb-6">
                        Supporting the Institute Through Technology and Innovation
                    </h3>

                    <div class="space-y-6 text-slate-600 leading-relaxed text-[15px]">

                        <p>
                            The Information Technology Services Office (ITSO) is responsible for handling, managing, and governing the Institute’s IT infrastructure and resources to ensure efficient and reliable technology services for the academic community.
                        </p>

                        <p>
                            ITSO is composed of the Infrastructure Team, Systems Development Team, and IT Services and Operations Team, working together to maintain ICT facilities, develop systems and applications, and provide technical support services.
                        </p>

                        <p>
                            The office also supervises the Computer Services Unit and the Management Information Systems Unit in supporting academic and administrative operations through technology solutions and digital innovation.
                        </p>

                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 mt-10">

                        <div class="bg-slate-50 border border-slate-100 rounded-2xl p-5">
                            <h4 class="text-3xl font-black text-feu-green">3</h4>
                            <p class="text-sm text-slate-500 mt-2">Major IT service clusters</p>
                        </div>

                        <div class="bg-slate-50 border border-slate-100 rounded-2xl p-5">
                            <h4 class="text-3xl font-black text-slate-800">24/7</h4>
                            <p class="text-sm text-slate-500 mt-2">Network monitoring and support</p>
                        </div>

                        <div class="bg-slate-50 border border-slate-100 rounded-2xl p-5">
                            <h4 class="text-3xl font-black text-feu-green">Campus</h4>
                            <p class="text-sm text-slate-500 mt-2">Technology infrastructure management</p>
                        </div>

                    </div>

                </div>
            </div>

            <!-- OFFICE INFO -->
            <div class="xl:col-span-2 relative overflow-hidden rounded-[2rem] shadow-2xl">

                <div class="absolute inset-0 bg-feu-green"></div>

                <div class="absolute -top-16 -right-16 w-72 h-72 bg-feu-yellow/10 rounded-full blur-3xl"></div>
                <div class="absolute bottom-0 left-0 w-60 h-60 bg-white/5 rounded-full blur-3xl"></div>

                <div class="relative z-10 p-8 md:p-10 text-white h-full flex flex-col">

                    <div class="flex items-center gap-4 mb-10">

                        <div class="w-16 h-16 rounded-2xl bg-white/10 border border-white/10 flex items-center justify-center backdrop-blur">

                            <svg class="w-8 h-8 text-feu-yellow"
                                 fill="none"
                                 stroke="currentColor"
                                 viewBox="0 0 24 24">

                                <path stroke-linecap="round"
                                      stroke-linejoin="round"
                                      stroke-width="2"
                                      d="M9.75 17L15 12l-5.25-5M4 12h11"/>
                            </svg>
                        </div>

                        <h3 class="text-3xl font-extrabold mt-1">
                            Office Information
                        </h3>

                    </div>

                    <div class="space-y-5">

                        <div class="group bg-white/5 hover:bg-white/10 border border-white/10 rounded-3xl p-6 transition-all duration-300 backdrop-blur-sm">
                            <div class="flex items-start gap-5">
                                <div class="w-14 h-14 rounded-2xl bg-feu-yellow text-slate-900 flex items-center justify-center font-black text-lg shadow-lg">
                                    01
                                </div>
                                <div class="flex-1">
                                    <h4 class="font-bold text-lg mb-2">Office Location</h4>
                                    <p class="text-slate-300 text-sm leading-relaxed">
                                        Information Technology Services Office <br>
                                        Room 1212 / 1608
                                    </p>
                                </div>
                            </div>
                        </div>

                        <div class="group bg-white/5 hover:bg-white/10 border border-white/10 rounded-3xl p-6 transition-all duration-300 backdrop-blur-sm">
                            <div class="flex items-start gap-5">
                                <div class="w-14 h-14 rounded-2xl bg-feu-yellow text-slate-900 flex items-center justify-center font-black text-lg shadow-lg">
                                    02
                                </div>
                                <div class="flex-1">
                                    <h4 class="font-bold text-lg mb-2">Office Hours</h4>
                                    <p class="text-slate-300 text-sm leading-relaxed">
                                        Monday to Saturday <br>
                                        7:00 a.m. to 9:00 p.m.
                                    </p>
                                </div>
                            </div>
                        </div>

                        <div class="group bg-white/5 hover:bg-white/10 border border-white/10 rounded-3xl p-6 transition-all duration-300 backdrop-blur-sm">
                            <div class="flex items-start gap-5">
                                <div class="w-14 h-14 rounded-2xl bg-feu-yellow text-slate-900 flex items-center justify-center font-black text-lg shadow-lg">
                                    03
                                </div>
                                <div class="flex-1">
                                    <h4 class="font-bold text-lg mb-2">Contact Information</h4>
                                    <p class="text-slate-300 text-sm mb-2">
                                        (02) 8281-8888 loc. 132
                                    </p>

                                    <a href="mailto:itso@feutech.edu.ph"
                                       class="inline-flex items-center gap-2 text-feu-yellow font-semibold hover:text-yellow-300 transition">

                                        itso@feutech.edu.ph

                                        <svg class="w-4 h-4"
                                             fill="none"
                                             stroke="currentColor"
                                             viewBox="0 0 24 24">

                                            <path stroke-linecap="round"
                                                  stroke-linejoin="round"
                                                  stroke-width="2"
                                                  d="M5 12h14">
                                            </path>

                                            <path stroke-linecap="round"
                                                  stroke-linejoin="round"
                                                  stroke-width="2"
                                                  d="M13 6l6 6-6 6">
                                            </path>
                                        </svg>
                                    </a>
                                </div>
                            </div>
                        </div>

                        <!-- Bottom Notice -->
                        <div class="mt-8 bg-white/5 border border-white/10 rounded-3xl p-6 backdrop-blur-sm">

                            <div class="flex items-start gap-4">

                                <div class="w-10 h-10 rounded-xl bg-feu-yellow text-slate-900 flex items-center justify-center flex-shrink-0">

                                    <svg class="w-5 h-5"
                                        fill="currentColor"
                                        viewBox="0 0 20 20">

                                        <path fill-rule="evenodd"
                                            d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z"
                                            clip-rule="evenodd">
                                        </path>
                                    </svg>
                                </div>

                                <p class="text-sm text-slate-300 leading-relaxed">
                                   ITSO ensures reliable technology services and secure digital operations by managing infrastructure, systems development, software services, technical support, and campus-wide connectivity for the Institute.
                                </p>

                            </div>
                        </div>

                    </div>

                </div>
            </div>

        </div>

        <!-- SERVICES -->
        <div class="xl:col-span-5 mt-20 mb-6 bg-white rounded-[2rem] border border-slate-200 shadow-xl overflow-hidden px-6 md:px-10 lg:px-14 py-14 lg:py-16">

            <div class="mb-14 pt-2 max-w-5xl mx-auto">

                <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-feu-green/10 border border-feu-green/10 mb-6">
                    <div class="w-2 h-2 rounded-full bg-feu-green"></div>
                    <span class="text-feu-green text-sm font-bold uppercase tracking-wide">
                        Services
                    </span>
                </div>

                <h3 class="text-3xl font-extrabold text-slate-800">
                    Technology and Digital Services
                </h3>

                <p class="mt-4 text-slate-600 leading-relaxed max-w-2xl">
                    ITSO provides technology infrastructure management, systems development, technical support, software services, and network administration to support the Institute’s academic and administrative operations.
                </p>

            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-7 max-w-6xl mx-auto">

                {% set services = [
                    {
                        title: 'Computer Services Unit',
                        icon: 'computer',
                        desc: '<ol class="list-decimal pl-5 space-y-2">
                                <li>Provides technical support and assistance to users of the Institute’s IT and communications facilities.</li>
                                <li>Handles operation, configuration, and administration of ICT infrastructure.</li>
                                <li>Maintains computing equipment, systems, and network resources.</li>
                               </ol>'
                    },
                    {
                        title: 'Management Information Systems Unit',
                        icon: 'systems',
                        desc: '<ol class="list-decimal pl-5 space-y-2">
                                <li>Creates and develops systems and applications for academic and administrative offices.</li>
                                <li>Supports business process automation and digital transformation.</li>
                                <li>Develops solutions based on operational requirements of the Institute.</li>
                               </ol>'
                    },
                    {
                        title: 'Computing Resources',
                        icon: 'server',
                        desc: '<ol class="list-decimal pl-5 space-y-2">
                                <li>Operates, maintains, and manages computer resources of FEU Tech.</li>
                                <li>Supports laboratories, peripherals, storage, and file management.</li>
                                <li>Ensures availability and functionality of computing facilities.</li>
                               </ol>'
                    },
                    {
                        title: 'Educational Software and Technologies',
                        icon: 'software',
                        desc: '<ol class="list-decimal pl-5 space-y-2">
                                <li>Facilitates software licenses and educational applications used by the academic community.</li>
                                <li>Provides access to educational technologies and digital tools.</li>
                                <li>Supports software services for students, faculty, and staff.</li>
                               </ol>'
                    },
                    {
                        title: 'Technical Helpdesk',
                        icon: 'helpdesk',
                        desc: '<ol class="list-decimal pl-5 space-y-2">
                                <li>Provides technical assistance related to academic technology services.</li>
                                <li>Handles technical concerns and support requests.</li>
                                <li>Ensures timely response and troubleshooting assistance.</li>
                               </ol>'
                    },
                    {
                        title: 'Network and Security',
                        icon: 'network',
                        desc: '<ol class="list-decimal pl-5 space-y-2">
                                <li>Manages and monitors LAN, WLAN, and Internet connectivity.</li>
                                <li>Ensures reliable and secure network infrastructure across campus.</li>
                                <li>Maintains network performance and security operations.</li>
                               </ol>'
                    },
                    {
                        title: 'Project Management',
                        icon: 'project',
                        desc: '<ol class="list-decimal pl-5 space-y-2">
                                <li>Develops and deploys customized web and mobile applications.</li>
                                <li>Supports FEU Tech’s business and operational requirements.</li>
                                <li>Handles project coordination and systems implementation.</li>
                               </ol>'
                    }
                ] %}

            {% for service in services %}
            <div class="group bg-white border border-slate-200 rounded-2xl p-6 hover:bg-[#008348] hover:border-[#008348] transition-all duration-300">

                <div class="flex items-start gap-5">

                    <div class="w-12 h-12 rounded-xl bg-feu-green/10 text-feu-green group-hover:text-[#febe10] flex items-center justify-center">

                        {% if service.icon == 'computer' %}
                            <!-- computer -->
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M9.75 17L3 17V5h18v12h-6.75M9 21h6"/>
                            </svg>

                        {% elseif service.icon == 'systems' %}
                            <!-- systems -->
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M4 6h16M4 12h16M4 18h16"/>
                            </svg>

                        {% elseif service.icon == 'server' %}
                            <!-- server -->
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M5 4h14v6H5V4zm0 10h14v6H5v-6z"/>
                            </svg>

                        {% elseif service.icon == 'software' %}
                            <!-- software -->
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M9.75 3v18M3 9.75h18"/>
                            </svg>

                        {% elseif service.icon == 'helpdesk' %}
                            <!-- helpdesk -->
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M18 10c0-3.314-2.686-6-6-6s-6 2.686-6 6v4a2 2 0 002 2h1v-6H8"/>
                            </svg>

                        {% elseif service.icon == 'network' %}
                            <!-- network -->
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M8 16l4-4 4 4M12 12V3"/>
                            </svg>

                        {% elseif service.icon == 'project' %}
                            <!-- project -->
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M9 17v-6h13v6M9 17H5V7h4m0 10v4m0-14V3m13 8V7h-4"/>
                            </svg>
                        {% endif %}

                    </div>

                    <div>
                        <h4 class="font-bold text-feu-green group-hover:text-[#febe10] transition-colors">
                            {{ service.title }}
                        </h4>

                        <div class="text-sm text-slate-500 group-hover:text-white transition-colors">
                            {{ service.desc|raw }}
                        </div>
                    </div>

                </div>

            </div>
            {% endfor %}

            </div>

        </div>

    </div>
</section>

{% endblock %}