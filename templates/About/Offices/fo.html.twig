{% extends 'base.html.twig' %}

{% block title %}Facilities Office | FEU Tech{% endblock %}

{% block body %}

<section class="relative w-full h-[28vh] min-h-[350px] flex items-end justify-center overflow-hidden">

    <div class="absolute inset-0 z-0">
        <img 
            src="/images/offices/offices.png" 
            alt="Facilities Office"
            class="w-full h-full object-cover"
        >

        <div class="absolute inset-0 z-10 bg-black/60"></div>

        <div class="absolute bottom-0 left-0 right-0 h-1 bg-gradient-to-r from-[#008348] via-[#febe10] to-[#008348]"></div>
    </div>

    <div class="absolute inset-0 z-[1] opacity-[0.05] pointer-events-none"
         style="background-image:url('data:image/svg+xml,%3Csvg width=%2760%27 height=%2760%27 viewBox=%270 0 60 60%27 xmlns=%27http://www.w3.org/2000/svg%27%3E%3Cg fill=%27none%27 fill-rule=%27evenodd%27%3E%3Cg fill=%27%23ffffff%27 fill-opacity=%271%27%3E%3Ccircle cx=%2730%27 cy=%2730%27 r=%272%27/%3E%3C/g%3E%3C/g%3E%3C/svg%3E'); background-size:30px 30px;">
    </div>

    <div class="relative z-10 text-center px-6 max-w-5xl mx-auto pb-16 md:pb-24">

        <span class="text-feu-yellow font-bold tracking-widest uppercase text-sm mb-4 block animate-bounce mt-8 md:mt-0">
            Offices
        </span>

        <h1 class="text-4xl md:text-6xl lg:text-7xl font-extrabold text-white uppercase leading-tight tracking-wide drop-shadow-xl">
            Facilities Office
        </h1>

        <p class="mt-6 text-slate-200 text-base md:text-lg max-w-3xl mx-auto leading-relaxed">
            Providing a safe, organized, and well-maintained academic environment through efficient facility operations, security, sanitation, and campus support services.
        </p>

    </div>
</section>

<!-- OVERVIEW SECTION -->
<section class="py-28 lg:py-32 bg-gradient-to-b from-slate-50 to-white relative overflow-hidden">

    <div class="absolute top-0 left-0 w-72 h-72 bg-feu-green opacity-5 rounded-full blur-3xl -translate-x-1/2 -translate-y-1/2"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">

        <div class="grid grid-cols-1 xl:grid-cols-5 gap-8">

            <!-- LEFT CONTENT -->
            <div class="xl:col-span-3 bg-white rounded-[2rem] border border-slate-200 shadow-xl overflow-hidden">

                <div class="h-1 bg-gradient-to-r from-feu-green via-feu-yellow to-feu-green"></div>

                <div class="p-8 md:p-12">

                    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-emerald-50 border border-emerald-100 mb-8">
                        <div class="w-2 h-2 rounded-full bg-feu-green"></div>

                        <span class="text-feu-green text-sm font-bold uppercase tracking-wide">
                            Overview
                        </span>
                    </div>

                    <h3 class="text-3xl font-extrabold text-slate-800 leading-tight mb-6">
                        Ensuring a Safe and Functional Campus Environment
                    </h3>

                    <div class="space-y-6 text-slate-600 leading-relaxed text-[15px]">

                        <p>
                            The Facilities Office (FO) provides and maintains an ideal academic and physical environment for the Institute by ensuring that campus facilities are safe, clean, organized, and fully operational.
                        </p>

                        <p>
                            Its primary responsibility is to support students, faculty, associates, and visitors by maintaining campus safety, facility readiness, equipment reliability, sanitation standards, and operational efficiency across all school areas.
                        </p>

                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 mt-10">

                        <div class="bg-slate-50 border border-slate-100 rounded-2xl p-5">
                            <h4 class="text-3xl font-black text-feu-green">11+</h4>
                            <p class="text-sm text-slate-500 mt-2">Essential campus operational services</p>
                        </div>

                        <div class="bg-slate-50 border border-slate-100 rounded-2xl p-5">
                            <h4 class="text-3xl font-black text-slate-800">Daily</h4>
                            <p class="text-sm text-slate-500 mt-2">Cleaning, monitoring, and maintenance operations</p>
                        </div>

                        <div class="bg-slate-50 border border-slate-100 rounded-2xl p-5">
                            <h4 class="text-3xl font-black text-feu-green">Campus</h4>
                            <p class="text-sm text-slate-500 mt-2">Full coverage of facilities and shared spaces</p>
                        </div>

                    </div>

                </div>
            </div>

            <!-- OFFICE INFO -->
            <div class="xl:col-span-2 relative overflow-hidden rounded-[2rem] shadow-2xl">

                <div class="absolute inset-0 bg-feu-green"></div>

                <div class="absolute -top-16 -right-16 w-72 h-72 bg-feu-yellow/10 rounded-full blur-3xl"></div>
                <div class="absolute bottom-0 left-0 w-60 h-60 bg-white/5 rounded-full blur-3xl"></div>

                <div class="relative z-10 p-8 md:p-10 text-white h-full flex flex-col">

                    <div class="flex items-center gap-4 mb-10">

                        <div class="w-16 h-16 rounded-2xl bg-white/10 border border-white/10 flex items-center justify-center backdrop-blur">

                            <svg class="w-8 h-8 text-feu-yellow"
                                 fill="none"
                                 stroke="currentColor"
                                 viewBox="0 0 24 24">

                                <path stroke-linecap="round"
                                      stroke-linejoin="round"
                                      stroke-width="2"
                                      d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/>
                            </svg>
                        </div>

                        <h3 class="text-3xl font-extrabold mt-1">
                            Office Information
                        </h3>

                    </div>

                    <div class="space-y-5">

                        <div class="group bg-white/5 hover:bg-white/10 border border-white/10 rounded-3xl p-6 transition-all duration-300 backdrop-blur-sm">
                            <div class="flex items-start gap-5">
                                <div class="w-14 h-14 rounded-2xl bg-feu-yellow text-slate-900 flex items-center justify-center font-black text-lg shadow-lg">
                                    01
                                </div>
                                <div class="flex-1">
                                    <h4 class="font-bold text-lg mb-2">Office Location</h4>
                                    <p class="text-slate-300 text-sm leading-relaxed">
                                        Facilities Office <br>
                                        Room 511
                                    </p>
                                </div>
                            </div>
                        </div>

                        <div class="group bg-white/5 hover:bg-white/10 border border-white/10 rounded-3xl p-6 transition-all duration-300 backdrop-blur-sm">
                            <div class="flex items-start gap-5">
                                <div class="w-14 h-14 rounded-2xl bg-feu-yellow text-slate-900 flex items-center justify-center font-black text-lg shadow-lg">
                                    02
                                </div>
                                <div class="flex-1">
                                    <h4 class="font-bold text-lg mb-2">Office Hours</h4>
                                    <p class="text-slate-300 text-sm leading-relaxed">
                                        Monday to Friday <br>
                                        8:00 a.m. – 5:00 p.m.
                                    </p>
                                </div>
                            </div>
                        </div>

                        <div class="group bg-white/5 hover:bg-white/10 border border-white/10 rounded-3xl p-6 transition-all duration-300 backdrop-blur-sm">
                            <div class="flex items-start gap-5">
                                <div class="w-14 h-14 rounded-2xl bg-feu-yellow text-slate-900 flex items-center justify-center font-black text-lg shadow-lg">
                                    03
                                </div>
                                <div class="flex-1">
                                    <h4 class="font-bold text-lg mb-2">Contact Information</h4>
                                    <p class="text-slate-300 text-sm mb-4">
                                        (02) 8281 8888 loc. 129/139
                                    </p>
                                </div>
                            </div>
                        </div>

                        <!-- Bottom Notice -->
                        <div class="mt-8 bg-white/5 border border-white/10 rounded-3xl p-6 backdrop-blur-sm">

                            <div class="flex items-start gap-4">

                                <div class="w-10 h-10 rounded-xl bg-feu-yellow text-slate-900 flex items-center justify-center flex-shrink-0">

                                    <svg class="w-5 h-5"
                                        fill="currentColor"
                                        viewBox="0 0 20 20">

                                        <path fill-rule="evenodd"
                                            d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z"
                                            clip-rule="evenodd">
                                        </path>
                                    </svg>
                                </div>

                                <p class="text-sm text-slate-300 leading-relaxed">
                                    The Facilities Office acts as the behind-the-scenes backbone of the campus, handling everything from technical repairs and event setups to the processing of lost and found items to ensure your daily student life runs smoothly.
                                </p>

                            </div>
                        </div>

                    </div>

                </div>
            </div>

        </div>

        <!-- OUR SERVICES SECTION -->
        <div class="xl:col-span-5 mt-20 mb-6 bg-white rounded-[2rem] border border-slate-200 shadow-xl overflow-hidden px-6 md:px-10 lg:px-14 py-14 lg:py-16">

            <div class="mb-14 pt-2 max-w-5xl mx-auto">

                <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-feu-green/10 border border-feu-green/10 mb-6">
                    <div class="w-2 h-2 rounded-full bg-feu-green"></div>
                    <span class="text-feu-green text-sm font-bold uppercase tracking-wide">
                        Our Services
                    </span>
                </div>

                <h3 class="text-3xl font-extrabold text-slate-800">
                    Campus Support Services
                </h3>

                <p class="mt-4 text-slate-600 leading-relaxed max-w-2xl">
                    The Facilities Office manages operational, safety, maintenance, and support services to ensure a clean, secure, and efficient campus environment.
                </p>

            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-7 max-w-6xl mx-auto">

                {% set services = [
                    {
                        title: 'Cleaning, Disinfecting & Sanitizing',
                        icon: 'cleaning',
                        desc: 'The Facilities Office provides and maintains the cleanliness and orderliness inside the campus. Disinfection and sanitation are done regularly to prevent the spread of infection and virus, especially in high touchpoint and high-traffic areas. Daily cleaning routines (including vacuuming, sweeping, scrubbing, dust and dirt removal, pest control, and proper waste disposal) are strictly observed to ensure a clean and safe environment for students and associates.'
                    },
                    {
                        title: 'Safety & Health',
                        icon: 'health',
                        desc: 'FO maintains a safe and healthy place for Tamaraws. It conducts a safety and health management program in coordination with the Health Service Unit Department to focus efforts in improving work and school environment, prevent injuries and illnesses, identify hazards, and discuss how to manage the safety and health of everyone in the school.'
                    },
                    {
                        title: 'Equipment Maintenance',
                        icon: 'maintenance',
                        desc: 'It ensures that all machineries and equipment are in good running condition by scheduling regular preventive maintenance.'
                    },
                    {
                        title: 'Security',
                        icon: 'security',
                        desc: 'It secures the assets of the Institute, maintains peace and order inside the premises, and always ensures the safety of its faculty, associates, and students.'
                    },
                    {
                        title: 'On-Campus Activity Program Management',
                        icon: 'activity',
                        desc: 'FO provides and maintains a good facility and readiness of rooms including the conference room, multi-purpose room, student plaza, cafeteria, chapel, piazza, and gym. It is in charge of preparing these areas for any scheduled event of the faculty and students. The office also provides sound system, furniture, and manpower assistance for all kinds of activities inside the campus.'
                    },
                    {
                        title: 'Inventory Management',
                        icon: 'inventory',
                        desc: 'FO ensures the proper encoding, tagging, tracking, and control of the inventory materials as it is bought, stored, and used. It makes sure to deliver, receive, and store the right quantities of items. The office also conducts quarterly review and physical inventory of all assets, furniture and fixtures, laboratory tools, equipment, and other materials.'
                    },
                    {
                        title: 'Vehicle Management',
                        icon: 'vehicle',
                        desc: 'It also ensures readiness of the company vehicle for any official business trip requested by the faculty, students, and other offices that may need to do a specific assigned task.'
                    },
                    {
                        title: 'CCTV Reviews',
                        icon: 'cctv',
                        desc: 'The Facilities Office ensures the functionality and operation of CCTV systems in the whole area. It assists students and associates in getting CCTV reviews and reports in coordination with the Human Resources Office.'
                    },
                    {
                        title: 'Project Management',
                        icon: 'project',
                        desc: 'FO ensures the existing project development in the area is being accomplished and done on a timely basis. Construction works are properly executed, monitored, and controlled based on the scope of works and methodology. This includes planning, identifying tasks, quantifying the resources needed, as well as determining budgets and timelines for completion. The office also coordinates with the different vendors and contractors for the completion of project works.'
                    },
                    {
                        title: 'Community & Government Coordination',
                        icon: 'community',
                        desc: 'It also maintains and continues good communication with its local government for the list of tasks and protocols which the campus is required to do so. It also ensures proper communication and information from the neighborhood for other necessary events that may be related to the school and community operation.'
                    }
                ] %}

                {% for service in services %}
                    <div class="group bg-white border border-slate-200 rounded-2xl p-6 lg:p-7 h-full w-full hover:bg-[#008348] hover:border-[#008348] hover:shadow-lg transition-all duration-300">

                        <div class="flex items-start gap-5">

                            <div class="w-12 h-12 mt-1 rounded-xl bg-feu-green/10 text-feu-green group-hover:bg-white/20 group-hover:text-[#febe10] flex items-center justify-center flex-shrink-0 transition-all duration-300">

                                {% if service.icon == 'cleaning' %}
                                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                              d="M9 3h6m-5 0v5m4-5v5m-7 4h10l-1 8H8l-1-8z"/>
                                    </svg>
                                {% elseif service.icon == 'maintenance' %}
                                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5h2m-7 7h12M6 19h12"/>
                                    </svg>
                                {% elseif service.icon == 'security' %}
                                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                              d="M12 3l7 4v5c0 5-3.5 8-7 9-3.5-1-7-4-7-9V7l7-4z"/>
                                    </svg>
                                {% elseif service.icon == 'health' %}
                                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                              d="M12 21s-7-4.35-7-10a4 4 0 017-2.65A4 4 0 0119 11c0 5.65-7 10-7 10z"/>
                                    </svg>
                                {% elseif service.icon == 'activity' %}
                                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                              d="M14.752 11.168l-6.518-3.73A1 1 0 007 8.304v7.392a1 1 0 001.234.97l6.518-1.63A1 1 0 0015.5 15V12a1 1 0 00-.748-.832z"/>
                                    </svg>
                                {% elseif service.icon == 'vehicle' %}
                                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                              d="M3 13l2-5h14l2 5M5 13h14v5H5v-5zm2 5a1 1 0 100 2 1 1 0 000-2zm10 0a1 1 0 100 2 1 1 0 000-2z"/>
                                    </svg>
                                {% elseif service.icon == 'cctv' %}
                                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                              d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14"/>
                                        <rect x="3" y="6" width="12" height="12" rx="2"/>
                                    </svg>
                                {% elseif service.icon == 'inventory' %}
                                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                              d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10"/>
                                    </svg>
                                {% elseif service.icon == 'project' %}
                                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                              d="M3 21h18M5 21V9l7-5 7 5v12"/>
                                    </svg>
                                {% elseif service.icon == 'community' %}
                                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                              d="M17 20h5V4H2v16h5m10 0v-6H7v6m10 0H7"/>
                                    </svg>
                                {% endif %}

                            </div>

                            <div>
                                <h4 class="font-bold text-feu-green text-[15px] mb-3 leading-snug group-hover:text-[#febe10] transition-colors duration-300">
                                    {{ service.title }}
                                </h4>

                                <p class="text-sm text-slate-500 text-justify leading-[1.65] group-hover:text-white transition-colors duration-300">
                                    {{ service.desc }}
                                </p>
                            </div>

                        </div>
                    </div>
                {% endfor %}

            </div>

        </div>

    </div>
</section>

{% endblock %}