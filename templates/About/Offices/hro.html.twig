{% extends 'base.html.twig' %}

{% block title %}Human Resources Office | FEU Tech{% endblock %}

{% block body %}

<section class="relative w-full h-[58vh] min-h-[450px] flex items-end justify-center overflow-hidden">

    <div class="absolute inset-0 z-0">
        <img 
            src="/images/EXECUTIVE_TECH.jpg" 
            alt="Human Resources Office"
            class="w-full h-full object-cover"
        >

        <div class="absolute inset-0 bg-gradient-to-b from-slate-950/80 via-slate-900/75 to-[#00351e]/95"></div>

        <div class="absolute bottom-0 left-0 right-0 h-1 bg-gradient-to-r from-[#008348] via-[#febe10] to-[#008348]"></div>
    </div>

    <div class="absolute inset-0 z-[1] opacity-[0.05] pointer-events-none"
         style="background-image:url('data:image/svg+xml,%3Csvg width=%2760%27 height=%2760%27 viewBox=%270 0 60 60%27 xmlns=%27http://www.w3.org/2000/svg%27%3E%3Cg fill=%27none%27 fill-rule=%27evenodd%27%3E%3Cg fill=%27%23ffffff%27 fill-opacity=%271%27%3E%3Ccircle cx=%2730%27 cy=%2730%27 r=%272%27/%3E%3C/g%3E%3C/g%3E%3C/svg%3E'); background-size:30px 30px;">
    </div>

    <div class="relative z-10 text-center px-6 max-w-5xl mx-auto pb-16 md:pb-24">

        <span class="text-feu-yellow font-bold tracking-widest uppercase text-sm mb-4 block animate-bounce mt-8 md:mt-0">
            Offices
        </span>

        <h1 class="text-4xl md:text-6xl lg:text-7xl font-extrabold text-white uppercase leading-tight tracking-wide drop-shadow-xl">
            Human Resources Office
        </h1>

        <p class="mt-6 text-slate-200 text-base md:text-lg max-w-3xl mx-auto leading-relaxed">
            Supports the College through strategic human resource management, employee engagement, organizational development, and performance enhancement programs.
        </p>

    </div>
</section>

<!-- OVERVIEW SECTION -->
<section class="py-28 lg:py-32 bg-gradient-to-b from-slate-50 to-white relative overflow-hidden">

    <div class="absolute top-0 left-0 w-72 h-72 bg-feu-green opacity-5 rounded-full blur-3xl -translate-x-1/2 -translate-y-1/2"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">

        <div class="grid grid-cols-1 xl:grid-cols-5 gap-8">

            <!-- LEFT CONTENT -->
            <div class="xl:col-span-3 bg-white rounded-[2rem] border border-slate-200 shadow-xl overflow-hidden">

                <div class="h-1 bg-gradient-to-r from-feu-green via-feu-yellow to-feu-green"></div>

                <div class="p-8 md:p-12">

                    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-emerald-50 border border-emerald-100 mb-8">
                        <div class="w-2 h-2 rounded-full bg-feu-green"></div>
                        <span class="text-feu-green text-sm font-bold uppercase tracking-wide">
                            General Information
                        </span>
                    </div>

                    <h3 class="text-3xl font-extrabold text-slate-800 leading-tight mb-6">
                        Strengthening People and Organizational Performance
                    </h3>

                    <div class="space-y-6 text-slate-600 leading-relaxed text-[15px]">

                        <p>
                            The Human Resources Office provides internal consultancy, expert HR guidance, and strategic support to management and associates.
                        </p>

                        <p>
                            It ensures the implementation of HR interventions that enhance morale, productivity, and organizational effectiveness.
                        </p>

                        <p>
                            It also aligns HR programs with institutional goals, labor laws, and best practices in human capital management.
                        </p>

                    </div>

                    <!-- UPDATED HR STATS -->
                    <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 mt-10">

                        <div class="bg-slate-50 border border-slate-100 rounded-2xl p-5">
                            <h4 class="text-2xl font-black text-feu-green">Recruitment</h4>
                            <p class="text-sm text-slate-500 mt-2">Hiring, onboarding & placement processes</p>
                        </div>

                        <div class="bg-slate-50 border border-slate-100 rounded-2xl p-5">
                            <h4 class="text-2xl font-black text-slate-800">Employee Support</h4>
                            <p class="text-sm text-slate-500 mt-2">Relations, concerns & workplace assistance</p>
                        </div>

                        <div class="bg-slate-50 border border-slate-100 rounded-2xl p-5">
                            <h4 class="text-2xl font-black text-feu-green">Development</h4>
                            <p class="text-sm text-slate-500 mt-2">Training, performance & career growth</p>
                        </div>

                    </div>

                </div>
            </div>

            <!-- OFFICE INFO -->
            <div class="xl:col-span-2 relative overflow-hidden rounded-[2rem] shadow-2xl">

                <div class="absolute inset-0 bg-feu-green"></div>

                <div class="relative z-10 p-8 md:p-10 text-white h-full flex flex-col">

                    <div class="flex items-center gap-4 mb-10">

                        <div class="w-16 h-16 rounded-2xl bg-white/10 border border-white/10 flex items-center justify-center backdrop-blur">
                            <svg class="w-8 h-8 text-feu-yellow" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/>
                            </svg>
                        </div>

                        <h3 class="text-3xl font-extrabold mt-1">
                            Office Information
                        </h3>

                    </div>

                    <div class="space-y-5">

                        <div class="group bg-white/5 hover:bg-white/10 border border-white/10 rounded-3xl p-6 backdrop-blur-sm">
                            <div class="flex items-start gap-5">

                                <div class="w-14 h-14 rounded-2xl bg-feu-yellow text-slate-900 flex items-center justify-center font-black text-lg shadow-lg">
                                    01
                                </div>

                                <div class="flex-1">
                                    <h4 class="font-bold text-lg mb-2">Office Location</h4>
                                    <p class="text-slate-300 text-sm leading-relaxed">
                                        Human Resources Office <br>
                                        Room 1602
                                    </p>
                                </div>

                            </div>
                        </div>

                        <div class="group bg-white/5 hover:bg-white/10 border border-white/10 rounded-3xl p-6 backdrop-blur-sm">

                            <div class="flex items-start gap-5">

                                <div class="w-14 h-14 rounded-2xl bg-feu-yellow text-slate-900 flex items-center justify-center font-black text-lg shadow-lg">
                                    02
                                </div>

                                <div class="flex-1">
                                    <h4 class="font-bold text-lg mb-2">Contact Information</h4>

                                    <p class="text-slate-300 text-sm mb-3">
                                        (02) 8281 8888 Local 147
                                    </p>

                                    <a href="mailto:hr@feutech.edu.ph"
                                       class="inline-flex items-center gap-2 text-feu-yellow font-semibold hover:text-yellow-300 transition">

                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                  d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8m-18 8h18a2 2 0 002-2V8a2 2 0 00-2-2H3a2 2 0 00-2 2v6a2 2 0 002 2z"/>
                                        </svg>

                                        hr@feutech.edu.ph
                                    </a>

                                </div>

                            </div>
                        </div>

                        <!-- ADDED BOTTOM NOTICE (HR VERSION) -->
                        <div class="mt-8 bg-white/5 border border-white/10 rounded-3xl p-6 backdrop-blur-sm">

                            <div class="flex items-start gap-4">

                                <div class="w-10 h-10 rounded-xl bg-feu-yellow text-slate-900 flex items-center justify-center flex-shrink-0">

                                    <svg class="w-5 h-5"
                                        fill="currentColor"
                                        viewBox="0 0 20 20">

                                        <path fill-rule="evenodd"
                                            d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z"
                                            clip-rule="evenodd">
                                        </path>
                                    </svg>
                                </div>

                                <p class="text-sm text-slate-300 leading-relaxed">
                                    The Human Resources Office serves as the backbone of employee management, ensuring smooth recruitment, development, and engagement processes while supporting both staff welfare and organizational growth across the institution.
                                </p>

                            </div>
                        </div>

                    </div>

                </div>
            </div>

        </div>

        
        <!-- SERVICES -->
        <div class="xl:col-span-5 mt-20 mb-6 bg-white rounded-[2rem] border border-slate-200 shadow-xl overflow-hidden px-6 md:px-10 lg:px-14 py-14 lg:py-16">

            <div class="mb-14 pt-2 max-w-5xl mx-auto">

                <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-feu-green/10 border border-feu-green/10 mb-6">
                    <div class="w-2 h-2 rounded-full bg-feu-green"></div>
                    <span class="text-feu-green text-sm font-bold uppercase tracking-wide">
                        Services
                    </span>
                </div>

                <h3 class="text-3xl font-extrabold text-slate-800">
                    Human Resources Services
                </h3>

                <p class="mt-4 text-slate-600 leading-relaxed max-w-2xl"> 
                    The Human Resources Services handles managing people-related concerns in an organization right from recruiting, hiring, training, administering compensation, analyzing performance and managing the orientation process .
                </p>

            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-7 max-w-6xl mx-auto">

                {% set services = [
                    {
                        title: 'Employee Relations',
                        icon: 'users',
                        desc: '<ol class="list-decimal pl-5 space-y-2">
                            <li>Performance coaching and workplace support.</li>
                            <li>Policy guidance and labor law compliance.</li>
                            <li>Conflict resolution and employee assistance.</li>
                            <li>Recognition and engagement programs.</li>
                            <li>Workplace wellness initiatives.</li>
                        </ol>'
                    },
                    {
                        title: 'Compensation & Benefits',
                        icon: 'cash',
                        desc: '<ol class="list-decimal pl-5 space-y-2">
                            <li>Salary structure monitoring and payroll management.</li>
                            <li>Benefits planning and administration.</li>
                            <li>Insurance and retirement scheme recommendations.</li>
                            <li>Performance evaluation system support.</li>
                        </ol>'
                    },
                    {
                        title: 'Learning & Development',
                        icon: 'graduation',
                        desc: '<ol class="list-decimal pl-5 space-y-2">
                            <li>Training and capability development programs.</li>
                            <li>Internal and external learning opportunities.</li>
                            <li>Professional growth initiatives.</li>
                            <li>Teamwork and collaboration development.</li>
                        </ol>'
                    },
                    {
                        title: 'Employment Services',
                        icon: 'briefcase',
                        desc: '<ol class="list-decimal pl-5 space-y-2">
                            <li>Recruitment and candidate screening.</li>
                            <li>Onboarding and orientation programs.</li>
                            <li>Job matching and placement.</li>
                            <li>Exit interviews and turnover analysis.</li>
                        </ol>'
                    },
                    {
                        title: 'HR Policy Documents',
                        icon: 'file',
                        desc: '<div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

                            <a href="/pdf/hro_sm_e-card_policy_guidelines.pdf" target="_blank"
                               class="group flex items-center gap-4 p-4 rounded-xl border border-slate-200 bg-slate-50 hover:bg-white hover:border-feu-green transition-all duration-300 shadow-sm hover:shadow-md">

                                <div class="w-12 h-12 rounded-lg bg-red-50 text-red-600 flex items-center justify-center flex-shrink-0 group-hover:bg-red-100">
                                    <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                                        <path d="M6 2a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6H6zm7 1.5L18.5 10H13V3.5z"/>
                                    </svg>
                                </div>

                                <div class="flex-1 min-w-0">
                                    <p class="font-semibold text-slate-800 group-hover:text-feu-green text-sm">
                                        SM E-Card Policy Guidelines
                                    </p>
                                    <p class="text-xs text-slate-500 mt-1"> Document • Click to open</p>
                                </div>

                            </a>

                            <a href="/pdf/hro_smsla_policy_guidelines.pdf" target="_blank"
                               class="group flex items-center gap-4 p-4 rounded-xl border border-slate-200 bg-slate-50 hover:bg-white hover:border-feu-green transition-all duration-300 shadow-sm hover:shadow-md">

                                <div class="w-12 h-12 rounded-lg bg-red-50 text-red-600 flex items-center justify-center flex-shrink-0 group-hover:bg-red-100">
                                    <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                                        <path d="M6 2a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6H6zm7 1.5L18.5 10H13V3.5z"/>
                                    </svg>
                                </div>

                                <div class="flex-1 min-w-0">
                                    <p class="font-semibold text-slate-800 group-hover:text-feu-green text-sm">
                                        SMSLA Policy Guidelines
                                    </p>
                                    <p class="text-xs text-slate-500 mt-1"> Click to open</p>
                                </div>
                            </a>

                        </div>'
                    }
                ] %}

                {% for service in services %}

                    <div class="group bg-white border border-slate-200 rounded-2xl p-6 lg:p-7 hover:bg-[#008348] hover:border-[#008348] transition-all duration-300
                        {% if service.title == 'HR Policy Documents' %} md:col-span-2 {% endif %}">

                        <div class="flex items-start gap-5">

                            <div class="w-12 h-12 mt-1 rounded-xl bg-feu-green/10 text-feu-green group-hover:text-[#febe10] flex items-center justify-center flex-shrink-0">

                                {% if service.icon == 'users' %}
                                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                              d="M17 20h5v-2a4 4 0 00-3-3.87M9 20H4v-2a4 4 0 013-3.87M16 3.13a4 4 0 010 7.75M8 3.13a4 4 0 000 7.75"/>
                                    </svg>

                                {% elseif service.icon == 'cash' %}
                                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                              d="M12 8c-1.5-1.5-4-1-4 1s2 2 4 2 4 .5 4 2-2.5 2.5-4 1M12 3v18"/>
                                    </svg>

                                {% elseif service.icon == 'graduation' %}
                                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                              d="M12 14l9-5-9-5-9 5 9 5z"/>
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                              d="M12 14v7"/>
                                    </svg>

                                {% elseif service.icon == 'briefcase' %}
                                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                              d="M9 6V4a2 2 0 012-2h2a2 2 0 012 2v2"/>
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                              d="M4 7h16v13H4z"/>
                                    </svg>

                                {% elseif service.icon == 'file' %}
                                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                              d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                              d="M14 2v6h6"/>
                                    </svg>
                                {% endif %}

                            </div>

                            <div>
                                <h4 class="font-bold text-feu-green text-[15px] mb-3 group-hover:text-[#febe10]">
                                    {{ service.title }}
                                </h4>

                                <div class="text-sm text-slate-500 group-hover:text-white">
                                    {{ service.desc|raw }}
                                </div>

                            </div>

                        </div>
                    </div>

                {% endfor %}

            </div>

        </div>

    </div>
</section>

{% endblock %}