{% extends 'base.html.twig' %}

{% block title %}Finance Office | FEU Tech{% endblock %}

{% block body %}

<section class="relative w-full h-[58vh] min-h-[450px] flex items-end justify-center overflow-hidden">

    <div class="absolute inset-0 z-0">
        <img 
            src="/images/EXECUTIVE_TECH.jpg" 
            alt="Finance Office"
            class="w-full h-full object-cover"
        >

        <div class="absolute inset-0 bg-gradient-to-b from-slate-950/80 via-slate-900/75 to-[#00351e]/95"></div>

        <div class="absolute bottom-0 left-0 right-0 h-1 bg-gradient-to-r from-[#008348] via-[#febe10] to-[#008348]"></div>
    </div>

    <div class="absolute inset-0 z-[1] opacity-[0.05] pointer-events-none"
         style="background-image:url('data:image/svg+xml,%3Csvg width=%2760%27 height=%2760%27 viewBox=%270 0 60 60%27 xmlns=%27http://www.w3.org/2000/svg%27%3E%3Cg fill=%27none%27 fill-rule=%27evenodd%27%3E%3Cg fill=%27%23ffffff%27 fill-opacity=%271%27%3E%3Ccircle cx=%2730%27 cy=%2730%27 r=%272%27/%3E%3C/g%3E%3C/g%3E%3C/svg%3E'); background-size:30px 30px;">
    </div>

    <div class="relative z-10 text-center px-6 max-w-5xl mx-auto pb-16 md:pb-24">

        <span class="text-feu-yellow font-bold tracking-widest uppercase text-sm mb-4 block animate-bounce mt-8 md:mt-0">
            Offices
        </span>

        <h1 class="text-4xl md:text-6xl lg:text-7xl font-extrabold text-white uppercase leading-tight tracking-wide drop-shadow-xl">
            Finance Office
        </h1>

        <p class="mt-6 text-slate-200 text-base md:text-lg max-w-3xl mx-auto leading-relaxed">
            Responsible for maintaining the Institute’s financial records, preparing and interpreting financial statements, and ensuring proper budget management, accounting, purchasing, and student financial services.
        </p>

    </div>
</section>

<!-- OVERVIEW SECTION -->
<section class="py-28 lg:py-32 bg-gradient-to-b from-slate-50 to-white relative overflow-hidden">

    <div class="absolute top-0 left-0 w-72 h-72 bg-feu-green opacity-5 rounded-full blur-3xl -translate-x-1/2 -translate-y-1/2"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">

        <div class="grid grid-cols-1 xl:grid-cols-5 gap-8">

            <!-- LEFT CONTENT -->
            <div class="xl:col-span-3 bg-white rounded-[2rem] border border-slate-200 shadow-xl overflow-hidden">

                <div class="h-1 bg-gradient-to-r from-feu-green via-feu-yellow to-feu-green"></div>

                <div class="p-8 md:p-12">

                    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-emerald-50 border border-emerald-100 mb-8">
                        <div class="w-2 h-2 rounded-full bg-feu-green"></div>

                        <span class="text-feu-green text-sm font-bold uppercase tracking-wide">
                            Overview
                        </span>
                    </div>

                    <h3 class="text-3xl font-extrabold text-slate-800 leading-tight mb-6">
                        Ensuring Accurate and Transparent Financial Management
                    </h3>

                    <div class="space-y-6 text-slate-600 leading-relaxed text-[15px]">

                        <p>
                            The Finance Office is responsible for maintaining the Institute’s books of accounts and preparing accurate financial statements to ensure proper financial reporting and compliance.
                        </p>

                        <p>
                            It provides overall supervision of the Budget, General Accounting, Students Accounts, Disbursements, and Purchasing Sections to ensure efficient financial operations and proper allocation of institutional resources.
                        </p>

                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 mt-10">

                        <div class="bg-slate-50 border border-slate-100 rounded-2xl p-5">
                            <h4 class="text-3xl font-black text-feu-green">5+</h4>
                            <p class="text-sm text-slate-500 mt-2">Core financial sections managed</p>
                        </div>

                        <div class="bg-slate-50 border border-slate-100 rounded-2xl p-5">
                            <h4 class="text-3xl font-black text-slate-800">Daily</h4>
                            <p class="text-sm text-slate-500 mt-2">Financial processing and transactions</p>
                        </div>

                        <div class="bg-slate-50 border border-slate-100 rounded-2xl p-5">
                            <h4 class="text-3xl font-black text-feu-green">Institute</h4>
                            <p class="text-sm text-slate-500 mt-2">Full financial oversight and compliance</p>
                        </div>

                    </div>

                </div>
            </div>

            <!-- OFFICE INFO -->
            <div class="xl:col-span-2 relative overflow-hidden rounded-[2rem] shadow-2xl">

                <div class="absolute inset-0 bg-feu-green"></div>

                <div class="absolute -top-16 -right-16 w-72 h-72 bg-feu-yellow/10 rounded-full blur-3xl"></div>
                <div class="absolute bottom-0 left-0 w-60 h-60 bg-white/5 rounded-full blur-3xl"></div>

                <div class="relative z-10 p-8 md:p-10 text-white h-full flex flex-col">

                    <div class="flex items-center gap-4 mb-10">

                        <div class="w-16 h-16 rounded-2xl bg-white/10 border border-white/10 flex items-center justify-center backdrop-blur">

                            <svg class="w-8 h-8 text-feu-yellow"
                                 fill="none"
                                 stroke="currentColor"
                                 viewBox="0 0 24 24">

                                <path stroke-linecap="round"
                                      stroke-linejoin="round"
                                      stroke-width="2"
                                      d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/>
                            </svg>
                        </div>

                        <h3 class="text-3xl font-extrabold mt-1">
                            Office Information
                        </h3>

                    </div>

                    <div class="space-y-5">

                        <div class="group bg-white/5 hover:bg-white/10 border border-white/10 rounded-3xl p-6 transition-all duration-300 backdrop-blur-sm">
                            <div class="flex items-start gap-5">
                                <div class="w-14 h-14 rounded-2xl bg-feu-yellow text-slate-900 flex items-center justify-center font-black text-lg shadow-lg">
                                    01
                                </div>
                                <div class="flex-1">
                                    <h4 class="font-bold text-lg mb-2">Office Location</h4>
                                    <p class="text-slate-300 text-sm leading-relaxed">
                                        Finance Office <br>
                                        Room 1509
                                    </p>
                                </div>
                            </div>
                        </div>

                        <div class="group bg-white/5 hover:bg-white/10 border border-white/10 rounded-3xl p-6 transition-all duration-300 backdrop-blur-sm">
                            <div class="flex items-start gap-5">
                                <div class="w-14 h-14 rounded-2xl bg-feu-yellow text-slate-900 flex items-center justify-center font-black text-lg shadow-lg">
                                    02
                                </div>
                                <div class="flex-1">
                                    <h4 class="font-bold text-lg mb-2">Contact Information</h4>
                                    <p class="text-slate-300 text-sm mb-2">
                                        (02) 8281-8888 loc. 115
                                    </p>
                                     <a href="mailto:accounting@feutech.edu.ph"
                                       class="inline-flex items-center gap-2 text-feu-yellow font-semibold hover:text-yellow-300 transition">

                                        accounting@feutech.edu.ph

                                        <svg class="w-4 h-4"
                                             fill="none"
                                             stroke="currentColor"
                                             viewBox="0 0 24 24">

                                            <path stroke-linecap="round"
                                                  stroke-linejoin="round"
                                                  stroke-width="2"
                                                  d="M5 12h14">
                                            </path>

                                            <path stroke-linecap="round"
                                                  stroke-linejoin="round"
                                                  stroke-width="2"
                                                  d="M13 6l6 6-6 6">
                                            </path>
                                        </svg>
                                    </a>
                                </div>
                            </div>
                        </div>


                        <!-- Bottom Notice -->
                        <div class="mt-8 bg-white/5 border border-white/10 rounded-3xl p-6 backdrop-blur-sm">

                            <div class="flex items-start gap-4">

                                <div class="w-10 h-10 rounded-xl bg-feu-yellow text-slate-900 flex items-center justify-center flex-shrink-0">

                                    <svg class="w-5 h-5"
                                        fill="currentColor"
                                        viewBox="0 0 20 20">

                                        <path fill-rule="evenodd"
                                            d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z"
                                            clip-rule="evenodd">
                                        </path>
                                    </svg>
                                </div>

                                <p class="text-sm text-slate-300 leading-relaxed">
                                   The Finance Office ensures the Institute’s resources are properly planned, recorded, and managed by overseeing budgeting, accounting, billing, payments, and purchasing to keep all financial operations accurate, organized, and transparent.
                                </p>

                            </div>
                        </div>

                    </div>

                </div>
            </div>

        </div>

        <!-- SERVICES -->
        <div class="xl:col-span-5 mt-20 mb-6 bg-white rounded-[2rem] border border-slate-200 shadow-xl overflow-hidden px-6 md:px-10 lg:px-14 py-14 lg:py-16">

            <div class="mb-14 pt-2 max-w-5xl mx-auto">

                <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-feu-green/10 border border-feu-green/10 mb-6">
                    <div class="w-2 h-2 rounded-full bg-feu-green"></div>
                    <span class="text-feu-green text-sm font-bold uppercase tracking-wide">
                        Services
                    </span>
                </div>

                <h3 class="text-3xl font-extrabold text-slate-800">
                    Financial Operations Services
                </h3>

                <p class="mt-4 text-slate-600 leading-relaxed max-w-2xl">
                    The Finance Office handles budgeting, accounting, disbursements, purchasing, and student accounts to ensure efficient and accurate financial operations.
                </p>

            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-7 max-w-6xl mx-auto">

                {% set services = [
                    {
                        title: 'Budget Section',
                        icon: 'budget',
                        desc: '<ol class="list-decimal pl-5 space-y-2">
                                <li>Review proposed budget submitted by Directors and prepare a master budget plan for submission to the Board.</li>
                                <li>Maintain records of budgeted and actual revenue and expenses to determine performance of various departments/offices.</li>
                                <li>Determine whether requests are within the authorized budget.</li>
                                <li>Determine budget deviations and discuss corrective measures with departments.</li>
                               </ol>'
                    },
                    {
                        title: 'General Accounting Section',
                        icon: 'accounting',
                        desc: '<ol class="list-decimal pl-5 space-y-2">
                                <li>Prepare trial balances and schedules.</li>
                                <li>Prepare financial statements.</li>
                                <li>Prepare bank reconciliation statements.</li>
                                <li>Record receipts.</li>
                                <li>Prepare monthly remittances to government authorities.</li>
                               </ol>'
                    },
                    {
                        title: 'Students Accounts Section',
                        icon: 'students',
                        desc: '<ol class="list-decimal pl-5 space-y-2">
                                <li>Maintain student financial records.</li>
                                <li>Issue examination permits.</li>
                                <li>Issue statements of accounts for refunds.</li>
                                <li>Process clearances for returning students.</li>
                                <li>Determine refund amounts.</li>
                               </ol>'
                    },
                    {
                        title: 'Disbursements Section',
                        icon: 'money',
                        desc: '<ol class="list-decimal pl-5 space-y-2">
                                <li>Responsible for ensuring that all disbursements of college funds are in order and properly authorized, meaning they are properly documented, funded and approved.</li>
                                <li>Ensures that authorized suppliers receive the correct payment when they are due.</li>
                                <li>Prepare checks.</li>
                                <li>Release checks to authorize payee.</li>
                               </ol>'
                    },
                    {
                        title: 'Purchasing Section',
                        icon: 'purchasing',
                        desc: '<ol class="list-decimal pl-5 space-y-2">
                                <li>Responsible for the timely procurement and receiving of materials, goods, equipment and services.</li>
                                <li>Search for suppliers.</li>
                                <li>Negotiate the best prices.</li>
                                <li>Procure the necessary materials, equipment, or suppliers adhering to the Institute’s purchasing policies and procedures.</li>
                               </ol>'
                    }
                ] %}

            {% for service in services %}
            <div class="group bg-white border border-slate-200 rounded-2xl p-6 hover:bg-[#008348] hover:border-[#008348] transition-all duration-300">

                <div class="flex items-start gap-5">

                    <div class="w-12 h-12 rounded-xl bg-feu-green/10 text-feu-green group-hover:text-[#febe10] flex items-center justify-center">

                        {% if service.icon == 'budget' %}
                            <!-- chart -->
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M3 3v18h18M7 14l3-3 3 3 5-5"/>
                            </svg>

                        {% elseif service.icon == 'accounting' %}
                            <!-- calculator -->
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M9 2h6v4H9V2zM4 6h16v16H4V6z"/>
                            </svg>

                        {% elseif service.icon == 'students' %}
                            <!-- PERSON icon (updated) -->
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-3.33 0-8 1.67-8 5v1h16v-1c0-3.33-4.67-5-8-5z"/>
                            </svg>

                        {% elseif service.icon == 'money' %}
                            <!-- MONEY / PAYMENT icon (updated) -->
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M17 9V7a4 4 0 00-8 0v2M5 11h14l-1 10H6L5 11z"/>
                            </svg>

                        {% elseif service.icon == 'purchasing' %}
                            <!-- cart -->
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13l-1.5 6H19"/>
                            </svg>
                        {% endif %}

                    </div>

                    <div>
                        <h4 class="font-bold text-feu-green group-hover:text-[#febe10] transition-colors">
                            {{ service.title }}
                        </h4>

                        <div class="text-sm text-slate-500 group-hover:text-white transition-colors">
                            {{ service.desc|raw }}
                        </div>
                    </div>

                </div>

            </div>
            {% endfor %}

            </div>

        </div>

    </div>
</section>

{% endblock %}