                <span class="text-white/90 uppercase tracking-[0.25em] text-xs font-semibold">
                    About FEU Tech
                </span>
            </div>

            <h1 class="text-5xl sm:text-6xl lg:text-7xl font-black text-white leading-[0.95]">
                Vision, Mission,
                <span class="block text-feu-yellow mt-2">
                    & Quality Policy
                </span>
            </h1>

            <div class="mt-8 h-1.5 w-40 bg-gradient-to-r from-feu-yellow via-white to-feu-green rounded-full"></div>

            <p class="mt-8 text-lg text-slate-200 max-w-2xl font-light">
                Driven by innovation, excellence, and nation-building.
            </p>

        </div>

    </div>

</section>


<!-- MAIN SECTION -->
<section class="relative py-28 bg-gradient-to-b from-slate-50 via-white to-slate-100 overflow-hidden">

