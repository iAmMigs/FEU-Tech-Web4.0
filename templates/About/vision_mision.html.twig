{% extends 'base.html.twig' %}

{% block body %}

<section id="top" class="relative isolate w-full min-h-[72vh] flex items-center overflow-hidden">

    <div class="absolute inset-0 z-0">
        <img src="/images/About_TECH.jpg"
             alt="Hero Background"
             class="w-full h-full object-cover scale-105">

        <div class="absolute inset-0 bg-gradient-to-br from-[#00180d]/95 via-[#002d19]/80 to-[#0f172a]/90"></div>

        <div class="absolute -top-32 -left-32 w-96 h-96 bg-feu-yellow/20 rounded-full blur-3xl"></div>
        <div class="absolute bottom-0 right-0 w-[32rem] h-[32rem] bg-feu-green/30 rounded-full blur-3xl"></div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-12 py-24 w-full">

        <div class="max-w-4xl">

            <div class="inline-flex items-center gap-3 px-5 py-2 rounded-full border border-white/10 bg-white/10 backdrop-blur-md mb-8">
