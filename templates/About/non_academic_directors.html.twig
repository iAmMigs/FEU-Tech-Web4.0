{% extends 'base.html.twig' %}

{% block body %}
<style>
    :root {
        --feu-green: #008348;
        --feu-yellow: #febe10;
    }

    /* Card (MATCHED STYLE) */
    .director-card {
        transition: all 0.3s ease;
        border: 1px solid #e2e8f0;
        position: relative;
        overflow: hidden;
        background-color: #ffffff;
    }

    .director-card:hover {
        background-color: #ffffff !important;
        border-color: var(--feu-green);
        box-shadow: 0 4px 12px rgba(0, 131, 72, 0.08);
    }

    .director-card:hover .program-title { color: var(--feu-green); }
    .director-card:hover .director-name { color: #000000; }
    .director-card:hover .role-text { color: var(--feu-yellow); }

    /* Email hover */
    .director-card .email-link { transition: color 0.2s ease; }
    .director-card:hover .email-link { color: #64748b; }
    .director-card .email-link:hover { color: var(--feu-green) !important; }

    /* Bottom line */
    .hover-line {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 0%;
        height: 4px;
        background: var(--feu-green);
        transition: width 0.4s ease;
    }

    .director-card:hover .hover-line {
        width: 100%;
    }
</style>

<!-- Hero Section (MATCHED) -->
<section id="top" class="relative w-full h-[45vh] min-h-[400px] flex items-center justify-center overflow-hidden bg-black">
    <div class="absolute inset-0 z-0">
        <img src="/images/EXECUTIVE_TECH.jpg" alt="Hero Background" class="w-full h-full object-cover opacity-40">
        <div class="absolute inset-0 bg-gradient-to-t from-black via-transparent to-black/20"></div>
    </div>

    <div class="relative z-10 text-center px-5 max-w-4xl mx-auto">
        <span class="text-[#febe10] font-bold tracking-[0.3em] uppercase text-xs mb-4 block">
            Administrative Leadership
        </span>

        <h1 class="text-5xl md:text-7xl font-black text-white leading-tight uppercase tracking-tighter">
            Non-Academic <span class="text-[#008348]">Directors</span>
        </h1>

        <div class="w-24 h-1 bg-[#febe10] mx-auto mt-6"></div>
    </div>
</section>

<!-- Section -->
<section class="py-24 bg-slate-50 relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">

        <!-- Grid (MATCHED) -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

            {% set directors = [
                ['Admissions & External Relations','Doris Rowena Z. Albelda','Director','admissions@feutech.edu.ph'],
                ['Communications','Ma. Ana C. Cayabyab','Director','co@feutech.edu.ph'],
                ['Facilities','Engr. Karl Kevin Dela Calzada','Director','fo@feutech.edu.ph'],
                ['Industry-Academe Linkage, Alumni, and Placement','Samantha Kyle R. Sadorra','Director','ialap@feutech.edu.ph'],
                ['Innovation Programs','Engr. Norman Nicole A. Jimenez','Director','innovate@fit.edu.ph'],
                ['Quality Assurance','Engr. Alexis Mervin T. Sy','Director','qao@feutech.edu.ph']
            ] %}

            {% for d in directors %}
            <div class="director-card bg-white p-8 rounded-lg shadow-sm">

                <!-- Program -->
                <h3 class="program-title text-[#008348] font-black text-sm uppercase tracking-widest mb-4 transition-colors">
                    {{ d[0] }}
                </h3>

                <!-- Name -->
                <p class="director-name text-xl font-bold text-black transition-colors leading-snug">
                    {{ d[1] }}
                </p>

                <!-- Role -->
                <p class="role-text text-xs uppercase mt-2 tracking-wider transition-colors">
                    {{ d[2] }}
                </p>

                <!-- Email -->
                {% if d[3] %}
                <div class="mt-6 pt-6 border-t border-slate-100">
                    <a href="mailto:{{ d[3] }}" 
                       class="email-link text-sm text-slate-500 font-medium transition-colors break-all flex items-center">
                        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                        </svg>
                        {{ d[3] }}
                    </a>
                </div>
                {% endif %}

                <!-- Hover line -->
                <div class="hover-line"></div>
            </div>
            {% endfor %}

        </div>
    </div>
</section>

{% endblock %}