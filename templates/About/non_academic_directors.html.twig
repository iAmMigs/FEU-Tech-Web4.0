{% extends 'base.html.twig' %}

{% block body %}

<!-- Hero Section -->
<section id="top" class="relative w-full h-[40vh] min-h-[400px] flex items-end justify-center overflow-hidden">
    <div class="absolute inset-0 z-0">
        <img src="/images/EXECUTIVE_TECH.jpg" alt="Hero Background" class="w-full h-full object-cover opacity-80 mix-blend-multiply">
        <div class="absolute inset-0 bg-slate-900/60 mix-blend-multiply"></div>
    </div>

    <div class="relative z-10 text-center px-5 max-w-4xl mx-auto pb-16 md:pb-24">
        <span class="text-feu-yellow font-bold tracking-widest uppercase text-sm mb-3 block animate-bounce">
            About Us
        </span>

        <h1 class="text-5xl md:text-7xl font-extrabold text-white leading-tight drop-shadow-lg">
            Non-Academic Directors of <span class="feu-gradient-text">FEU Tech</span>
        </h1>
    </div>
</section>


<!-- Non-Academic Directors Section -->
<section class="py-24 bg-slate-100 relative overflow-hidden scroll-animate">

    <!-- Background accents -->
    <div class="absolute -top-32 -right-32 w-[500px] h-[500px] bg-feu-green opacity-10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-feu-yellow opacity-10 rounded-full blur-3xl"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">

        <!-- Header -->
        <div class="text-center mb-20">
            <span class="text-feu-green font-bold tracking-widest uppercase text-sm animate-pulse">
                Administrative Leadership
            </span>
            <h2 class="text-4xl md:text-5xl font-extrabold text-slate-800 mt-3">
                Non-Academic Directors
            </h2>
            <p class="text-slate-500 mt-4 max-w-2xl mx-auto">
                Leaders responsible for institutional operations, services, and external engagement.
            </p>
        </div>

        <!-- Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">

            {% set directors = [
                ['Admissions & External Relations','Doris Rowena Z. Albelda','Director','admissions@feutech.edu.ph'],
                ['Communications','Ma. Ana C. Cayabyab','Director','co@feutech.edu.ph'],
                ['Facilities','Engr. Karl Kevin Dela Calzada','Director','fo@feutech.edu.ph'],
                ['Industry-Academe Linkage, Alumni, and Placement','Samantha Kyle R. Sadorra','Director','ialap@feutech.edu.ph'],
                ['Innovation Programs','Engr. Norman Nicole A. Jimenez','Director','innovate@fit.edu.ph'],
                ['Quality Assurance','Engr. Alexis Mervin T. Sy','Director','qao@feutech.edu.ph']
            ] %}

            {% for d in directors %}
            <div class="group bg-white p-6 rounded-2xl shadow-lg border border-slate-100 transition duration-500 hover:-translate-y-3 hover:shadow-2xl">

                <!-- Office -->
                <h3 class="text-feu-green font-bold text-lg mb-3">
                    {{ d[0] }}
                </h3>

                <!-- Name -->
                <p class="font-semibold text-slate-800 group-hover:text-feu-green transition">
                    {{ d[1] }}
                </p>

                <!-- Role -->
                <p class="text-feu-yellow font-semibold text-sm mt-2">
                    {{ d[2] }}
                </p>

                <!-- Email -->
                {% if d[3] %}
                <a href="mailto:{{ d[3] }}" 
                   class="block mt-3 text-sm text-slate-500 hover:text-feu-green transition break-all">
                    {{ d[3] }}
                </a>
                {% endif %}

            </div>
            {% endfor %}

        </div>
    </div>
</section>


<!-- Scroll Animation Script -->
<script>
document.addEventListener("DOMContentLoaded", () => {
    const elements = document.querySelectorAll(".scroll-animate");

    const observer = new IntersectionObserver(entries => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add("opacity-100", "translate-y-0");
            }
        });
    }, { threshold: 0.2 });

    elements.forEach(el => {
        el.classList.add("opacity-0", "translate-y-10", "transition-all", "duration-1000");
        observer.observe(el);
    });
});
</script>

{% endblock %}