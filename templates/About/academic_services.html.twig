{% extends 'base.html.twig' %}

{% block body %}
<style>
    :root {
        --feu-green: #008348;
        --feu-yellow: #febe10;
    }

    /* Base card layout */
    .service-card {
        transition: all 0.3s ease;
        border: 1px solid #e2e8f0;
        position: relative;
        overflow: hidden;
        background-color: #ffffff;
    }

    /* Hover State */
    .service-card:hover {
        background-color: #ffffff !important;
        border-color: var(--feu-green);
        box-shadow: 0 4px 12px rgba(0, 131, 72, 0.08);
    }

    /* Text colors */
    .service-card:hover .service-title {
        color: var(--feu-green);
    }

    .service-card:hover .service-name {
        color: #000000;
    }

    .service-card:hover .role-text {
        color: var(--feu-yellow);
    }

    /* Accent line */
    .hover-line {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 0%;
        height: 4px;
        background: var(--feu-green);
        transition: width 0.4s ease;
    }

    .service-card:hover .hover-line {
        width: 100%;
    }
</style>

<!-- Hero Section -->
<section id="top" class="relative w-full h-[45vh] min-h-[400px] flex items-center justify-center overflow-hidden bg-black">
    <div class="absolute inset-0 z-0">
        <img src="/images/EXECUTIVE_TECH.jpg" alt="Hero Background" class="w-full h-full object-cover opacity-40">
        <div class="absolute inset-0 bg-gradient-to-t from-black via-transparent to-black/20"></div>
    </div>

    <div class="relative z-10 text-center px-5 max-w-4xl mx-auto">
        <span class="text-[#febe10] font-bold tracking-[0.3em] uppercase text-xs mb-4 block">
            Student Support
        </span>
        <h1 class="text-5xl md:text-7xl font-black text-white leading-tight uppercase tracking-tighter">
            Academic <span class="text-[#febe10]">Services</span>
        </h1>
        <div class="w-24 h-1 bg-[#febe10] mx-auto mt-6"></div>
    </div>
</section>

<!-- Academic Services Section -->
<section class="py-24 bg-slate-50 relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">

        <!-- Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

            {% set services = [
                ['Community Extension Services','Edison G. Atanacio, RSW','Director'],
                ['Discipline Office','Yvette G. Supnet, RC','Coordinator'],
                ['Guidance and Counseling','Marietta M. Bengat, M.Ed., RGC','Director'],
                ['iTamaraw Center for Academic Resources and Enrichment (iCARE)','Engr. Kennedy P. Limbo','Director'],
                ['Library','Mercedita M. Ragudo, RL, MLIS','Chief Librarian'],
                ['Registrar','Danna May C. Mansul, MIT',''],
                ['Student Activities and Development','Marlon O. Maglipas, M.A.','Director']
            ] %}

            {% for s in services %}
            <div class="service-card bg-white p-8 rounded-lg shadow-sm">

                <!-- Office -->
                <h3 class="service-title text-[#008348] font-black text-sm uppercase tracking-widest mb-4 transition-colors">
                    {{ s[0] }}
                </h3>

                <!-- Name -->
                <p class="service-name text-xl font-bold text-black transition-colors leading-snug">
                    {{ s[1] }}
                </p>

                <!-- Role -->
                {% if s[2] %}
                <p class="role-text text-xs uppercase mt-2 tracking-wider transition-colors">
                    {{ s[2] }}
                </p>
                {% endif %}

                <!-- Hidden Hover Accent -->
                <div class="hover-line"></div>
            </div>
            {% endfor %}

        </div>
    </div>
</section>

{% endblock %}