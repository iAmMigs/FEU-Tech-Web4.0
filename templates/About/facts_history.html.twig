{% extends 'base.html.twig' %}

{% block body %}

<section id="top" class="relative w-full h-[25vh] min-h-[250px] flex items-end justify-center overflow-hidden">
    <div class="absolute inset-0 z-0">
        <img src="/images/About_TECH.jpg"
             alt="Hero Background"
             class="w-full h-full object-cover opacity-80 mix-blend-multiply">
        <div class="absolute inset-0 bg-slate-900/60 mix-blend-multiply"></div>
    </div>

    <div class="relative z-10 text-center px-5 max-w-4xl mx-auto pb-10 md:pb-18">
        <h1 class="text-5xl md:text-7xl font-extrabold text-white mb-6 leading-tight drop-shadow-lg">
            History of <span class="feu-gradient-text">FEU Tech</span>
        </h1>
        <p class="text-lg md:text-xl text-slate-200 mb-10 font-light max-w-2xl mx-auto drop-shadow-md">
            Facts and History
        </p>
    </div>
</section>

<div class="bg-white min-h-screen py-12 px-4 md:px-10">

    <div class="relative max-w-7xl mx-auto" id="timeline">

        <!-- Background line -->
        <div class="absolute left-1/2 transform -translate-x-1/2 h-full border-l-4 border-green-200"></div>

        <!-- Active scrolling line -->
        <div id="timeline-line"
             class="absolute left-1/2 transform -translate-x-1/2 top-0 w-[4px] bg-green-700 h-0 transition-all duration-300 z-10">
        </div>

        <div class="space-y-16">

            {% set timeline = [
                { 'date': '1936', 'content': 'The Commonwealth was two years old and independence was promised a decade hence. The FEU, a private education pioneer, took stock of the emergent nation’s needs. Among its findings was a very pressing need for engineers and technologists to help build the nation. It felt itself challenged and it thus established the Institute of Technology. An increasing demand for trained engineers and technologists remained. With the government’s accelerated economic recovery program, private businesses establishing more and more factories, and agriculture shifting to mechanization, the demand for trained and skilled personnel was greater than ever. The Institute of Technology helped by filling the country’s needs in this respect.', 'image': '/images/history/1936.jpg' },
                { 'date': '1936', 'content': 'When it was founded, the Institute of Technology initially offered a complete course in civil engineering. The Institute has since added complete courses in six other major fields of technology: architecture, chemical engineering, mechanical engineering, electrical engineering, industrial engineering, and chemistry.', 'image': '/images/history/1930.jpg' },
                { 'date': '1952', 'content': 'A course in geodetic engineering was also started', 'image': '/images/history/1960.jpg' },
                { 'date': '1971', 'content': 'The Department of Architecture was elevated into the Institute of Architecture and Fine Arts and took over the architecture program.', 'image': '/images/history/1945.jpg' },
                { 'date': '1978', 'content': 'The course in chemistry was transferred to the Institute of Arts and Sciences.', 'image': '/images/history/1978.jpg' },
                { 'date': '1991', 'content': 'SM Foundation and IBM Philippines set up the Asia Pacific Computer Technology Center (APCTC). Six months later, APCTC collaborated with Far Eastern University (FEU) and Intelligent Wave, Inc. (IWI) and set up a computer school, which was subsequently called East Asia Computer Center. Later, the name was changed to East Asia Institute of Computer Technology (EAICT). Initially, the only degree offered was a Bachelor of Science in Computer and Information Science (BSCIS).', 'image': '/images/history/1991.jpg' },
                { 'date': '1992', 'content': 'FEU takes pride in its relentless efforts for academic excellence. For this reason, it conducts a constant review of programs of major tertiary courses. After a thorough study of the Technology Program, the administration decided to phase it out in favor of a computer technology program forged with East Asia Computer Center, Inc., which offered degrees in Computer Science.', 'image': '/images/history/1992.png' },
                { 'date': '1994', 'content': 'EAICT started to offer the degree of Bachelor of Science in Computer Engineering (BSCOE).', 'image': '/images/history/1994.jpg' },
                { 'date': 'September 30, 1998', 'content': 'The Commission on Higher Education (CHED) noted the change in the name of East Asia Institute of Computer Technology (EAICT) to East Asia College of Information Technology (EACIT).', 'image': '/images/history/1998.jpg' },
                { 'date': 'February 24, 2000', 'content': 'EACIT sought the approval of CHED to offer additional courses leading to the degrees of Bachelor of Science in Information Technology and Bachelor of Science in Information Management. Both courses gained full recognition in April 2004.', 'image': '/images/history/2000.jpg' },
                { 'date': '2001', 'content': 'FEU acquired the controlling stock of EACIT and gained full control of the College.', 'image': '/images/history/2001.jpg' },
                { 'date': '2002', 'content': 'FEU acquired the controlling stock of EACIT.', 'image': '/images/history/2002.jpg' },
                { 'date': '2003', 'content': 'FEU merged Engineering and EACIT forming FEU–EAC.', 'image': '/images/history/2003.jpg' },
                { 'date': '2014', 'content': 'FEU–EAC was renamed FEU Institute of Technology (FEU Tech).', 'image': '/images/history/2014.jpg' }
            ] %}

            {% for item in timeline %}
                {% set isRight = loop.index is even %}

                <div class="relative timeline-item opacity-0 transition-all duration-700 ease-out group flex"
                     data-index="{{ loop.index0 }}">

                    <div class="w-1/2 flex justify-end pr-10">
                        <div class="max-w-md w-full flex flex-col">
                            {% if not isRight %}
                                <h2 class="text-2xl font-extrabold text-green-600 mb-3 text-right group-hover:text-[#febe10] transition">
                                    {{ item.date }}
                                </h2>

                                <div class="flex-1 bg-white rounded-lg shadow-md p-5 border-r-2 border-green-200 flex items-center justify-center text-right group-hover:bg-[#008348] group-hover:text-white transition-all duration-300">
                                    <p>{{ item.content }}</p>
                                </div>
                            {% else %}
                                <div class="mb-3 h-8"></div>

                                <div class="flex-1 overflow-hidden rounded-xl shadow-xl bg-gray-100">
                                    <img src="{{ item.image }}"
                                         class="w-full h-full object-cover transition duration-500 group-hover:scale-105">
                                </div>
                            {% endif %}
                        </div>
                    </div>

                    <!-- CENTER MARKER -->
                    <div class="w-16 flex flex-col items-center marker-container relative z-20">
                        <div class="h-11"></div>

                        <div class="flex-1 w-full relative flex items-center justify-center">

                            <!-- DEFAULT DOT -->
                            <span class="timeline-dot absolute w-6 h-6 rounded-full bg-green-600 border-4 border-white shadow-lg z-10 transition-all duration-300"></span>

                            <!-- ACTIVE GIF -->
                            <img src="/images/readingtamtam2.gif"
                                 class="timeline-gif absolute w-14 h-14 object-contain opacity-0 scale-75 transition-all duration-300 z-20 pointer-events-none rounded-full border-4 border-transparent bg-white">
                        </div>
                    </div>

                    <div class="w-1/2 flex justify-start pl-10">
                        <div class="max-w-md w-full flex flex-col">
                            {% if isRight %}
                                <h2 class="text-2xl font-extrabold text-green-600 mb-3 text-left group-hover:text-[#febe10] transition">
                                    {{ item.date }}
                                </h2>

                                <div class="flex-1 bg-white rounded-lg shadow-md p-5 border-l-2 border-green-200 flex items-center justify-center text-left group-hover:bg-[#008348] group-hover:text-white transition-all duration-300">
                                    <p>{{ item.content }}</p>
                                </div>
                            {% else %}
                                <div class="mb-3 h-8"></div>

                                <div class="flex-1 overflow-hidden rounded-xl shadow-xl bg-gray-100">
                                    <img src="{{ item.image }}"
                                         class="w-full h-full object-cover transition duration-500 group-hover:scale-105">
                                </div>
                            {% endif %}
                        </div>
                    </div>

                </div>
            {% endfor %}

        </div>
    </div>
</div>

<script>
    const items = document.querySelectorAll('.timeline-item');
    const line = document.getElementById('timeline-line');
    const timeline = document.getElementById('timeline');

    const updateLine = () => {

        let activeIndex = -1;
        const viewportMiddle = window.innerHeight / 2;

        items.forEach((item, index) => {
            const rect = item.getBoundingClientRect();

            // Item becomes active once it crosses viewport middle
            if (rect.top < viewportMiddle) {
                activeIndex = index;
            }
        });

        const timelineTop =
            timeline.getBoundingClientRect().top + window.scrollY;

        // If no active item yet
        if (activeIndex < 0) {
            line.style.height = '0px';
        } else {

            // LAST ITEM SPECIAL CASE
            // Make the dark line continue to the very bottom
            if (activeIndex === items.length - 1) {

                const timelineBottom =
                    timeline.getBoundingClientRect().bottom + window.scrollY;

                line.style.height =
                    (timelineBottom - timelineTop) + 'px';

            } else {

                // Normal behavior
                const currentItem = items[activeIndex];
                const dot = currentItem.querySelector('.timeline-dot');

                const dotCenter =
                    dot.getBoundingClientRect().top +
                    window.scrollY +
                    (dot.offsetHeight / 2);

                line.style.height =
                    (dotCenter - timelineTop) + 'px';
            }
        }

        // Handle icon visibility
        items.forEach((item, index) => {

            const dot = item.querySelector('.timeline-dot');
            const gif = item.querySelector('.timeline-gif');

            if (index === activeIndex) {

                dot.classList.add('opacity-0', 'scale-0');

                gif.classList.remove(
                    'opacity-0',
                    'scale-75',
                    'border-transparent'
                );

                gif.classList.add(
                    'opacity-100',
                    'scale-100',
                    'border-green-500'
                );

            } else {

                dot.classList.remove('opacity-0', 'scale-0');

                gif.classList.remove(
                    'opacity-100',
                    'scale-100',
                    'border-green-500'
                );

                gif.classList.add(
                    'opacity-0',
                    'scale-75',
                    'border-transparent'
                );
            }
        });
    };

    // Fade in animation
    const observer = new IntersectionObserver((entries) => {

        entries.forEach(entry => {

            if (entry.isIntersecting) {

                entry.target.classList.remove('opacity-0');
                entry.target.classList.add('opacity-100');
            }
        });

    }, {
        threshold: 0.2
    });

    items.forEach(item => observer.observe(item));

    // Scroll listeners
    window.addEventListener('scroll', updateLine);
    window.addEventListener('resize', updateLine);

    // Initial load
    updateLine();
</script>

{% endblock %}