{% extends 'base.html.twig' %}

{% block title %}Facilities Office | FEU Institute of Technology{% endblock %}

{% block body %}

<!-- HERO SECTION -->
<section class="relative min-h-[50vh] flex items-end overflow-hidden bg-slate-800">

    <!-- Background Image -->
    <div class="absolute inset-0">
        <img src="/images/FEU_TECH.jpg"
             alt="FEU Tech Facilities"
             class="w-full h-full object-cover">

        <!-- Dark Overlay -->
        <div class="absolute inset-0 bg-slate-950/70"></div>

        <!-- Gradient Accent -->
        <div class="absolute inset-0 bg-gradient-to-r from-[#003b25]/90 via-[#003b25]/60 to-transparent"></div>

        <!-- Bottom Accent -->
        <div class="absolute bottom-0 left-0 right-0 h-1 bg-gradient-to-r from-[#008348] via-[#febe10] to-[#008348]"></div>
    </div>

    <!-- Decorative Glow -->
    <div class="absolute top-20 right-[-120px] w-[400px] h-[400px] bg-[#febe10]/10 blur-3xl rounded-full"></div>
    <div class="absolute bottom-[-150px] left-[-100px] w-[350px] h-[350px] bg-[#008348]/20 blur-3xl rounded-full"></div>

    <!-- Content -->
    <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 pb-20 w-full">

        <div class="max-w-3xl">

            <span class="inline-flex items-center px-5 py-2 rounded-full bg-white/10 backdrop-blur-md border border-white/10 text-feu-yellow text-sm font-bold tracking-[0.25em] uppercase mb-7">
                Campus Facilities
            </span>

            <h1 class="text-5xl md:text-6xl lg:text-7xl font-black text-white leading-[0.95] tracking-tight">
                Building the
                <span class="text-feu-yellow">
                    Future of Learning
                </span>
            </h1>

            <p class="mt-8 text-lg md:text-xl text-slate-200 leading-relaxed max-w-2xl">
                FEU Tech delivers modern academic environments, advanced learning spaces,
                and student-centered facilities designed to empower innovation,
                collaboration, wellness, and technological excellence.
            </p>
        </div>

    </div>

</section>

<!-- QUICK STATS -->
<section class="relative z-20 -mt-14">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">

        <div class="grid grid-cols-2 lg:grid-cols-4 gap-5">

            <div class="bg-white rounded-3xl p-7 shadow-2xl border border-slate-100">
                <div class="text-4xl font-black text-feu-green">17</div>
                <p class="text-slate-500 mt-3 text-sm font-medium">
                    Floors of modern infrastructure
                </p>
            </div>

            <div class="bg-white rounded-3xl p-7 shadow-2xl border border-slate-100">
                <div class="text-4xl font-black text-feu-yellow">24/7</div>
                <p class="text-slate-500 mt-3 text-sm font-medium">
                    Campus safety & monitoring
                </p>
            </div>

            <div class="bg-white rounded-3xl p-7 shadow-2xl border border-slate-100">
                <div class="text-4xl font-black text-slate-800">WiFi</div>
                <p class="text-slate-500 mt-3 text-sm font-medium">
                    Building-wide connectivity
                </p>
            </div>

            <div class="bg-white rounded-3xl p-7 shadow-2xl border border-slate-100">
                <div class="text-4xl font-black text-feu-green">Labs</div>
                <p class="text-slate-500 mt-3 text-sm font-medium">
                    Industry-standard facilities
                </p>
            </div>

        </div>

    </div>
</section>

<!-- MAIN FACILITIES SECTION -->
<section id="facilities-section" class="py-24 bg-[#f8fafc] relative overflow-hidden">

    <!-- Background Accents -->
    <div class="absolute top-0 left-0 w-[450px] h-[450px] bg-feu-green/5 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 right-0 w-[450px] h-[450px] bg-feu-yellow/10 rounded-full blur-3xl"></div>

    <div class="max-w-7xl mx-auto px-6 lg:px-8 relative z-10">
        <div class="grid grid-cols-1 lg:grid-cols-[340px_1fr] gap-8">

            <!-- LEFT NAVIGATION -->
            <div class="space-y-4">

                {% set facilities = [
                    {
                        number: '01',
                        title: 'Campus Facilities',
                        subtitle: 'Learning spaces & equipment',
                        color: 'emerald'
                    },
                    {
                        number: '02',
                        title: 'Main Campus',
                        subtitle: 'Heritage & environment',
                        color: 'yellow'
                    },
                    {
                        number: '03',
                        title: 'Technology Building',
                        subtitle: 'Modern infrastructure',
                        color: 'emerald'
                    },
                    {
                        number: '04',
                        title: 'Facilities Office',
                        subtitle: 'Safety & maintenance',
                        color: 'yellow'
                    },
                    {
                        number: '05',
                        title: 'Student Support Offices',
                        subtitle: 'Services & development',
                        color: 'emerald'
                    }
                ] %}

                {% for item in facilities %}
                <button onclick="showContent({{ loop.index0 }})"
                        class="facility-btn {{ loop.first ? 'active' : '' }}">

                    <div class="flex items-center gap-4">

                        <div class="facility-icon {{ item.color }}">
                            {{ item.number }}
                        </div>

                        <div class="text-left">
                            <h3 class="font-bold text-slate-800 text-sm">
                                {{ item.title }}
                            </h3>

                            <p class="text-xs text-slate-500 mt-1">
                                {{ item.subtitle }}
                            </p>
                        </div>

                    </div>

                </button>
                {% endfor %}

            </div>

            <!-- RIGHT VIEWER -->
            <div id="viewer"
                 class="relative overflow-hidden rounded-[2rem] bg-white border border-slate-200 shadow-[0_25px_80px_rgba(15,23,42,0.08)]">

                <!-- Dynamic Content Here -->

            </div>

        </div>

    </div>

</section>

<!-- STYLES -->
<style>

.facility-btn{
    width:100%;
    padding:1rem;
    border-radius:1.4rem;
    background:white;
    border:1px solid #e2e8f0;
    transition:all .3s ease;
    box-shadow:0 4px 20px rgba(15,23,42,.03);
}

.facility-btn:hover{
    transform:translateY(-4px);
    border-color:rgba(0,131,72,.2);
    box-shadow:0 16px 35px rgba(15,23,42,.08);
}

.facility-btn.active{
    background:#003b25;
    border-color:#003b25;
}

.facility-btn.active h3,
.facility-btn.active p{
    color:white;
}

.facility-icon{
    width:44px;
    height:44px;
    min-width:44px;
    border-radius:.9rem;
    display:flex;
    align-items:center;
    justify-content:center;
    font-weight:800;
    font-size:.8rem;
    transition:.3s;
}

.facility-icon.emerald{
    background:#ecfdf5;
    color:#008348;
}

.facility-icon.yellow{
    background:#fef9c3;
    color:#ca8a04;
}

.facility-icon.slate{
    background:#f1f5f9;
    color:#0f172a;
}

.facility-icon.blue{
    background:#eff6ff;
    color:#2563eb;
}

.facility-icon.purple{
    background:#faf5ff;
    color:#9333ea;
}

.facility-btn.active .facility-icon{
    background:rgba(255,255,255,.1);
    color:#febe10;
}

.facility-hero-btn{
    padding:.95rem 1.75rem;
    border-radius:1rem;
    font-weight:700;
    transition:.3s;
}

.facility-hero-btn:hover{
    transform:translateY(-3px);
}

.facility-stat-card{
    background:#f8fafc;
    border:1px solid #e2e8f0;
    border-radius:1.25rem;
    padding:1.2rem;
}

.facility-stat-card .stat-title{
    font-size:2rem;
    font-weight:900;
    line-height:1;
}

.facility-stat-card p{
    margin-top:.55rem;
    font-size:.82rem;
    color:#64748b;
    line-height:1.5;
}

.facility-main-image{
    transition: opacity .35s ease;
}

.gallery-thumb{
    width:80px;
    height:80px;
    overflow:hidden;
    border-radius:1rem;
    border:3px solid rgba(255,255,255,.7);
    background:white;
    cursor:pointer;
    transition:all .3s ease;
    box-shadow:0 10px 30px rgba(0,0,0,.25);
}

.gallery-thumb:hover{
    transform:translateY(-5px) scale(1.05);
    border-color:#febe10;
}

.gallery-thumb img{
    width:100%;
    height:100%;
    object-fit:cover;
}

</style>

<!-- SCRIPT -->
<script>

const data = [

{
    badge: "Facilities",

    title: "Modern Learning & Campus Facilities",

    images: [
        "/images/facility/campus_facilities_1.jpg",
        "/images/facility/campus_facilities_2.jpg",
        "/images/facility/campus_facilities_3.jpg",
    ],

    desc: `
        <p>
            FEU Tech provides fully-equipped air-conditioned classrooms and laboratories;
            high-tech computers, engineering tools, and equipment; 24-hour security and monitoring;
            full library services; canteen and student services; and building-wide WiFi accessibility.
        </p>

        <p>
            Students benefit from a safe, innovative, and technology-driven academic environment
            designed to support learning, collaboration, and professional growth.
        </p>
    `,

    stats: `
        <div class="facility-stat-card">
            <div class="stat-title text-feu-green">E-Library</div>
            <p>A go-to place when you need to study</p>
        </div>

        <div class="facility-stat-card">
            <div class="stat-title text-feu-yellow">WiFi</div>
            <p>Building-wide internet accessibility</p>
        </div>

        <div class="facility-stat-card">
            <div class="stat-title text-slate-800">Labs</div>
            <p>Industry-standard engineering facilities and high-tech computers</p>
        </div>
    `
},

{
    badge: "Heritage",

    title: "The FEU Main Campus Experience",

    images: [
        "/images/facility/Main_campus.jpg",
        "/images/facility/Main_campus_2.jpg",
        "/images/facility/Main_campus_3.jpg"
    ],

    desc: `
        <p>
            The FEU Technology Building is located along Morayta within Far Eastern University’s
            prestigious campus, which has been part of Manila’s educational legacy for over 90 years.
        </p>

        <p>
            The Main Campus features grassy parks, shady trees, and award-winning Art Deco architecture,
            including five buildings designed by National Artist Pablo Antonio.
        </p>
    `,

    stats: `
        <div class="facility-stat-card">
            <div class="stat-title text-feu-green">90+</div>
            <p>Years of educational excellence</p>
        </div>

        <div class="facility-stat-card">
            <div class="stat-title text-feu-yellow">5</div>
            <p>Art Deco buildings by Pablo Antonio</p>
        </div>

        <div class="facility-stat-card">
            <div class="stat-title text-slate-800">Green</div>
            <p>Open parks and shaded campus spaces</p>
        </div>
    `
},

{
    badge: "Innovation",

    title: "The Modern FEU Technology Building",

    images: [
        "/images/facility/Modern (1).jpg",
        "/images/facility/Modern (2).jpg",
        "/images/facility/Modern (3).jpg"
    ],

    desc: `
        <p>
            FEU Institute of Technology is housed in a modern 17-story building in the
            heart of Manila’s University Belt.
        </p>

        <p>
            The building includes scenic elevators, electronic library facilities,
            a covered gym and basketball court, a 25-meter indoor swimming pool,
            eco-friendly Green Building Technology, standby power supply systems,
            and energy-efficient air conditioning.
        </p>
    `,

    stats: `
        <div class="facility-stat-card">
            <div class="stat-title text-feu-green">17</div>
            <p>Floors of modern infrastructure</p>
        </div>

        <div class="facility-stat-card">
            <div class="stat-title text-feu-yellow">25m</div>
            <p>Indoor swimming pool facility</p>
        </div>

        <div class="facility-stat-card">
            <div class="stat-title text-slate-800">Eco</div>
            <p>Green Building Technology systems</p>
        </div>
    `
},

{
    badge: "Operations",

    title: "Facilities Office Responsibilities",

    images: [
        "/images/facility/facilities_1.jpg",
        "/images/facility/facilities_2.jpg",
        "/images/facility/facilities_3.png"
    ],

    desc: `
        <p>
            The Facilities Office maintains an ideal academic physical setting
            for the Institute while ensuring safety and efficiency across campus.
        </p>

        <p>
            Its main responsibility is to create and maintain a safe environment
            for students and associates while monitoring facility usage and
            daily campus activities.
        </p>
    `,

    stats: `
        <div class="facility-stat-card">
            <div class="stat-title text-feu-green">Safe</div>
            <p>Secure learning environment</p>
        </div>

        <div class="facility-stat-card">
            <div class="stat-title text-feu-yellow">Daily</div>
            <p>Facility activity monitoring</p>
        </div>

        <div class="facility-stat-card">
            <div class="stat-title text-slate-800">Care</div>
            <p>Campus maintenance management</p>
        </div>
    `
},

{
    badge: "Student Services",

    title: "Comprehensive Student Support Offices",

    images: [
        "/images/facility/student_support_1.png",
        "/images/facility/student_support_1.jpg",
        "/images/facility/student_support_3.jpg"
    ],

    desc: `
        <p>
            FEU Tech supports students through specialized offices including
            AERO, GCO, SADO, Health Services Unit, ITSO, iCARE,
            Library Services, IALAP, and the Registrar’s Office.
        </p>

        <p>
            These offices provide academic support, wellness services,
            career development, leadership opportunities, industry linkages,
            technological assistance, and student-centered services.
        </p>
    `,

    stats: `
        <div class="facility-stat-card">
            <div class="stat-title text-feu-green">iCARE</div>
            <p>Academic enrichment services</p>
        </div>

        <div class="facility-stat-card">
            <div class="stat-title text-feu-yellow">IALAP</div>
            <p>Career and industry opportunities</p>
        </div>

        <div class="facility-stat-card">
            <div class="stat-title text-slate-800">SADO</div>
            <p>Leadership and student development</p>
        </div>
    `
}

];

function changeGalleryImage(src){

    const mainImage = document.getElementById("mainFacilityImage");

    mainImage.style.opacity = "0";

    setTimeout(() => {
        mainImage.src = src;
        mainImage.style.opacity = "1";
    }, 200);
}

function showContent(index){

    const viewer = document.getElementById("viewer");
    const buttons = document.querySelectorAll(".facility-btn");

    buttons.forEach(btn => btn.classList.remove("active"));
    buttons[index].classList.add("active");

    viewer.innerHTML = `

        <div class="relative overflow-hidden">

            <!-- MAIN IMAGE -->
            <div class="relative h-[420px] overflow-hidden">

                <img 
                    id="mainFacilityImage"
                    src="${data[index].images[0]}"
                    class="w-full h-full object-cover facility-main-image">

                <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-900/40 to-transparent"></div>

                <div class="absolute bottom-16 left-0 p-8 lg:p-10">

                    <div class="inline-flex items-center px-4 py-2 rounded-full bg-white/10 backdrop-blur-md border border-white/10 text-white text-xs font-bold uppercase tracking-[0.2em] mb-5">
                        ${data[index].badge}
                    </div>

                    <h2 class="text-4xl lg:text-5xl font-black text-white max-w-3xl leading-tight">
                        ${data[index].title}
                    </h2>

                </div>

            </div>

            <!-- THUMBNAILS -->
            <div class="absolute bottom-6 right-6 flex gap-4 z-20">

                ${data[index].images.map((img) => `
                    <button 
                        onclick="changeGalleryImage('${img}')"
                        class="gallery-thumb">

                        <img src="${img}" class="w-full h-full object-cover">

                    </button>
                `).join('')}

            </div>

        </div>

        <div class="p-8 lg:p-10">

            <div class="grid grid-cols-1 lg:grid-cols-[1.2fr_.8fr] gap-10">

                <div>

                    <div class="space-y-7 text-slate-600 leading-loose text-[16px] lg:text-[17px] font-medium">
                        ${data[index].desc}
                    </div>

                </div>

                <div class="grid grid-cols-1 gap-4">
                    ${data[index].stats}
                </div>

            </div>

        </div>
    `;
}

showContent(0);

</script>

{% endblock %}