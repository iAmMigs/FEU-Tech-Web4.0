{% extends 'base.html.twig' %}

{% block body %}
<style>
    :root {
        --feu-green: #006341;
        --feu-gold: #EAAA00;
    }
    
    .text-gradient-feu {
        background: linear-gradient(to right, #EAAA00, #fff9c4);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        display: inline-block;
    }

    .glass-card {
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
    }

    .glass-card:hover {
        background: rgba(255, 255, 255, 0.2);
        transform: translateX(12px);
        border-color: rgba(255, 255, 255, 0.3);
        z-index: 100; 
    }

    .description-popup {
        visibility: hidden;
        opacity: 0;
        position: absolute;
        left: 105%;
        top: 0;
        width: 320px;
        padding: 1.25rem;
        background: rgba(0, 0, 0, 0.95);
        backdrop-filter: blur(15px);
        border: 1px solid rgba(234, 170, 0, 0.6);
        color: white;
        border-radius: 0.75rem;
        font-size: 0.875rem;
        line-height: 1.5;
        z-index: 999; 
        transition: all 0.3s ease-in-out;
        transform: translateX(-10px);
        box-shadow: 0 20px 40px rgba(0,0,0,0.9);
        pointer-events: none;
    }

    .glass-card:hover .description-popup {
        visibility: visible;
        opacity: 1;
        transform: translateX(0);
    }

    .soft-underline {
        height: 1px;
        background: linear-gradient(to right, rgba(255,255,255,0.8), transparent);
        width: 100%;
        margin-top: 0.5rem;
    }

    /* Updated scroll math: 500px (width) + 24px (gap) * 3 images */
    @keyframes scroll {
        0% { transform: translateX(0); }
        100% { transform: translateX(calc(-500px * 3 - 1.5rem * 3)); }
    }

    .carousel-track {
        display: flex;
        gap: 1.5rem;
        width: max-content;
        animation: scroll 30s linear infinite;
    }

    .carousel-track:hover {
        animation-play-state: paused;
    }
</style>

<div class="relative w-full h-screen overflow-hidden bg-black font-sans">
    
    <div class="absolute inset-0 z-0">
        <img src="/images/FACILITIES_TECH.jpg" alt="Background" class="w-full h-full object-cover opacity-40">
        <div class="absolute inset-0 bg-gradient-to-tr from-black via-black/40 to-transparent"></div>
    </div>

    <div class="absolute -right-16 bottom-0 z-10 h-[85%] pointer-events-none select-none">
        <img src="/images/TAMTAM.png" alt="Mascot" class="h-full w-auto object-contain">
    </div>

    <div class="relative z-20 grid grid-cols-1 lg:grid-cols-12 h-full w-full">
        
        <div class="lg:col-span-5 flex flex-col justify-start mt-24 px-20 space-y-12 z-50">
            <div class="space-y-1">
                <h1 class="text-white text-7xl font-bold leading-none tracking-tight">
                    Facilities of<br>
                    <span class="text-gradient-feu">FEU Tech</span>
                </h1>
            </div>

            <div class="space-y-4 w-full max-w-sm">
                <div class="glass-card rounded-xl p-6 cursor-pointer group">
                    <p class="text-white/90 text-lg font-medium">What FEU Tech provides</p>
                    <div class="description-popup">
                        FEU Tech provides fully-equipped air-conditioned classrooms and laboratories; high-tech computers, engineering tools, and equipment; 24-hour security and monitoring; full library services; canteen and student services; and building-wide WiFi accessibility.
                    </div>
                </div>

                <div class="glass-card rounded-xl p-6 cursor-pointer group">
                    <p class="text-white/90 text-lg font-medium">What the Main Campus features</p>
                    <div class="description-popup">
                        Located within FEU’s prestigious campus, a vital part of Manila’s legacy for 90+ years. Features a natural ecological environment of grassy parks and shady trees, and five Art Deco buildings designed by National Artist Pablo Antonio.
                    </div>
                </div>

                <div class="glass-card rounded-xl p-6 cursor-pointer group">
                    <p class="text-white/90 text-lg font-medium">What the new building features</p>
                    <div class="description-popup">
                        A 17-story building in the University Belt featuring scenic elevators, electronic library, covered gym, 25-meter indoor pool, and eco-friendly Green Building Technology with energy-efficient air conditioning.
                    </div>
                </div>
            </div>
        </div>

        <div class="lg:col-span-7 flex flex-col justify-start mt-24 items-center lg:items-start pr-20 z-10">
            
            <div class="mb-14 text-center lg:text-left">
                <h2 class="text-white/80 text-4xl font-light italic mb-3">We are Building</h2>
                <div class="inline-block">
                    <h1 class="text-white text-8xl font-black tracking-[0.15em] uppercase leading-none">
                        FUTURE
                    </h1>
                    <div class="soft-underline"></div>
                </div>
            </div>

            <!-- Added mt-12 to push ONLY the carousel lower -->
            <div class="relative w-full overflow-hidden py-4 mb-8">
                <div class="carousel-track">
                    <!-- Increased size to w-[500px] h-[300px] -->
                    <div class="w-[500px] h-[300px] rounded-2xl overflow-hidden border-[3px] border-white/20 shadow-2xl shrink-0">
                        <img src="/images/FACILITIES_TECH.jpg" class="w-full h-full object-cover" alt="Facility 1">
                    </div>
                    <div class="w-[500px] h-[300px] rounded-2xl overflow-hidden border-[3px] border-white/20 shadow-2xl shrink-0">
                        <img src="/images/FACILITIES_TECH.jpg" class="w-full h-full object-cover" alt="Facility 2">
                    </div>
                    <div class="w-[500px] h-[300px] rounded-2xl overflow-hidden border-[3px] border-white/20 shadow-2xl shrink-0">
                        <img src="/images/FACILITIES_TECH.jpg" class="w-full h-full object-cover" alt="Facility 3">
                    </div>
                    <!-- Duplicates -->
                    <div class="w-[500px] h-[300px] rounded-2xl overflow-hidden border-[3px] border-white/20 shadow-2xl shrink-0">
                        <img src="/images/FACILITIES_TECH.jpg" class="w-full h-full object-cover" alt="Facility 1">
                    </div>
                    <div class="w-[500px] h-[300px] rounded-2xl overflow-hidden border-[3px] border-white/20 shadow-2xl shrink-0">
                        <img src="/images/FACILITIES_TECH.jpg" class="w-full h-full object-cover" alt="Facility 2">
                    </div>
                    <div class="w-[500px] h-[300px] rounded-2xl overflow-hidden border-[3px] border-white/20 shadow-2xl shrink-0">
                        <img src="/images/FACILITIES_TECH.jpg" class="w-full h-full object-cover" alt="Facility 3">
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>
{% endblock %}