{% extends 'base.html.twig' %}

{% block body %}
<style>
    :root {
        --feu-green: #008348;
        --feu-yellow: #febe10;
    }

    /* Card style (MATCHED) */
    .officer-card {
        transition: all 0.3s ease;
        border: 1px solid #e2e8f0;
        position: relative;
        overflow: hidden;
        background-color: #ffffff;
    }

    .officer-card:hover {
        background-color: #ffffff !important;
        border-color: var(--feu-green);
        box-shadow: 0 4px 12px rgba(0, 131, 72, 0.08);
    }

    .officer-card:hover .name {
        color: #000000;
    }

    .officer-card:hover .role {
        color: var(--feu-yellow);
    }

    /* Bottom accent line */
    .hover-line {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 0%;
        height: 4px;
        background: var(--feu-green);
        transition: width 0.4s ease;
    }

    .officer-card:hover .hover-line {
        width: 100%;
    }
</style>

<!-- Hero Section (MATCHED) -->
<section id="top" class="relative w-full h-[45vh] min-h-[400px] flex items-center justify-center overflow-hidden bg-black">
    <div class="absolute inset-0 z-0">
        <img src="/images/EXECUTIVE_TECH.jpg" alt="Hero Background" class="w-full h-full object-cover opacity-40">
        <div class="absolute inset-0 bg-gradient-to-t from-black via-transparent to-black/20"></div>
    </div>

    <div class="relative z-10 text-center px-5 max-w-4xl mx-auto">
        <span class="text-[#febe10] font-bold tracking-[0.3em] uppercase text-xs mb-4 block">
            Leadership
        </span>

        <h1 class="text-5xl md:text-7xl font-black text-white leading-tight uppercase tracking-tighter">
            Executive <span class="text-[#008348]">Officers</span>
        </h1>

        <div class="w-24 h-1 bg-[#febe10] mx-auto mt-6"></div>
    </div>
</section>

<!-- Executive Officers Section -->
<section class="py-24 bg-slate-50 relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">

        <!-- Grid (MATCHED gap) -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

            {% set officers = [
                ['Juan Miguel R. Montinola','President'],
                ['Benson T. Tan, Ph.D.','Senior Executive Director'],
                ['Edna M. Anicete','Executive Director for Finance'],
                ['Rossana T. Adao','Executive Director'],
                ['Romano Q. Neyra, D.T., Asean Engineer','Senior Director for Engineering'],
                ['Ace C. Lagman, DIT','Senior Director for Computer Studies and Multimedia Arts'],
                ['Manuel B. Garcia, DIT, LPT','Senior Director for Educational Technology and Digital Learning'],
                ['Engr. Daryl D. David','Senior Director for Innovation and Research'],
                ['Remella A. Cabreros, D.B.A.','Senior Director for Academic Services'],
                ['Jarvis C. Muyargas','Senior Director for Student Success'],
                ['Engr. Rolando B. Cauriz','Senior Director for Facilities'],
                ['Jacklyn Anne C. Mantolino','Senior Director for Human Resources'],
                ['Ana Liza G. Velasquez','Senior Director for Information Technology Services'],
                ['Ma. Christina N. Nalipay','Senior Director for Finance']
            ] %}

            {% for o in officers %}
            <div class="officer-card bg-white p-8 rounded-lg shadow-sm">

                <!-- Name -->
                <p class="name text-xl font-bold text-black transition-colors leading-snug">
                    {{ o[0] }}
                </p>

                <!-- Role -->
                <p class="role text-s text-[#008348] uppercase mt-2 tracking-wider transition-colors">
                    {{ o[1] }}
                </p>

                <!-- Hover line -->
                <div class="hover-line"></div>
            </div>
            {% endfor %}

        </div>
    </div>
</section>

{% endblock %}