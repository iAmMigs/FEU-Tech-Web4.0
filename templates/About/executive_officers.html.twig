{% extends 'base.html.twig' %}

{% block body %}

<!-- Hero Section -->
<section id="top" class="relative w-full h-[40vh] min-h-[400px] flex items-end justify-center overflow-hidden">
    <div class="absolute inset-0 z-0">
        <img src="/images/EXECUTIVE_TECH.jpg" alt="Hero Background" class="w-full h-full object-cover opacity-80 mix-blend-multiply">
        <div class="absolute inset-0 bg-slate-900/60 mix-blend-multiply"></div>
    </div>

    <div class="relative z-10 text-center px-5 max-w-4xl mx-auto pb-16 md:pb-24">
        <span class="text-feu-yellow font-bold tracking-widest uppercase text-sm mb-3 block animate-bounce">
            About Us
        </span>

        <h1 class="text-5xl md:text-7xl font-extrabold text-white mb-6 leading-tight drop-shadow-lg">
            Executive Officers of <span class="feu-gradient-text">FEU Tech</span>
        </h1>
    </div>
</section>


<!-- Executive Officers Section -->
<section class="py-24 bg-slate-100 relative overflow-hidden">

