{% extends 'base.html.twig' %}

{% block title %}College of Engineering | FEU Institute of Technology{% endblock %}

{% block body %}

<!-- HERO SECTION -->
<section class="relative min-h-[92vh] overflow-hidden bg-[#03140d] flex items-center">

    <div class="absolute inset-0">
        <img src="/images/offices/academic.png"
             alt="COE Hero"
             class="w-full h-full object-cover opacity-20">

        <div class="absolute inset-0 bg-gradient-to-br from-[#02110b]/80 via-[#05261a]/60 to-[#03140d]/85"></div>
    </div>

    <div class="absolute inset-0 opacity-[0.06]"
         style="background-image:
         linear-gradient(rgba(255,255,255,0.08) 1px, transparent 1px),
         linear-gradient(90deg, rgba(255,255,255,0.08) 1px, transparent 1px);
         background-size: 42px 42px;">
    </div>

    <div class="absolute top-0 left-0 w-[500px] h-[500px] bg-[#008348]/25 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 right-0 w-[500px] h-[500px] bg-[#febe10]/15 rounded-full blur-3xl"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 w-full">

        <div class="max-w-4xl">

            <span class="inline-flex items-center gap-2 px-5 py-2 rounded-full border border-[#febe10]/20 bg-[#008348]/20 text-[#febe10] text-sm font-semibold tracking-[0.2em] uppercase">
                ⚙ Build • Design • Engineer
            </span>

            <h1 class="mt-8 text-5xl md:text-7xl font-black text-white uppercase leading-[0.95]">
                College of
                <span class="block text-transparent bg-clip-text bg-gradient-to-r from-white via-[#febe10] to-[#febe10]">
                    Engineering
                </span>
            </h1>

            <p class="mt-8 text-lg md:text-2xl text-slate-300 max-w-3xl leading-relaxed">
                Developing globally competitive engineers equipped with analytical thinking,
                innovation, and technical mastery in infrastructure, systems, electronics,
                and sustainable engineering solutions.
            </p>

        </div>

    </div>
</section>

<!-- STICKY NAV -->
<div class="sticky top-[80px] z-40 bg-[#03140d]/85 backdrop-blur-xl border-y border-white/5">
    <div class="max-w-7xl mx-auto px-6">
        <div class="flex overflow-x-auto gap-8 py-4 text-sm font-semibold uppercase tracking-wide text-slate-300 scrollbar-hide">
            <a href="#overview" class="hover:text-[#febe10] transition whitespace-nowrap">Overview</a>
            <a href="#programs" class="hover:text-[#febe10] transition whitespace-nowrap">Programs</a>
            <a href="#peo" class="hover:text-[#febe10] transition whitespace-nowrap">Objectives</a>
            <a href="#outcomes" class="hover:text-[#febe10] transition whitespace-nowrap">Outcomes</a>
        </div>
    </div>
</div>

<!-- OVERVIEW -->
<section id="overview" class="py-28 bg-[#f8fafc] scroll-mt-32">

    <div class="max-w-7xl mx-auto px-6 lg:px-8">

        <div class="grid lg:grid-cols-2 gap-20 items-center">

            <div>

                <span class="text-[#008348] font-bold uppercase tracking-[0.2em] text-sm">
                    About COE
                </span>

                <h2 class="mt-5 text-4xl md:text-5xl font-black text-slate-900 leading-tight">
                    Engineering the Future of Infrastructure & Innovation
                </h2>

                <p class="mt-6 text-lg text-slate-600 leading-relaxed">
                    The College of Engineering develops globally competitive professionals
                    with strong foundations in science, mathematics, design, and innovation.
                </p>

                <p class="mt-6 text-lg text-slate-600 leading-relaxed">
                    Students are trained in modern engineering fields including civil,
                    mechanical, electrical, electronics, computer engineering, and construction systems.
                </p>

            </div>

            <!-- ENHANCED SIDE CARDS -->
            <div class="grid gap-6">

                <div class="bg-white border border-slate-200 rounded-3xl p-7 shadow-sm hover:shadow-xl transition duration-300">
                    <div class="flex items-center gap-5">

                        <div class="w-16 h-16 rounded-2xl bg-[#008348]/10 flex items-center justify-center">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-[#008348]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M3 7.5l9-4.5 9 4.5m-18 0l9 4.5m-9-4.5v9l9 4.5m0-9l9-4.5m-9 4.5v9"/>
                            </svg>
                        </div>

                        <div>
                            <h3 class="text-4xl font-black text-[#008348]">6</h3>
                            <p class="text-slate-600 font-medium mt-1">
                                Engineering Programs
                            </p>
                        </div>

                    </div>
                </div>

                <div class="bg-white border border-slate-200 rounded-3xl p-7 shadow-sm hover:shadow-xl transition duration-300">
                    <div class="flex items-center gap-5">

                        <div class="w-16 h-16 rounded-2xl bg-[#febe10]/15 flex items-center justify-center">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-[#febe10]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L15 12l-5.25-5"/>
                            </svg>
                        </div>

                        <div>
                            <h3 class="text-4xl font-black text-[#febe10]">BIM</h3>
                            <p class="text-slate-600 font-medium mt-1">
                                Modern Engineering Tools
                            </p>
                        </div>

                    </div>
                </div>

                <div class="bg-white border border-slate-200 rounded-3xl p-7 shadow-sm hover:shadow-xl transition duration-300">
                    <div class="flex items-center gap-5">

                        <div class="w-16 h-16 rounded-2xl bg-[#008348]/10 flex items-center justify-center">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-[#008348]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0v11.25m0-11.25H8.25"/>
                            </svg>
                        </div>

                        <div>
                            <h3 class="text-4xl font-black text-[#008348]">Design</h3>
                            <p class="text-slate-600 font-medium mt-1">
                                Systems & Innovation
                            </p>
                        </div>

                    </div>
                </div>

            </div>

        </div>

    </div>
</section>

<!-- PROGRAMS -->
<section id="programs" class="py-28 bg-white scroll-mt-32">

    <div class="max-w-7xl mx-auto px-6 lg:px-8">

        <div class="text-center mb-16">
            <h2 class="text-4xl md:text-5xl font-black text-slate-800">
                Engineering Programs
            </h2>
        </div>

        <div class="grid md:grid-cols-2 xl:grid-cols-3 gap-8">

            <!-- Construction Engineering -->
            <div class="group bg-white border border-slate-200 rounded-3xl p-8 shadow-sm hover:shadow-2xl transition duration-300 hover:-translate-y-2">

                <div class="flex items-start gap-5 mb-6">

                    <div class="shrink-0 w-16 h-16 rounded-2xl bg-[#008348]/10 flex items-center justify-center mt-1">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6"> <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 0 0 4.486-6.336l-3.276 3.277a3.004 3.004 0 0 1-2.25-2.25l3.276-3.276a4.5 4.5 0 0 0-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437 1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008Z"
                             class="w-8 h-8 text-[#008348]"
                             fill="none"
                             viewBox="0 0 24 24"
                             stroke="currentColor"
                             stroke-width="1.8">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M3 21h18M5 21V9l7-5 7 5v12M9 21V14h6v7"/>
                        </svg>
                    </div>

                    <h3 class="text-xl font-black uppercase leading-snug text-[#008348]">
                        Bachelor of Science in Construction Engineering and Management
                    </h3>

                </div>

                <p class="text-slate-600 leading-relaxed">
                    B.S. Construction Engineering and Management combines engineering and management to improve construction projects. Students gain hands-on experience with tools like Building Information Modeling (BIM) and construction safety protocols.
                </p>

            </div>

            <!-- Civil Engineering -->
            <div class="group bg-white border border-slate-200 rounded-3xl p-8 shadow-sm hover:shadow-2xl transition duration-300 hover:-translate-y-2">

                <div class="flex items-start gap-5 mb-6">

                    <div class="shrink-0 w-16 h-16 rounded-2xl bg-[#febe10]/15 flex items-center justify-center mt-1">
                        <svg xmlns="http://www.w3.org/2000/svg"
                             class="w-8 h-8 text-[#febe10]"
                             fill="none"
                             viewBox="0 0 24 24"
                             stroke="currentColor"
                             stroke-width="1.8">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M4 18h16M6 18V9m4 9V6m4 12v-8m4 8V4"/>
                        </svg>
                    </div>

                    <h3 class="text-xl font-black uppercase leading-snug text-[#008348]">
                        Bachelor of Science in Civil Engineering
                    </h3>

                </div>

                <p class="text-slate-600 leading-relaxed">
                    The program was established in order to answer the need for professional civil engineers who can contribute significantly in building the nation through infrastructure planning and development.
                </p>

            </div>

            <!-- Computer Engineering -->
            <div class="group bg-white border border-slate-200 rounded-3xl p-8 shadow-sm hover:shadow-2xl transition duration-300 hover:-translate-y-2">

                <div class="flex items-start gap-5 mb-6">

                    <div class="shrink-0 w-16 h-16 rounded-2xl bg-[#008348]/10 flex items-center justify-center mt-1">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 0 1-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0 1 15 18.257V17.25m6-12V15a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 15V5.25m18 0A2.25 2.25 0 0 0 18.75 3H5.25A2.25 2.25 0 0 0 3 5.25m18 0V12a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 12V5.25"
                             class="w-8 h-8 text-[#008348]"
                             fill="none"
                             viewBox="0 0 24 24"
                             stroke="currentColor"
                             stroke-width="1.8">
                            <rect x="7" y="7" width="10" height="10" rx="2"/>
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M9 1v3M15 1v3M9 20v3M15 20v3M20 9h3M20 15h3M1 9h3M1 15h3"/>
                        </svg>
                    </div>

                    <h3 class="text-xl font-black uppercase leading-snug text-[#008348]">
                        Bachelor of Science in Computer Engineering
                    </h3>

                </div>

                <p class="text-slate-600 leading-relaxed">
                    The program provides a broad undergraduate education to develop analytical skills and practical design knowledge that ensures long-term career flexibility.
                </p>

            </div>

            <!-- Electrical Engineering -->
            <div class="group bg-white border border-slate-200 rounded-3xl p-8 shadow-sm hover:shadow-2xl transition duration-300 hover:-translate-y-2">

                <div class="flex items-start gap-5 mb-6">

                    <div class="shrink-0 w-16 h-16 rounded-2xl bg-[#febe10]/15 flex items-center justify-center mt-1">
                        <svg xmlns="http://www.w3.org/2000/svg"
                             class="w-8 h-8 text-[#febe10]"
                             fill="none"
                             viewBox="0 0 24 24"
                             stroke="currentColor"
                             stroke-width="1.8">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M13 2L6 14h5l-1 8 7-12h-5l1-8z"/>
                        </svg>
                    </div>

                    <h3 class="text-xl font-black uppercase leading-snug text-[#008348]">
                        Bachelor of Science in Electrical Engineering
                    </h3>

                </div>

                <p class="text-slate-600 leading-relaxed">
                    The branch of engineering that deals with the technology of electricity, especially the design and application of circuitry and equipment for power generation and distribution, machine control, and communications.
                </p>

            </div>

            <!-- Electronics Engineering -->
            <div class="group bg-white border border-slate-200 rounded-3xl p-8 shadow-sm hover:shadow-2xl transition duration-300 hover:-translate-y-2">

                <div class="flex items-start gap-5 mb-6">

                    <div class="shrink-0 w-16 h-16 rounded-2xl bg-[#008348]/10 flex items-center justify-center mt-1">
                        <svg xmlns="http://www.w3.org/2000/svg"
                             class="w-8 h-8 text-[#008348]"
                             fill="none"
                             viewBox="0 0 24 24"
                             stroke="currentColor"
                             stroke-width="1.8">
                            <rect x="5" y="5" width="14" height="14" rx="2"/>
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M9 9h6v6H9z"/>
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M3 9h2M3 15h2M19 9h2M19 15h2M9 3v2M15 3v2M9 19v2M15 19v2"/>
                        </svg>
                    </div>

                    <h3 class="text-xl font-black uppercase leading-snug text-[#008348]">
                        Bachelor of Science in Electronics Engineering
                    </h3>

                </div>

                <p class="text-slate-600 leading-relaxed">
                    Being the most sought after branch of Engineering, this program is a dynamic program that prepares its graduates to be in the forefront of the revolutionary electronics technology.
                </p>

            </div>

            <!-- Mechanical Engineering -->
            <div class="group bg-white border border-slate-200 rounded-3xl p-8 shadow-sm hover:shadow-2xl transition duration-300 hover:-translate-y-2">

                <div class="flex items-start gap-5 mb-6">

                    <div class="shrink-0 w-16 h-16 rounded-2xl bg-[#febe10]/15 flex items-center justify-center mt-1">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28Z" />
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" 
                             class="w-8 h-8 text-[#febe10]"
                             fill="none"
                             viewBox="0 0 24 24"
                             stroke="currentColor"
                             stroke-width="1.8">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M12 3v3M12 18v3M4.93 4.93l2.12 2.12M16.95 16.95l2.12 2.12M3 12h3M18 12h3M4.93 19.07l2.12-2.12M16.95 7.05l2.12-2.12"/>
                            <circle cx="12" cy="12" r="4"/>
                        </svg>
                    </div>

                    <h3 class="text-xl font-black uppercase leading-snug text-[#008348]">
                        Bachelor of Science in Mechanical Engineering
                    </h3>

                </div>

                <p class="text-slate-600 leading-relaxed">
                    The program is one of the most versatile degrees in Engineering. Our program crosses many fields of study and makes students proficient in all forms of mechanical systems and design.
                </p>

            </div>

        </div>

    </div>
</section>

<!-- PROGRAM EDUCATIONAL OBJECTIVES -->
<section id="peo" class="relative py-28 overflow-hidden bg-gradient-to-br from-[#03140d] via-[#05261a] to-[#02110b] text-white scroll-mt-32">

    <!-- BACKGROUND IMAGE -->
    <div class="absolute inset-0">
        <img src="/images/offices/academic.png"
             alt="PEO Background"
             class="w-full h-full object-cover opacity-[0.08]">

        <div class="absolute inset-0 bg-gradient-to-br from-[#02110b]/90 via-[#05261a]/80 to-[#03140d]/95"></div>
    </div>

    <!-- GRID EFFECT -->
    <div class="absolute inset-0 opacity-[0.05]"
         style="background-image:
         linear-gradient(rgba(255,255,255,0.08) 1px, transparent 1px),
         linear-gradient(90deg, rgba(255,255,255,0.08) 1px, transparent 1px);
         background-size: 40px 40px;">
    </div>

    <!-- LARGE GLOW CIRCLES -->
    <div class="absolute -top-40 -left-32 w-[520px] h-[520px] rounded-full bg-[#008348]/20 blur-3xl"></div>

    <div class="absolute bottom-0 right-0 w-[480px] h-[480px] rounded-full bg-[#febe10]/15 blur-3xl"></div>

    <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2
                w-[700px] h-[700px] rounded-full border border-white/5">
    </div>

    <!-- TECHNOLOGY RINGS -->
    <div class="absolute top-24 right-20 w-72 h-72 rounded-full border border-[#febe10]/10"></div>

    <div class="absolute top-32 right-28 w-56 h-56 rounded-full border border-[#febe10]/10"></div>

    <div class="absolute top-40 right-36 w-40 h-40 rounded-full border border-[#febe10]/10"></div>

    <div class="absolute bottom-16 left-10 w-80 h-80 rounded-full border border-[#008348]/10"></div>

    <div class="absolute bottom-24 left-20 w-60 h-60 rounded-full border border-[#008348]/10"></div>

    <!-- FLOATING PARTICLES -->
    <div class="absolute top-[18%] left-[12%] w-5 h-5 rounded-full bg-[#febe10]/40 blur-sm"></div>

    <div class="absolute top-[30%] left-[18%] w-3 h-3 rounded-full bg-white/40"></div>

    <div class="absolute top-[22%] right-[20%] w-4 h-4 rounded-full bg-[#008348]/50"></div>

    <div class="absolute bottom-[18%] right-[15%] w-6 h-6 rounded-full bg-[#febe10]/30 blur-sm"></div>

    <div class="absolute bottom-[28%] left-[32%] w-3 h-3 rounded-full bg-white/40"></div>

    <!-- RADIAL LIGHT -->
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(255,255,255,0.05),transparent_65%)]"></div>

    <!-- CONTENT -->
    <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8">

        <!-- HEADER -->
        <div class="text-center max-w-3xl mx-auto mb-16">

            <span class="inline-flex items-center gap-2 px-5 py-2 rounded-full border border-[#febe10]/20 bg-white/5 backdrop-blur-md text-[#febe10] text-sm font-semibold tracking-[0.2em] uppercase">
                ✨ Future Engineers
            </span>

            <h2 class="mt-6 text-4xl md:text-5xl font-black leading-tight">
                Program Educational Objectives
            </h2>

            <p class="mt-5 text-slate-300 text-lg leading-relaxed">
                Guiding principles shaping future-ready engineers equipped with
                leadership, innovation, and lifelong learning.
            </p>

        </div>

        <!-- CARDS -->
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">

            <!-- CARD 1 -->
            <div class="group relative p-8 rounded-3xl bg-white/[0.06]
                        border border-white/10 backdrop-blur-2xl overflow-hidden
                        hover:bg-white/[0.10] transition duration-500
                        hover:-translate-y-3
                        hover:shadow-[0_0_40px_rgba(0,131,72,0.25)]">

                <div class="absolute inset-0 bg-gradient-to-br
                            from-[#008348]/10 to-transparent
                            opacity-0 group-hover:opacity-100
                            transition duration-500"></div>

                <div class="absolute -top-10 -right-10 w-32 h-32
                            bg-[#008348]/10 rounded-full blur-2xl"></div>

                <div class="relative z-10">

                    <div class="w-14 h-14 rounded-2xl bg-[#008348]/20
                                border border-[#febe10]/20
                                flex items-center justify-center mb-6
                                shadow-lg shadow-[#008348]/20">

                        <svg xmlns="http://www.w3.org/2000/svg"
                             class="w-7 h-7 text-[#febe10]"
                             fill="none"
                             viewBox="0 0 24 24"
                             stroke="currentColor"
                             stroke-width="1.8">
                            <path stroke-linecap="round"
                                  stroke-linejoin="round"
                                  d="M11.25 3L4.5 12h6.75L9 21l10.5-12h-6.75L15 3z"/>
                        </svg>

                    </div>

                    <h3 class="font-black text-xl mb-3">
                        Innovation
                    </h3>

                    <p class="text-slate-300 leading-relaxed text-sm">
                        Engaged in the practice of engineering or technopreneurship and innovation.
                    </p>

                </div>

            </div>

            <!-- CARD 2 -->
            <div class="group relative p-8 rounded-3xl bg-white/[0.06]
                        border border-white/10 backdrop-blur-2xl overflow-hidden
                        hover:bg-white/[0.10] transition duration-500
                        hover:-translate-y-3
                        hover:shadow-[0_0_40px_rgba(254,190,16,0.25)]">

                <div class="absolute inset-0 bg-gradient-to-br
                            from-[#febe10]/10 to-transparent
                            opacity-0 group-hover:opacity-100
                            transition duration-500"></div>

                <div class="absolute -bottom-10 -left-10 w-32 h-32
                            bg-[#febe10]/10 rounded-full blur-2xl"></div>

                <div class="relative z-10">

                    <div class="w-14 h-14 rounded-2xl bg-[#febe10]/10
                                border border-[#febe10]/20
                                flex items-center justify-center mb-6
                                shadow-lg shadow-[#febe10]/10">

                        <svg xmlns="http://www.w3.org/2000/svg"
                             class="w-7 h-7 text-[#febe10]"
                             fill="none"
                             viewBox="0 0 24 24"
                             stroke="currentColor"
                             stroke-width="1.8">
                            <path stroke-linecap="round"
                                  stroke-linejoin="round"
