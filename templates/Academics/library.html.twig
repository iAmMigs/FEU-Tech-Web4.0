                                    <span class="font-bold text-lg sm:text-xl text-feu-green">8:00 am — 5:00 pm</span>
                                </div>
                                <p class="text-sm italic font-medium text-red-500 bg-red-50 p-4 rounded-xl inline-block mt-6">Note: No service during Trimestral Break</p>
                            </div>

                            <!-- Mascot Placement (Outside Researchers - Subtle Outline) -->
