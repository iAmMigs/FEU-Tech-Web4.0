                                <img src="\images\offices\tammyjump.png" alt="Mascot" class="w-full h-full object-contain grayscale group-hover:grayscale-0">
                            </div>

                            <div class="relative z-10">
                                <span class="text-feu-green font-black text-5xl opacity-10 absolute -top-4 -left-2">02</span>
                                <h2 class="text-2xl font-black mb-4 text-feu-green uppercase tracking-tight">
                                    Mission
                                </h2>
                                <p class="text-slate-600 leading-relaxed font-medium">
                                    The mission of the FEU Tech Library is to provide service and develop a collection that will support the instructional, curricular, research and industry needs of the College.
                                </p>
                            </div>
                        </div>

