                        <div class="absolute top-0 right-0 w-32 h-32 bg-feu-yellow/10 rounded-full -mr-16 -mt-16"></div>
                        
                        <h2 class="text-4xl font-black mb-12 text-feu-green flex items-center gap-4">
                            <span class="bg-feu-yellow w-12 h-1"></span> 
                            HISTORY
                        </h2>

                        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
                            <!-- Image Content (Span 5) -->
