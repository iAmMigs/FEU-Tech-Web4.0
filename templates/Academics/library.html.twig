                <div class="relative overflow-hidden bg-white border border-slate-100 shadow-xl p-10">
                        <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(254,190,16,0.15),transparent_30%),radial-gradient(circle_at_bottom_left,rgba(0,131,72,0.10),transparent_35%)]"></div>

                        <div class="relative z-10 flex flex-col lg:flex-row lg:items-center lg:justify-between">
                            <div>
                                <p class="uppercase tracking-[0.35em] text-feu-green font-bold text-xs mb-3">
                                    FEU TECH KNOWLEDGE HUB
                                </p>

                                <h2 class="text-4xl md:text-5xl font-black text-feu-green uppercase tracking-tight leading-none">
                                    Library Services
                                </h2>
                            </div>

                            <div class="hidden lg:flex items-center gap-3">
                                <div class="h-3 w-3 rounded-full bg-feu-green animate-pulse"></div>
                                <div class="h-3 w-3 rounded-full bg-feu-yellow animate-pulse delay-100"></div>
                                <div class="h-3 w-3 rounded-full bg-feu-green animate-pulse delay-200"></div>
                            </div>
                        </div>
                    </div>

        <!-- TOP DESIGN -->
        <div class="absolute inset-0 opacity-[0.03]"
             style="background-image: linear-gradient(to right, #008348 1px, transparent 1px), linear-gradient(to bottom, #008348 1px, transparent 1px); background-size: 32px 32px;">
        </div>

        <!-- HEADER -->
        <div class="relative bg-feu-green px-10 py-12 overflow-hidden">
            <div class="absolute top-0 right-0 w-72 h-72 bg-feu-yellow/20 rounded-full blur-3xl"></div>

            <div class="relative z-10 flex flex-col lg:flex-row lg:items-center lg:justify-between gap-8">
                <div class="max-w-3xl">
                    <div class="flex items-center gap-4 mb-5">
                        <div class="bg-white/10 p-4 rounded-2xl border border-white/10 backdrop-blur-sm">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-9 w-9 text-feu-yellow" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
                            </svg>
                        </div>

                        <div>
                            <p class="text-feu-yellow uppercase text-xs tracking-[0.35em] font-bold mb-2">
                                Main Department
                            </p>

                            <h3 class="text-4xl font-black text-white uppercase tracking-tight">
                                Readers' Services
                            </h3>
                        </div>
                    </div>

                    <p class="text-white/85 text-lg leading-relaxed max-w-3xl">
                        The largest of the Library's departments, it serves the students, staff of the College, as well as visiting researchers and the general public who need to access the library's resources and services.
                    </p>
                </div>

                <div class="hidden xl:block relative">
                    <div class="absolute inset-0 bg-feu-yellow/30 blur-2xl rounded-full"></div>
                    <img src="\images\offices\tammywave.png"
                         alt="Mascot"
                         class="relative w-44 object-contain drop-shadow-2xl transition duration-500 hover:scale-105">
                </div>
            </div>
        </div>

        <!-- CONTENT -->
        <div class="relative p-8 md:p-10">

            <div class="grid md:grid-cols-2 xl:grid-cols-2 gap-6">

                <!-- CARD -->
                <div class="group relative overflow-hidden bg-slate-50 border border-slate-100 rounded-[2rem] p-7 hover:-translate-y-2 hover:shadow-2xl transition-all duration-500">
                    <div class="absolute top-0 left-0 h-1 w-full bg-feu-green"></div>

                    <div class="flex items-center justify-between mb-5">
                        <h4 class="text-xl font-black text-feu-green uppercase">
                            Circulation
                        </h4>

                        <span class="text-5xl font-black text-feu-green/10 group-hover:text-feu-yellow/20 transition">
                            01
                        </span>
                    </div>

                    <p class="text-sm leading-relaxed text-slate-600">
