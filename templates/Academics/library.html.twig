                                <div class="relative group">
                                    <div class="absolute -inset-2 border-2 border-feu-yellow/30 rounded-2xl translate-x-3 translate-y-3 transition-transform group-hover:translate-x-1 group-hover:translate-y-1"></div>
                                    
