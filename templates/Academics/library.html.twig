                                        <img 
                                            src="/images/offices/library_history.jpg" 
                                            alt="FEU Tech Library Archive" 
                                            class="w-full h-[400px] object-cover transition-transform duration-700 group-hover:scale-110"
                                        >
                                        <!-- Subtle Vintage Overlay -->
                                        <div class="absolute inset-0 bg-gradient-to-t from-feu-green/60 to-transparent opacity-40"></div>
                                    </div>
                                </div>
                            </div>

                            <!-- Text Content (Span 7) -->
                            <div class="lg:col-span-7 order-1 lg:order-2 space-y-8">
                                <div class="relative pl-8 border-l-4 border-feu-yellow/20">
                                    <span class="absolute -left-[10px] top-0 w-4 h-4 rounded-full bg-feu-yellow shadow-[0_0_10px_rgba(234,179,8,0.5)]"></span>
                                    <p class="text-slate-600 text-lg leading-relaxed italic">
                                        "The beginnings of the FEU Tech Library can be traced back to <span class="text-feu-green font-bold">1993</span> when it was still called <span class="font-bold text-feu-green">EAST ASIA INSTITUTE OF COMPUTER TECHNOLOGY</span>."
                                        The journey began with a modest collection of just <span class="font-semibold text-slate-900">386 volumes</span>. Following the landmark merger of the Engineering and IT colleges in 2003, our resource hub underwent a massive transformation to meet the demands of a new era in technology.
                                    </p>
                                </div>

                                <div class="space-y-6 text-slate-600 text-lg leading-relaxed">
                                    <p class="bg-slate-50 p-6 rounded-2xl border-l-4 border-feu-green">
                                        Today, we bridge the gap between tradition and innovation—where <span class="font-bold text-feu-green">physical archives meet digital intelligence</span>, ensuring our Tamaraws have the fastest access to global knowledge.
                                    </p>
                                </div>
                            </div>
                        </div>
                    </section>

                <!-- Service Hours Section -->
                <section id="service-hours" class="scroll-section p-10 bg-feu-green/5 rounded-3xl border border-slate-100">
                    <div class="relative mb-12">
