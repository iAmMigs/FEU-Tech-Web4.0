                        <div class="absolute -bottom-2 left-0 w-32 h-2 bg-feu-yellow rounded-full"></div>
                    </div>

                    <div class="grid md:grid-cols-2 gap-10 items-stretch">
                        <!-- Regular Term Card -->
                        <div class="bg-feu-green p-10 rounded-3xl text-white relative overflow-hidden shadow-2xl group hover:shadow-feu-yellow/20 transition-shadow duration-300">
                            <!-- Background Visuals -->
                            <div class="absolute top-0 right-0 w-64 h-64 bg-feu-yellow/20 rounded-full -mr-20 -mt-20 blur-2xl opacity-50 group-hover:opacity-100 transition-opacity"></div>
                            
                            <h3 class="text-2xl font-extrabold mb-10 flex items-center gap-3 relative z-10 text-feu-yellow">
                                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                Regular Term
                            </h3>
                            
                            <div class="space-y-6 relative z-10">
                                <div class="flex flex-col sm:flex-row sm:justify-between border-b border-white/10 pb-4">
                                    <span class="font-medium text-white/80">Monday — Friday</span>
                                    <span class="font-bold text-lg sm:text-xl text-feu-yellow">7:00 am — 8:00 pm</span>
                                </div>
                                <div class="flex flex-col sm:flex-row sm:justify-between border-b border-white/10 pb-4">
                                    <span class="font-medium text-white/80">Saturday</span>
                                    <span class="font-bold text-lg sm:text-xl text-feu-yellow">8:00 am — 5:00 pm</span>
                                </div>
                            </div>
                            
                            <!-- Mascot Placement (Regular Term) -->
                            <div class="absolute -bottom-10 -right-10 w-48 h-48 opacity-20 group-hover:opacity-100 group-hover:-translate-y-4 transition-all duration-500 ease-out z-0">
                                <img src="\images\offices\tammywave.png" alt="Tammy the Mascot waving" class="w-full h-full object-contain">
                            </div>
                        </div>

                        <!-- Outside Researchers Card -->
                        <div class="bg-white p-10 rounded-3xl border-2 border-slate-100 shadow-lg relative overflow-hidden group hover:border-feu-green/30 transition-all duration-300">
