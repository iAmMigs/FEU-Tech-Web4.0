{% extends 'base.html.twig' %}

{% block title %}FEU Tech Library | Knowledge Hub{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        :root {
            --feu-green: #008348;
            --feu-yellow: #febe10;
        }
        .text-feu-green { color: var(--feu-green); }
        .bg-feu-green { background-color: var(--feu-green); }
        .text-feu-yellow { color: var(--feu-yellow); }
        .bg-feu-yellow { background-color: var(--feu-yellow); }

        .hero-gradient {
            background: linear-gradient(rgba(0, 131, 72, 0.9), rgba(0, 45, 25, 0.95)), url('https://images.unsplash.com/photo-1507842217343-583bb7270b66?auto=format&fit=crop&q=80');
            background-size: cover;
            background-position: center;
        }

        .scroll-section {
            scroll-margin-top: 100px;
        }

        .custom-scrollbar::-webkit-scrollbar {
            width: 6px;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: var(--feu-green);
            border-radius: 10px;
        }

        .hover-card {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .hover-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
        }

        /* ACTIVE DIRECTORY HIGHLIGHT */
        .nav-link {
            position: relative;
        }
        .nav-link.active {
            background: var(--feu-green);
            color: white !important;
            transform: translateX(4px);
        }
        .nav-link.active::before {
            content: "";
            position: absolute;
            left: -6px;
            top: 50%;
            transform: translateY(-50%);
            width: 4px;
            height: 60%;
            background: var(--feu-yellow);
            border-radius: 10px;
        }

        /* FLOATING CIRCLES */
        .floating-circles {
            position: absolute;
            inset: 0;
            overflow: hidden;
            pointer-events: none;
        }
        .circle {
            position: absolute;
            border-radius: 50%;
            opacity: 0.15;
            animation: float 10s infinite ease-in-out;
        }
        .circle.one { width: 120px; height: 120px; background: #fff; top: 10%; left: 5%; }
        .circle.two { width: 80px; height: 80px; background: var(--feu-yellow); bottom: 15%; right: 10%; animation-duration: 14s; }
        .circle.three { width: 160px; height: 160px; background: #ffffff; top: 40%; right: 20%; animation-duration: 18s; }

        @keyframes float {
            0%, 100% { transform: translateY(0px); }
            50% { transform: translateY(-20px); }
        }
    </style>
{% endblock %}

{% block body %}
<main class="bg-slate-50">
    <!-- Hero Section -->
    <section class="hero-gradient text-white py-20 px-4 mb-12">
        <div class="max-w-7xl mx-auto text-center animate-fade-in">
            <h1 class="text-5xl md:text-6xl font-black mb-4 tracking-tight">FEU TECH <span class="text-feu-yellow">LIBRARY</span></h1>
            <p class="text-xl max-w-2xl mx-auto font-light opacity-90 italic">"The center of excellence in providing knowledge and quality information."</p>
            <div class="mt-10 flex flex-wrap justify-center gap-4">
                <a href="#services" class="bg-feu-yellow text-feu-green px-8 py-3 rounded-full font-bold hover:scale-105 transition-transform">Browse Services</a>
                <a href="#service-hours" class="border-2 border-white px-8 py-3 rounded-full font-bold hover:bg-white hover:text-feu-green transition-all">Check Hours</a>
            </div>
        </div>
    </section>

    <div class="max-w-7xl mx-auto px-4 lg:px-8 pb-20">
        <div class="flex flex-col lg:flex-row gap-12">

            <!-- Quick Navigation Sidebar -->
            <aside class="lg:w-1/4">
                <div class="sticky top-28 bg-white p-6 rounded-2xl shadow-sm border border-slate-100">
