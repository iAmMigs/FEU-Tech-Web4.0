                               class="nav-link block px-4 py-3 text-slate-600 hover:bg-feu-green hover:text-white rounded-xl transition-all font-medium">
                                {{ item }}
                            </a>
                        {% endfor %}
                    </nav>

                    <div class="mt-8 p-4 bg-feu-green/5 rounded-xl border border-feu-green/10">
                        <h4 class="text-feu-green font-bold text-sm uppercase mb-2">Quick Contact</h4>
                        <p class="text-xs text-slate-600">Local 120/150</p>
                        <p class="text-xs text-slate-600">library@feutech.edu.ph</p>
                    </div>
                </div>
            </aside>


            <!-- Main Content Area -->
            <div class="lg:w-3/4 space-y-20">

             <!-- Contact & Location Footer -->
                <section class="bg-white p-10 rounded-3xl shadow-sm border border-slate-100 flex flex-col md:flex-row justify-between items-center gap-8">
                    <div class="flex items-center gap-6">
                        <div class="bg-feu-green text-white p-4 rounded-2xl">
                            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                        </div>
                        <div>
                            <h4 class="font-bold text-slate-400 text-xs uppercase tracking-widest">Location</h4>
                            <p class="text-xl font-bold text-feu-green">Room 1401</p>
                            <p class="text-sm text-slate-500">FEU Institute of Technology</p>
                        </div>
                    </div>
                    <div class="h-10 w-px bg-slate-100 hidden md:block"></div>
                    <div class="text-center md:text-right">
                        <h4 class="font-bold text-slate-400 text-xs uppercase tracking-widest mb-2">Trunkline</h4>
                        <p class="text-lg font-bold text-slate-700">(02) 8281 8888</p>
                        <p class="text-sm font-medium text-feu-green">Local 120/150</p>
                    </div>
                </section>

                <!-- Vision & Mission Section -->
                <section id="vision-and-mission" class="scroll-section">
                    <div class="grid md:grid-cols-3 gap-8">
                        
                        <!-- Vision Card -->
                        <div class="group relative bg-white p-8 rounded-3xl border-t-8 border-feu-green shadow-sm hover:shadow-xl transition-all duration-300 overflow-hidden">
                            <!-- Decorative Background Mascot -->
                            <div class="absolute -right-4 -bottom-6 w-32 h-32 opacity-10 group-hover:opacity-100 group-hover:-translate-y-2 transition-all duration-500 pointer-events-none">
