{% extends 'base.html.twig' %}

{% block title %}General Education | FEU Institute of Technology{% endblock %}

{% block body %}

<!-- HERO SECTION -->
<section class="relative min-h-[92vh] overflow-hidden bg-[#03140d] flex items-center">

    <!-- Background -->
    <div class="absolute inset-0">
        <img src="/images/offices/academic.png"
             alt="General Education Hero"
             class="w-full h-full object-cover opacity-20">

        <div class="absolute inset-0 bg-gradient-to-br from-[#02110b]/80 via-[#05261a]/60 to-[#03140d]/85"></div>
    </div>

    <!-- Grid Overlay -->
    <div class="absolute inset-0 opacity-[0.06]"
         style="background-image:
         linear-gradient(rgba(255,255,255,0.08) 1px, transparent 1px),
         linear-gradient(90deg, rgba(255,255,255,0.08) 1px, transparent 1px);
         background-size: 42px 42px;">
    </div>

    <!-- Glow -->
    <div class="absolute top-0 left-0 w-[500px] h-[500px] bg-[#008348]/25 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 right-0 w-[500px] h-[500px] bg-[#febe10]/15 rounded-full blur-3xl"></div>

    <!-- Content -->
    <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 w-full">

        <div class="max-w-4xl">

            <span class="inline-flex items-center gap-2 px-5 py-2 rounded-full border border-[#febe10]/20 bg-[#008348]/20 text-[#febe10] text-sm font-semibold tracking-[0.2em] uppercase">

                <svg xmlns="http://www.w3.org/2000/svg"
                     fill="none"
                     viewBox="0 0 24 24"
                     stroke-width="1.8"
                     stroke="currentColor"
                     class="w-4 h-4">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M9.813 15.904L9 18l-.813-2.096A4.5 4.5 0 005.904 13.5L3.75 12l2.154-1.5A4.5 4.5 0 008.187 8.096L9 6l.813 2.096A4.5 4.5 0 0012.096 10.5L14.25 12l-2.154 1.5a4.5 4.5 0 00-2.283 2.404z"/>
                </svg>

                Inspire • Learn • Transform
            </span>

            <h1 class="mt-8 text-5xl md:text-7xl font-black text-white uppercase leading-[0.95]">
                General
                <span class="block text-transparent bg-clip-text bg-gradient-to-r from-white via-[#febe10] to-[#febe10]">
                    Education
                </span>
            </h1>

            <p class="mt-8 text-lg md:text-2xl text-slate-300 max-w-3xl leading-relaxed">
                Strengthening holistic education through humanities,
                social sciences, communication, mathematics,
                and physical sciences.
            </p>

            <div class="mt-10 flex flex-col sm:flex-row gap-4">

                <a href="#departments"
                   class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-2xl bg-[#008348] hover:bg-[#006839] text-white font-bold transition-all duration-300 hover:scale-105 shadow-lg shadow-[#008348]/20">

                    Explore Departments

                    <svg xmlns="http://www.w3.org/2000/svg"
                         fill="none"
                         viewBox="0 0 24 24"
                         stroke-width="2"
                         stroke="currentColor"
                         class="w-5 h-5">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
                    </svg>

                </a>

            </div>

        </div>

    </div>

</section>

<!-- STICKY NAV -->
<div class="sticky top-[80px] z-40 bg-[#03140d]/85 backdrop-blur-xl border-y border-white/5">

    <div class="max-w-7xl mx-auto px-6">

        <div class="flex overflow-x-auto gap-8 py-4 text-sm font-semibold uppercase tracking-wide text-slate-300 scrollbar-hide">

            <a href="#overview" class="hover:text-[#febe10] transition whitespace-nowrap">
                Overview
            </a>

            <a href="#departments" class="hover:text-[#febe10] transition whitespace-nowrap">
                Departments
            </a>

            <a href="#advantages" class="hover:text-[#febe10] transition whitespace-nowrap">
                Why General Education
            </a>

        </div>

    </div>

</div>

<!-- OVERVIEW -->
<section id="overview" class="py-28 bg-[#f8fafc] scroll-mt-32">

    <div class="max-w-7xl mx-auto px-6 lg:px-8">

        <div class="grid lg:grid-cols-2 gap-20 items-center">

            <!-- LEFT -->
            <div>

                <span class="text-[#008348] font-bold uppercase tracking-[0.2em] text-sm">
                    About General Education
                </span>

                <h2 class="mt-5 text-4xl md:text-5xl font-black text-slate-900 leading-tight">
                    Developing Holistic
                    and Future-Ready Learners
                </h2>

                <p class="mt-6 text-lg text-slate-600 leading-relaxed">
                    The General Education Department of FEU Institute of Technology
                    provides students with strong academic foundations through
                    interdisciplinary learning in humanities, communication,
                    mathematics, and the sciences.
                </p>

                <p class="mt-6 text-lg text-slate-600 leading-relaxed">
                    Through values-centered instruction and continuous professional
                    advancement, the department nurtures critical thinking,
                    analytical skills, communication competence, and social awareness
                    essential for lifelong success.
                </p>

            </div>

            <!-- ENHANCED SIDE CARDS -->
            <div class="grid gap-6">

                <div class="bg-white border border-slate-200 rounded-3xl p-7 shadow-sm hover:shadow-xl transition duration-300">

                    <div class="flex items-center gap-5">

                        <div class="w-16 h-16 rounded-2xl bg-[#008348]/10 flex items-center justify-center">

                            <svg xmlns="http://www.w3.org/2000/svg"
                                 class="w-8 h-8 text-[#008348]"
                                 fill="none"
                                 viewBox="0 0 24 24"
                                 stroke="currentColor"
                                 stroke-width="1.8">
                                <path stroke-linecap="round"
                                      stroke-linejoin="round"
                                      d="M3 7.5l9-4.5 9 4.5m-18 0l9 4.5m-9-4.5v9l9 4.5m0-9l9-4.5m-9 4.5v9"/>
                            </svg>

                        </div>

                        <div>
                            <h3 class="text-4xl font-black text-[#008348]">2</h3>
                            <p class="text-slate-600 font-medium mt-1">
                                Academic Departments
                            </p>
                        </div>

                    </div>

                </div>

                <div class="bg-white border border-slate-200 rounded-3xl p-7 shadow-sm hover:shadow-xl transition duration-300">

                    <div class="flex items-center gap-5">

                        <div class="w-16 h-16 rounded-2xl bg-[#febe10]/15 flex items-center justify-center">

                            <svg xmlns="http://www.w3.org/2000/svg"
                                 class="w-8 h-8 text-[#febe10]"
                                 fill="none"
                                 viewBox="0 0 24 24"
                                 stroke="currentColor"
                                 stroke-width="1.8">
                                <path stroke-linecap="round"
                                      stroke-linejoin="round"
                                      d="M9.75 17L15 12l-5.25-5"/>
                            </svg>

                        </div>

                        <div>
                            <h3 class="text-4xl font-black text-[#febe10]">100%</h3>
                            <p class="text-slate-600 font-medium mt-1">
                                Student-Centered Learning
                            </p>
                        </div>

                    </div>

                </div>

                <div class="bg-white border border-slate-200 rounded-3xl p-7 shadow-sm hover:shadow-xl transition duration-300">

                    <div class="flex items-center gap-5">

                        <div class="w-16 h-16 rounded-2xl bg-[#008348]/10 flex items-center justify-center">

                            <svg xmlns="http://www.w3.org/2000/svg"
                                 class="w-8 h-8 text-[#008348]"
                                 fill="none"
                                 viewBox="0 0 24 24"
                                 stroke="currentColor"
                                 stroke-width="1.8">
                                <path stroke-linecap="round"
                                      stroke-linejoin="round"
                                      d="M4.5 19.5l15-15m0 0v11.25m0-11.25H8.25"/>
                            </svg>

                        </div>

                        <div>
                            <h3 class="text-4xl font-black text-[#008348]">21st</h3>
                            <p class="text-slate-600 font-medium mt-1">
                                Century Skills Focus
                            </p>
                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

</section>

<!-- DEPARTMENTS -->
<section id="departments" class="py-28 bg-white scroll-mt-32">

    <div class="max-w-7xl mx-auto px-6 lg:px-8">

        <div class="text-center mb-16">
            <h2 class="text-4xl md:text-5xl font-black text-slate-800">
                Departments
            </h2>
        </div>

        <div class="grid md:grid-cols-2 gap-8">

            <!-- HSC -->
            <div class="group bg-white border border-slate-200 rounded-3xl p-8 shadow-sm hover:shadow-2xl transition duration-300 hover:-translate-y-2">
               
                <div class="flex items-start gap-5 mb-6">

                    <div class="w-16 h-16 rounded-2xl bg-[#008348]/10 flex items-center justify-center mb-5">

                        <svg xmlns="http://www.w3.org/2000/svg"
                             class="w-8 h-8 text-[#008348]"
                             fill="none"
                             viewBox="0 0 24 24"
                             stroke="currentColor"
                             stroke-width="1.8">
                            <path stroke-linecap="round"
                                  stroke-linejoin="round"
                                  d="M14.25 2.25v2.386c0 .516.214 1.01.593 1.364l5.043 4.72c1.062.994 1.364 2.534.755 3.84l-2.104 4.51A2.25 2.25 0 0116.5 20.25h-9a2.25 2.25 0 01-2.037-1.29l-2.104-4.51c-.609-1.306-.307-2.846.755-3.84l5.043-4.72a1.875 1.875 0 00.593-1.364V2.25m5.25 0h-6"/>
                        </svg>

                    </div>

                    <h3 class="text-xl font-black uppercase leading-snug text-[#008348]">
                        Humanities, Social Sciences and Communication
                    </h3>

                </div>

                <p class="text-slate-600 leading-relaxed">
                    With the goal of elevating the competency of each student,
                    the HSC Department of FEU Institute of Technology extends
                    its expertise to contribute to the overall development of
                    students through a set of knowledge areas and values integration.
                </p>

            </div>

            <!-- MPS -->
            <div class="group bg-white border border-slate-200 rounded-3xl p-8 shadow-sm hover:shadow-2xl transition duration-300 hover:-translate-y-2">

                <div class="flex items-start gap-5 mb-6">

                    <div class="w-16 h-16 rounded-2xl bg-[#febe10]/15 flex items-center justify-center mb-5">

                        <svg xmlns="http://www.w3.org/2000/svg"
                             class="w-8 h-8 text-[#febe10]"
                             fill="none"
                             viewBox="0 0 24 24"
                             stroke="currentColor"
                             stroke-width="1.8">
                            <path stroke-linecap="round"
                                  stroke-linejoin="round"
                                  d="M9 3h6a2.25 2.25 0 012.25 2.25v13.5A2.25 2.25 0 0115 21H9a2.25 2.25 0 01-2.25-2.25V5.25A2.25 2.25 0 019 3z"/>
                            <path stroke-linecap="round"
                                  stroke-linejoin="round"
                                  d="M9.75 7.5h4.5m-4.5 3h.008v.008H9.75V10.5zm2.25 0h.008v.008H12V10.5zm2.25 0h.008v.008H14.25V10.5zM9.75 13.5h.008v.008H9.75V13.5zm2.25 0h.008v.008H12V13.5zm2.25 0h.008v.008H14.25V13.5zM9.75 16.5h4.5"/>
                        </svg>

                    </div>

                    <h3 class="text-xl font-black uppercase leading-snug text-[#008348]">
                        Mathematics and Physical Sciences
                    </h3>

                </div>

                <p class="text-slate-600 leading-relaxed">
                    Striving to be a leader in establishing solid foundations
                    in engineering and technology, the Mathematics and Physical
                    Sciences (MPS) Department commits itself in providing quality
                    instruction through continuous professional advancement
                    of its Associates.
                </p>

            </div>

        </div>

    </div>

</section>

<!-- WHY CHOOSE -->
<section id="advantages" class="relative overflow-hidden py-28 bg-[#03140d] text-white scroll-mt-32">

   <!-- BACKGROUND IMAGE -->
    <div class="absolute inset-0">
        <img src="/images/offices/academic.png"
             alt="General Education Background"
             class="w-full h-full object-cover opacity-[0.08]">

        <div class="absolute inset-0 bg-gradient-to-br from-[#02110b]/90 via-[#05261a]/80 to-[#03140d]/95"></div>
    </div>

    <!-- GRID EFFECT -->
    <div class="absolute inset-0 opacity-[0.05]"
         style="background-image:
         linear-gradient(rgba(255,255,255,0.08) 1px, transparent 1px),
         linear-gradient(90deg, rgba(255,255,255,0.08) 1px, transparent 1px);
         background-size: 40px 40px;">
    </div>

    <!-- LARGE GLOW CIRCLES -->
    <div class="absolute -top-40 -left-32 w-[520px] h-[520px] rounded-full bg-[#008348]/20 blur-3xl"></div>

    <div class="absolute bottom-0 right-0 w-[480px] h-[480px] rounded-full bg-[#febe10]/15 blur-3xl"></div>

    <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2
                w-[700px] h-[700px] rounded-full border border-white/5">
    </div>

    <!-- TECHNOLOGY RINGS -->
    <div class="absolute top-24 right-20 w-72 h-72 rounded-full border border-[#febe10]/10"></div>

    <div class="absolute top-32 right-28 w-56 h-56 rounded-full border border-[#febe10]/10"></div>

    <div class="absolute top-40 right-36 w-40 h-40 rounded-full border border-[#febe10]/10"></div>

    <div class="absolute bottom-16 left-10 w-80 h-80 rounded-full border border-[#008348]/10"></div>

    <div class="absolute bottom-24 left-20 w-60 h-60 rounded-full border border-[#008348]/10"></div>

    <!-- FLOATING PARTICLES -->
    <div class="absolute top-[18%] left-[12%] w-5 h-5 rounded-full bg-[#febe10]/40 blur-sm"></div>

    <div class="absolute top-[30%] left-[18%] w-3 h-3 rounded-full bg-white/40"></div>

    <div class="absolute top-[22%] right-[20%] w-4 h-4 rounded-full bg-[#008348]/50"></div>

    <div class="absolute bottom-[18%] right-[15%] w-6 h-6 rounded-full bg-[#febe10]/30 blur-sm"></div>

    <div class="absolute bottom-[28%] left-[32%] w-3 h-3 rounded-full bg-white/40"></div>

    <!-- RADIAL LIGHT -->
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(255,255,255,0.05),transparent_65%)]"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8">

        <div class="text-center max-w-3xl mx-auto mb-20">

            <span class="inline-flex items-center gap-2 px-5 py-2 rounded-full border border-[#febe10]/20 bg-white/5 backdrop-blur-md text-[#febe10] text-sm font-semibold tracking-[0.2em] uppercase">
                ✨ Why choose General Education
            </span>

            <h2 class="mt-5 text-4xl md:text-5xl font-black">
                Experience Holistic
                Academic Development
            </h2>

        </div>

        <div class="grid md:grid-cols-3 gap-8">

            <div class="rounded-3xl bg-white/5 border border-white/10 p-8 backdrop-blur-md">

                <div class="w-14 h-14 rounded-2xl bg-[#008348]/20 flex items-center justify-center mb-6">

                    <svg xmlns="http://www.w3.org/2000/svg"
                         class="w-7 h-7 text-[#febe10]"
                         fill="none"
                         viewBox="0 0 24 24"
                         stroke="currentColor"
                         stroke-width="1.8">
                        <path stroke-linecap="round"
                              stroke-linejoin="round"
                              d="M12 6v6l4 2"/>
                    </svg>

                </div>

                <h3 class="text-2xl font-bold mb-4">
                    Values-Centered Education
                </h3>

                <p class="text-slate-300">
                    Promoting ethical leadership, social awareness,
                    and personal growth through transformative learning.
                </p>

            </div>

            <div class="rounded-3xl bg-white/5 border border-white/10 p-8 backdrop-blur-md">

                <div class="w-14 h-14 rounded-2xl bg-[#008348]/20 flex items-center justify-center mb-6">

                    <svg xmlns="http://www.w3.org/2000/svg"
                         class="w-7 h-7 text-[#febe10]"
                         fill="none"
                         viewBox="0 0 24 24"
                         stroke="currentColor"
                         stroke-width="1.8">
                        <path stroke-linecap="round"
                              stroke-linejoin="round"
                              d="M3.75 3v11.25A2.25 2.25 0 006 16.5h12M3.75 3h16.5v10.5H6A2.25 2.25 0 013.75 11.25V3z"/>
                    </svg>

                </div>

                <h3 class="text-2xl font-bold mb-4">
                    Strong Academic Foundations
                </h3>

                <p class="text-slate-300">
                    Building competencies in communication,
                    critical thinking, mathematics, and sciences.
                </p>

            </div>

            <div class="rounded-3xl bg-white/5 border border-white/10 p-8 backdrop-blur-md">

                <div class="w-14 h-14 rounded-2xl bg-[#008348]/20 flex items-center justify-center mb-6">

                    <svg xmlns="http://www.w3.org/2000/svg"
                         class="w-7 h-7 text-[#febe10]"
                         fill="none"
                         viewBox="0 0 24 24"
                         stroke="currentColor"
                         stroke-width="1.8">
                        <path stroke-linecap="round"
                              stroke-linejoin="round"
                              d="M9.813 15.904L9 18l-.813-2.096A4.5 4.5 0 005.904 13.5L3.75 12l2.154-1.5A4.5 4.5 0 008.187 8.096L9 6l.813 2.096A4.5 4.5 0 0012.096 10.5L14.25 12l-2.154 1.5a4.5 4.5 0 00-2.283 2.404z"/>
                    </svg>

                </div>

                <h3 class="text-2xl font-bold mb-4">
                    Continuous Professional Excellence
                </h3>

                <p class="text-slate-300">
                    Dedicated faculty members committed to quality instruction
                    and lifelong professional advancement.
                </p>

            </div>

        </div>

    </div>

</section>

{% endblock %}